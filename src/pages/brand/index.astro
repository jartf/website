---
import BaseLayout from "@/layouts/BaseLayout.astro";
import T from "@/components/T.astro";
import { Image } from 'astro:assets';
import { siteUrl, siteName } from '@/lib/constants';

const colors = [
  { key: "primary", dark: { value: "195 100% 65%", hex: "#54D4FF" }, light: { value: "195 100% 40%", hex: "#0099CC" } },
  { key: "background", dark: { value: "270 30% 10%", hex: "#1A0F2E" }, light: { value: "0 0% 100%", hex: "#FFFFFF" } },
  { key: "card", dark: { value: "270 25% 15%", hex: "#2A1F45" }, light: { value: "0 0% 100%", hex: "#FFFFFF" } },
  { key: "foreground", dark: { value: "0 0% 95%", hex: "#F2F2F2" }, light: { value: "240 10% 3.9%", hex: "#0A0A0F" } },
  { key: "muted", dark: { value: "270 25% 20%", hex: "#3A2F5A" }, light: { value: "240 4.8% 95.9%", hex: "#F4F4F5" } },
  { key: "border", dark: { value: "270 25% 25%", hex: "#4A3F6F" }, light: { value: "240 5.9% 90%", hex: "#E4E4E7" } },
];

const logos = [
  { key: "faceOnly", src: "/favicon", alt: "Jarema logo - face only", dimKey: "dimensions1" },
  { key: "faceAndBody", src: "/favicons", alt: "Jarema logo - face and body", dimKey: "dimensions2" }
];

const fontSamples = [
  { key: "english", text: "Sphinx of black quartz, judge my vow" },
  { key: "vietnamese", text: "Bốn phương phẳng lặng, hai kinh vững vàng" },
  { key: "polish", text: "Pchnąć w tę łódź jeża lub ośm skrzyń fig" },
  { key: "russian", text: "Друг мой эльф! Яшке б свёз птиц южных чащ!" },
  { key: "japanese", text: "色は匂えど散りぬるを" },
  { key: "hebrew", text: "דג סקרן שט בים, מאוכזב ולפתע מצא חברה" },
  { key: "thai", text: "เป็นมนุษย์สุดประเสริฐเลิศคุณค่า" },
  { key: "symbols", text: "0123456789-= !@#$%^&*()_+" }
];

const fonts = [
  { key: "spaceGrotesk", weight: "700", class: "font-heading", link: "https://fonts.google.com/specimen/Space+Grotesk", samples: fontSamples },
  { key: "lexend", weight: "400, 700", class: "font-body", link: "https://fonts.google.com/specimen/Lexend", samples: fontSamples },
  { key: "monaspice", weight: "400", class: "font-monaspice", link: "https://github.com/ryanoasis/nerd-fonts/tree/master/patched-fonts/Monaspace", samples: fontSamples },
  { key: "notoSansSC", weight: "400-700", class: "font-zh-hans", link: "https://fonts.google.com/specimen/Noto+Sans+SC", samples: [{ key: "chineseSimplified", text: "人有悲欢离合，月有阴晴圆缺，此事古难全。" }, { key: "chineseTraditional", text: "人有悲歡離合，月有陰晴圓缺，此事古難全。" }] },
  { key: "hanNomGothic", weight: "400", class: "font-vi-hani", link: "https://hannom-rcv.org/font.html", samples: [{ key: "vietnameseHanNom", text: "身㛪辰𤽸分㛪𧷺，𠤩浽𠀧沉買渃𡽫，硍湼默油𢬣几揑，𦓡㛪刎𡨹𬌓𢚸𣘈。" }] }
];

const usagePoints = ["point1", "point2", "point3", "point4"];
const cardClasses = "bg-card border rounded-lg p-6";
---

<BaseLayout title="Brand" description="Visual identity and brand elements. Use these if you want to reference or link to this site.">
  <div class="container mx-auto px-4 py-8 lg:py-12 max-w-4xl">
    <header class="mb-12 text-center">
      <T key="brand.pageTitle" tag="h1" class="text-4xl font-bold mb-4" />
      <T key="brand.pageDescription" tag="p" class="text-lg text-muted-foreground max-w-2xl mx-auto" />
    </header>

    <!-- Name -->
    <section class="mb-12">
      <T key="brand.name.title" tag="h2" class="text-2xl font-bold mb-6" />
      <div class={cardClasses} class:list={["space-y-4"]}>
        {[["nameLabel", "Jarema"], ["displayNameLabel", "∴ Jarema"]].map(([key, text], i) => (
          <div>
            <p class="text-sm text-muted-foreground mb-2"><T key={`brand.name.${key}`} /></p>
            <p class="text-2xl font-bold">{text}</p>
            {i === 1 && <p class="text-sm text-muted-foreground mt-2"><T key="brand.name.symbolNote" /></p>}
          </div>
        ))}
      </div>
    </section>

    <!-- Logo -->
    <section class="mb-12">
      <T key="brand.logo.title" tag="h2" class="text-2xl font-bold mb-6" />
      <div class="grid md:grid-cols-2 gap-6">
        {logos.map(({ key, src, alt, dimKey }) => (
          <div class={cardClasses}>
            <p class="text-sm font-medium mb-4"><T key={`brand.logo.${key}`} /></p>
            <div class="bg-background rounded p-8 mb-4 flex items-center justify-center">
              <Image src={`${src}.png`} alt={alt} width={128} height={128} class="pixelated" />
            </div>
            <div class="space-y-2">
              <div class="flex gap-2">
                {[{format: "png", key: "brand.logo.formats.png"}, {format: "svg", key: "brand.logo.formats.svg"}].map(({ format, key }) => (
                  <a href={`${src}.${format}`} target="_blank" class="flex-1 text-sm bg-muted hover:bg-muted/80 px-3 py-1.5 rounded text-center transition-colors"><T key={key} /></a>
                ))}
              </div>
              <p class="text-sm text-muted-foreground"><T key={`brand.logo.${dimKey}`} /></p>
            </div>
          </div>
        ))}
      </div>
    </section>

    <!-- Badge -->
    <section class="mb-12">
      <T key="brand.badge.title" tag="h2" class="text-2xl font-bold mb-6" />
      <div class={cardClasses}>
        <div class="text-center mb-6">
          <Image src="/badge.png" alt="Jarema's badge" width={176} height={62} class="pixelated mx-auto" />
        </div>
        <div class="space-y-4">
          <div>
            <p class="text-sm text-muted-foreground mb-1"><T key="brand.badge.urlLabel" /></p>
            <code class="block bg-muted p-2 rounded text-sm overflow-x-auto select-all">{siteUrl}/badge.png</code>
          </div>
          <div>
            <p class="text-sm text-muted-foreground mb-1"><T key="brand.badge.htmlLabel" /></p>
            <pre class="bg-muted p-2 rounded text-sm overflow-x-auto select-all"><code>{`<a href="${siteUrl}/">
  <img src="${siteUrl}/badge.png" alt="${siteName}" width="88" height="31" style="image-rendering: pixelated;">
</a>`}</code></pre>
          </div>
        </div>
      </div>
    </section>

    <!-- Colors -->
    <section class="mb-12">
      <T key="brand.colors.title" tag="h2" class="text-2xl font-bold mb-6" />
      <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-4">
        {colors.map(({ key, dark, light }) => (
          <div class={cardClasses} class:list={["p-4"]}>
            <div class="mb-3">
              <T key={`brand.colors.names.${key}`} tag="p" class="font-medium mb-1" />
              <T key={`brand.colors.descriptions.${key}`} tag="p" class="text-sm text-muted-foreground" />
            </div>
            <div class="space-y-3">
              {[{ modeKey: "darkMode", data: dark }, { modeKey: "lightMode", data: light }].map(({ modeKey, data }) => (
                <div>
                  <T key={`brand.colors.${modeKey}`} tag="p" class="text-sm text-muted-foreground mb-2" />
                  <div class="flex items-center gap-2 mb-1">
                    <div class="w-8 h-8 rounded border border-border flex-shrink-0" style={`background-color: ${data.hex}`} />
                    <code class="text-sm bg-muted px-2 py-1 rounded flex-1">{data.hex}</code>
                  </div>
                  <code class="block text-sm bg-muted px-2 py-1 rounded">hsl({data.value})</code>
                </div>
              ))}
            </div>
          </div>
        ))}
      </div>
    </section>

    <!-- Fonts -->
    <section class="mb-12">
      <T key="brand.fonts.title" tag="h2" class="text-2xl font-bold mb-6" />
      <div class="space-y-6">
        {fonts.map(({ key, weight, link, samples, class: fontClass }) => (
          <div class={cardClasses}>
            <div class="mb-4 flex items-start justify-between gap-4">
              <div>
                <T key={`brand.fonts.names.${key}`} tag="h3" class="font-bold text-lg mb-1" />
                <T key={`brand.fonts.usage.${key}`} tag="p" class="text-sm text-muted-foreground mb-1" />
                <p class="text-sm text-muted-foreground"><T key="brand.fonts.weight" /> {weight}</p>
              </div>
              <a href={link} target="_blank" rel="noopener noreferrer" class="text-sm bg-muted hover:bg-muted/80 px-4 py-2 rounded transition-colors whitespace-nowrap">
                <T key="brand.fonts.viewOnGoogleFonts" />
              </a>
            </div>
            <div class="bg-background rounded p-6 grid md:grid-cols-2 gap-4">
              {samples.map(({ key: langKey, text }) => (
                <div>
                  <T key={`brand.fonts.languages.${langKey}`} tag="p" class="text-sm text-muted-foreground mb-1" />
                  <p class:list={["text-base", fontClass, key === "spaceGrotesk" && "font-bold"]}>{text}</p>
                </div>
              ))}
            </div>
          </div>
        ))}
      </div>
    </section>

    <!-- Usage -->
    <section class="mb-12">
      <T key="brand.usage.title" tag="h2" class="text-2xl font-bold mb-6" />
      <div class={cardClasses} class:list={["space-y-4"]}>
        {usagePoints.map(point => (
          <div>
            <p class="font-medium mb-2"><T key={`brand.usage.${point}Title`} /></p>
            <p class="text-sm text-muted-foreground"><T key={`brand.usage.${point}Text`} /></p>
          </div>
        ))}
      </div>
      <p class="text-sm text-muted-foreground mt-4 text-center"><T key="brand.usage.footer" /></p>
    </section>

    <div class="text-center">
      <a href="#" class="text-sm text-muted-foreground hover:text-primary transition-colors">↑ Back to top</a>
    </div>
  </div>
</BaseLayout>
