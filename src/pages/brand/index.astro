---
import BaseLayout from "@/layouts/BaseLayout.astro";
import T from "@/components/T.astro";
import { Image } from 'astro:assets';

const colors = [
  { name: "Primary", dark: { value: "195 100% 65%", hex: "#54D4FF" }, light: { value: "195 100% 40%", hex: "#0099CC" }, desc: "Main accent color" },
  { name: "Background", dark: { value: "270 30% 10%", hex: "#1A0F2E" }, light: { value: "0 0% 100%", hex: "#FFFFFF" }, desc: "Page background" },
  { name: "Card", dark: { value: "270 25% 15%", hex: "#2A1F45" }, light: { value: "0 0% 100%", hex: "#FFFFFF" }, desc: "Card background" },
  { name: "Foreground", dark: { value: "0 0% 95%", hex: "#F2F2F2" }, light: { value: "240 10% 3.9%", hex: "#0A0A0F" }, desc: "Main text color" },
  { name: "Muted", dark: { value: "270 25% 20%", hex: "#3A2F5A" }, light: { value: "240 4.8% 95.9%", hex: "#F4F4F5" }, desc: "Muted elements" },
  { name: "Border", dark: { value: "270 25% 25%", hex: "#4A3F6F" }, light: { value: "240 5.9% 90%", hex: "#E4E4E7" }, desc: "Borders and dividers" },
];

const logos = [
  { key: "faceOnly", src: "/favicon", alt: "Jarema logo - face only", dimKey: "dimensions1" },
  { key: "faceAndBody", src: "/favicons", alt: "Jarema logo - face and body", dimKey: "dimensions2" }
];

const fontSamples = [
  { lang: "English", text: "Sphinx of black quartz, judge my vow" },
  { lang: "Vietnamese", text: "Trời xanh quen với má hồng đánh ghen" },
  { lang: "Polish", text: "Pchnąć w tę łódź jeża lub ośm skrzyń fig" },
  { lang: "Russian", text: "Съешь ещё этих мягких французских булок, да выпей же чаю" },
  { lang: "Japanese", text: "色は匂えど散りぬるを" },
  { lang: "Hebrew", text: "דג סקרן שט בים, מאוכזב ולפתע מצא חברה" },
  { lang: "Symbols", text: "0123456789-= !@#$%^&*()_+" }
];

const fonts = [
  { name: "Space Grotesk", usage: "Headings and titles", weight: "400-700", class: "font-heading", link: "https://fonts.google.com/specimen/Space+Grotesk", samples: fontSamples },
  { name: "Lexend", usage: "Body text and UI elements", weight: "400-700", class: "font-body", link: "https://fonts.google.com/specimen/Lexend", samples: fontSamples },
  { name: "Noto Sans SC", usage: "Chinese text (Simplified)", weight: "400-700", class: "font-noto-sans-sc", link: "https://fonts.google.com/specimen/Noto+Sans+SC", samples: [{ lang: "Chinese (Simplified)", text: "床前明月光，疑是地上霜。举头望明月，低头思故乡。" }] },
  { name: "Han Nom Gothic", usage: "Vietnamese Chữ Nôm", weight: "400", class: "font-han-nom", link: "https://hannom-rcv.org/font.html", samples: [{ lang: "Vietnamese Chữ Nôm", text: "身㛪辰𤽸分㛪𧷺，𠤩浽𠀧沉買渃𡽫，硍湼默油𢬣几揑，𦓡㛪刎𡨹𬌓𢚸𣘈。" }] }
];

const usagePoints = ["point1", "point2", "point3", "point4"];
const cardClasses = "bg-card border rounded-lg p-6";
---

<BaseLayout title="Brand" description="Visual identity and brand elements. Use these if you want to reference or link to this site.">
  <div class="container mx-auto px-4 py-8 lg:py-12 max-w-4xl">
    <header class="mb-12 text-center">
      <T key="brand.pageTitle" tag="h1" class="text-4xl font-bold mb-4" />
      <T key="brand.pageDescription" tag="p" class="text-lg text-muted-foreground max-w-2xl mx-auto" />
    </header>

    <!-- Name -->
    <section class="mb-12">
      <T key="brand.name.title" tag="h2" class="text-2xl font-bold mb-6" />
      <div class={cardClasses} class:list={["space-y-4"]}>
        {[["nameLabel", "Jarema"], ["displayNameLabel", "∴ Jarema"]].map(([key, text], i) => (
          <div>
            <p class="text-sm text-muted-foreground mb-2"><T key={`brand.name.${key}`} /></p>
            <p class="text-2xl font-bold">{text}</p>
            {i === 1 && <p class="text-sm text-muted-foreground mt-2"><T key="brand.name.symbolNote" /></p>}
          </div>
        ))}
      </div>
    </section>

    <!-- Logo -->
    <section class="mb-12">
      <T key="brand.logo.title" tag="h2" class="text-2xl font-bold mb-6" />
      <div class="grid md:grid-cols-2 gap-6">
        {logos.map(({ key, src, alt, dimKey }) => (
          <div class={cardClasses}>
            <p class="text-sm font-medium mb-4"><T key={`brand.logo.${key}`} /></p>
            <div class="bg-background rounded p-8 mb-4 flex items-center justify-center">
              <Image src={`${src}.png`} alt={alt} width={128} height={128} class="pixelated" />
            </div>
            <div class="space-y-2">
              <div class="flex gap-2">
                {["PNG", "SVG"].map(format => (
                  <a href={`${src}.${format.toLowerCase()}`} target="_blank" class="flex-1 text-sm bg-muted hover:bg-muted/80 px-3 py-1.5 rounded text-center transition-colors">{format}</a>
                ))}
              </div>
              <p class="text-sm text-muted-foreground"><T key={`brand.logo.${dimKey}`} /></p>
            </div>
          </div>
        ))}
      </div>
    </section>

    <!-- Badge -->
    <section class="mb-12">
      <T key="brand.badge.title" tag="h2" class="text-2xl font-bold mb-6" />
      <div class={cardClasses}>
        <div class="text-center mb-6">
          <Image src="/badge.png" alt="Jarema's badge" width={176} height={62} class="pixelated mx-auto" />
        </div>
        <div class="space-y-4">
          <div>
            <p class="text-sm text-muted-foreground mb-1"><T key="brand.badge.urlLabel" /></p>
            <code class="block bg-muted p-2 rounded text-sm overflow-x-auto select-all">https://jarema.me/badge.png</code>
          </div>
          <div>
            <p class="text-sm text-muted-foreground mb-1"><T key="brand.badge.htmlLabel" /></p>
            <pre class="bg-muted p-2 rounded text-sm overflow-x-auto select-all"><code>{`<a href="https://jarema.me/">
  <img src="https://jarema.me/badge.png" alt="Jarema's digital garden" width="88" height="31" style="image-rendering: pixelated;">
</a>`}</code></pre>
          </div>
        </div>
      </div>
    </section>

    <!-- Colors -->
    <section class="mb-12">
      <T key="brand.colors.title" tag="h2" class="text-2xl font-bold mb-6" />
      <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-4">
        {colors.map(({ name, dark, light, desc }) => (
          <div class={cardClasses} class:list={["p-4"]}>
            <div class="mb-3">
              <p class="font-medium mb-1">{name}</p>
              <p class="text-sm text-muted-foreground">{desc}</p>
            </div>
            <div class="space-y-3">
              {[{ mode: "Dark mode", data: dark }, { mode: "Light mode", data: light }].map(({ mode, data }) => (
                <div>
                  <p class="text-sm text-muted-foreground mb-2">{mode}</p>
                  <div class="flex items-center gap-2 mb-1">
                    <div class="w-8 h-8 rounded border border-border flex-shrink-0" style={`background-color: ${data.hex}`} aria-label={`${name} ${mode.toLowerCase()} color preview`} />
                    <code class="text-sm bg-muted px-2 py-1 rounded flex-1">{data.hex}</code>
                  </div>
                  <code class="block text-sm bg-muted px-2 py-1 rounded">hsl({data.value})</code>
                </div>
              ))}
            </div>
          </div>
        ))}
      </div>
    </section>

    <!-- Fonts -->
    <section class="mb-12">
      <T key="brand.fonts.title" tag="h2" class="text-2xl font-bold mb-6" />
      <div class="space-y-6">
        {fonts.map(({ name, usage, weight, link, samples, class: fontClass }) => (
          <div class={cardClasses}>
            <div class="mb-4 flex items-start justify-between gap-4">
              <div>
                <h3 class="font-bold text-lg mb-1">{name}</h3>
                <p class="text-sm text-muted-foreground mb-1">{usage}</p>
                <p class="text-sm text-muted-foreground">Weight: {weight}</p>
              </div>
              <a href={link} target="_blank" rel="noopener noreferrer" class="text-sm bg-muted hover:bg-muted/80 px-4 py-2 rounded transition-colors whitespace-nowrap">
                View on Google Fonts
              </a>
            </div>
            <div class="bg-background rounded p-6 space-y-4">
              {samples.map(({ lang, text }, i) => (
                <div>
                  <p class="text-sm text-muted-foreground mb-1">{lang}</p>
                  <p class:list={[i === 0 ? "text-xl" : "text-base", fontClass]}>{text}</p>
                </div>
              ))}
            </div>
          </div>
        ))}
      </div>
    </section>

    <!-- Usage -->
    <section class="mb-12">
      <T key="brand.usage.title" tag="h2" class="text-2xl font-bold mb-6" />
      <div class={cardClasses} class:list={["space-y-4"]}>
        {usagePoints.map(point => (
          <div>
            <p class="font-medium mb-2"><T key={`brand.usage.${point}Title`} /></p>
            <p class="text-sm text-muted-foreground"><T key={`brand.usage.${point}Text`} /></p>
          </div>
        ))}
      </div>
      <p class="text-sm text-muted-foreground mt-4 text-center"><T key="brand.usage.footer" /></p>
    </section>

    <div class="text-center">
      <a href="#" class="text-sm text-muted-foreground hover:text-primary transition-colors">↑ Back to top</a>
    </div>
  </div>
</BaseLayout>

<style>
  .pixelated {
    image-rendering: pixelated;
    image-rendering: -moz-crisp-edges;
    image-rendering: crisp-edges;
  }
</style>
