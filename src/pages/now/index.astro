---
import BaseLayout from "@/layouts/BaseLayout.astro";
import T from "@/components/T.astro";
import { nowItems } from "@/content/now-items";
import { translations } from "@/i18n";

const iconMap: Record<string, string> = {
  Headphones: "🎧", BookOpen: "📚", Code: "💻", Coffee: "☕",
  Brain: "🧠", GraduationCap: "🎓", Activity: "📡", Lightbulb: "💡",
};

const sortedItems = [...nowItems].sort((a, b) => new Date(b.date).getTime() - new Date(a.date).getTime());
const getCategoryTranslation = (category: string) => translations.en.now?.categories?.[category] || category;
---

<BaseLayout title="Now" description="What I'm currently up to, thinking about, and focused on.">
  <div class="container mx-auto px-4 py-8 lg:py-12" id="now-page">
    <div class="max-w-3xl mx-auto">
      <header class="text-center mb-10">
        <T key="now.title" tag="h1" class="text-4xl font-bold mb-4" />
        <T key="now.description" tag="p" class="text-muted-foreground text-lg mx-auto" />
        {sortedItems.length > 0 && (
          <p class="text-sm text-muted-foreground/70 mt-4">
            <span data-i18n="now.lastUpdated">Last updated</span>:
            <time id="last-updated-date" data-date={sortedItems[0].date} datetime={sortedItems[0].date}>
              {new Date(sortedItems[0].date).toLocaleDateString("en", { year: "numeric", month: "long", day: "numeric" })}
            </time>
          </p>
        )}
      </header>

      <!-- What is a /now page? -->
      <div class="mb-8 p-6 border rounded-lg bg-muted/30">
        <T key="now.whatIsNow" tag="h2" class="font-semibold mb-2" />
        <p class="text-muted-foreground text-sm">
          <T key="now.whatIsNowDescription" />
          {" "}
          <a href="https://nownownow.com/about" target="_blank" rel="noopener noreferrer" class="text-primary hover:underline">nownownow.com</a>
        </p>
      </div>

      <div class="grid gap-6" id="now-items-container">
        {sortedItems.map((item) => (
          <article
            class="border rounded-lg p-6 bg-card hover:shadow-md transition-shadow"
            data-category={item.category}
            data-now-content={JSON.stringify(item.content)}
            data-now-content-secondary={item.contentSecondary && JSON.stringify(item.contentSecondary)}
          >
            <div class="flex items-start gap-4">
              <span class="text-3xl flex-shrink-0" aria-hidden="true">{iconMap[item.icon] || "📌"}</span>
              <div class="flex-1 min-w-0">
                <h2 class="font-semibold text-lg mb-2" data-i18n={`now.categories.${item.category}`}>
                  {getCategoryTranslation(item.category)}
                </h2>
                <div class="flex items-center gap-3 overflow-hidden">
                  {item.image && <img src={item.image} alt="Cover art" class="w-12 h-12 rounded-lg flex-shrink-0" loading="lazy" decoding="async" />}
                  {item.contentSecondary ? (
                    <div class="flex-1 min-w-0 overflow-hidden">
                      <p class="now-text font-semibold break-words block">{item.content.en}</p>
                      <p class="now-subtext text-sm text-muted-foreground break-words">{item.contentSecondary.en}</p>
                    </div>
                  ) : (
                    <p class="now-text min-w-0">{item.content.en}</p>
                  )}
                </div>
                <time class="text-xs text-muted-foreground mt-3 block" datetime={item.date} data-date={item.date}>
                  {new Date(item.date).toLocaleDateString("en", {
                    year: "numeric", month: "long", day: "numeric",
                    hour: "2-digit", minute: "2-digit", timeZoneName: "short",
                  })}
                </time>
              </div>
            </div>
          </article>
        ))}
      </div>
    </div>
  </div>
</BaseLayout>

<script>
  import { languageStore, t } from "@/i18n";

  interface PremidActivity {
    name: string;
    details?: string;
    state?: string;
    assets?: {
      large_image?: string;
      large_text?: string;
      small_image?: string;
      small_text?: string;
    };
  }

  const iconMap = { Headphones: "🎧", Activity: "📡" };

  const createActivityCard = (activity: PremidActivity): string => {
    const { assets } = activity;
    const largeImg = assets?.large_image ?
      `<div class="relative w-12 h-12 flex-shrink-0">
        <img src="${assets.large_image}" alt="${assets.large_text || activity.name}" class="w-12 h-12 rounded-lg" loading="lazy" />
        ${assets.small_image ? `<img src="${assets.small_image}" alt="${assets.small_text || ""}" class="absolute -bottom-1 -right-1 w-6 h-6 rounded-full border-1 border-background bg-background" loading="lazy" />` : ''}
      </div>` : '';

    return `<div class="flex items-center gap-3 overflow-hidden">${largeImg}
      <div class="flex-1 min-w-0 overflow-hidden">
        <span class="font-semibold break-words block">${activity.name}</span>
        ${activity.details ? `<p class="text-sm break-words">${activity.details}</p>` : ''}
        ${activity.state ? `<p class="text-sm text-muted-foreground break-words">${activity.state}</p>` : ''}
      </div></div>`;
  };

  const enhanceWithLiveData = async () => {
    const container = document.getElementById("now-items-container");
    if (!container) return;

    try {
      const [lastfmRes, premidRes] = await Promise.all([
        fetch("/api/lastfm").catch(() => null),
        fetch("/api/premid").catch(() => null),
      ]);

      const liveItems: any[] = [];

      // Parse Last.fm
      if (lastfmRes?.ok) {
        const xml = await lastfmRes.text();
        const doc = new DOMParser().parseFromString(xml, "application/xml");
        const tracks = Array.from(doc.getElementsByTagName("track"));

        if (tracks.length) {
          const track = tracks.find(t => t.getAttribute("nowplaying") === "true") || tracks[0];
          const name = track?.getElementsByTagName("name")[0]?.textContent || "";
          const artist = track?.getElementsByTagName("artist")[0]?.textContent || "";

          if (name && artist) {
            const nowplaying = track?.getAttribute("nowplaying") === "true";
            let date: string | undefined = undefined;

            if (!nowplaying) {
              const dateElem = track?.getElementsByTagName("date")[0];
              if (dateElem) {
                const uts = dateElem.getAttribute("uts");
                if (uts) {
                  date = new Date(Number(uts) * 1000).toLocaleString("en", {
                    year: "numeric",
                    month: "long",
                    day: "numeric",
                    hour: "2-digit",
                    minute: "2-digit",
                    timeZoneName: "short",
                  });
                }
              }
            }

            liveItems.push({
              type: "lastfm",
              category: "listening",
              name,
              artist,
              url: track?.getElementsByTagName("url")[0]?.textContent || "",
              nowplaying,
              date,
              image: Array.from(track?.getElementsByTagName("image") || [])
                .find(img => img.getAttribute("size") === "large")?.textContent?.trim() || "",
            });
          }
        }
      }

      // Parse PreMID
      if (premidRes?.ok) {
        const data = await premidRes.json();
        if (data.activities?.length) {
          liveItems.push({
            type: "premid",
            category: "premid",
            activities: data.activities.map((a: any) => a.activity),
          });
        }
      }

      if (liveItems.length) {
        // Remove conflicting static items
        container.querySelectorAll("article").forEach(article => {
          const category = article.getAttribute("data-category");
          if ((category === "listening" && liveItems.some(i => i.type === "lastfm")) ||
              (category === "premid" && liveItems.some(i => i.type === "premid"))) {
            article.remove();
          }
        });

        // Build and insert live items HTML
        const html = liveItems.map(item => {
          const icon = iconMap[item.type === "lastfm" ? "Headphones" : "Activity"];

          let content = '';
          if (item.type === "lastfm") {
            const categoryLabel = t("now.categories.listening") || "Listening";
            content = `
              <div class="flex items-center gap-2 mb-2">
                <h2 class="font-semibold text-lg" data-i18n="now.categories.listening">${categoryLabel}</h2>
                ${item.nowplaying ? '<span class="ml-2 text-sm font-bold text-red-600 dark:text-white dark:bg-red-600 px-2 py-0.5 rounded animate-pulse">Live</span>' : ''}
              </div>
              <div class="flex items-center gap-3 overflow-hidden">
                ${item.image ? `<img src="${item.image}" alt="${item.name} cover art" class="w-12 h-12 rounded-lg flex-shrink-0" loading="lazy" decoding="async" />` : ''}
                <div class="flex-1 min-w-0 overflow-hidden">
                  <a href="${item.url}" target="_blank" rel="noopener noreferrer" class="hover:underline font-semibold break-words block">${item.name}</a>
                  <p class="text-sm text-muted-foreground break-words">${item.artist}</p>
                </div>
              </div>
              ${item.date && !item.nowplaying ? `<div class="text-xs text-muted-foreground mt-2">${item.date}</div>` : ''}`;
          } else {
            const categoryLabel = t("now.categories.premid") || "Discord activity";
            content = `
              <div class="flex items-center gap-2 mb-2">
                <h2 class="font-semibold text-lg" data-i18n="now.categories.premid">${categoryLabel}</h2>
                <span class="ml-2 text-sm font-bold text-red-600 dark:text-white dark:bg-red-600 px-2 py-0.5 rounded animate-pulse">Live</span>
              </div>
              <div class="space-y-3">${item.activities.map(createActivityCard).join('')}</div>`;
          }

          return `<article class="border rounded-lg p-6 bg-card hover:shadow-md transition-shadow">
            <div class="flex items-start gap-4">
              <span class="text-3xl flex-shrink-0" aria-hidden="true">${icon}</span>
              <div class="flex-1 min-w-0">${content}</div>
            </div>
          </article>`;
        }).join('');

        container.insertAdjacentHTML("afterbegin", html);
        updateNowPageTranslations();
      }
    } catch (error) {
      console.error("Failed to enhance with live data:", error);
    }
  };

  const updateNowPageTranslations = () => {
    const page = document.getElementById("now-page");
    if (!page) return;

    const lang = languageStore.get();

    // Update i18n keys
    page.querySelectorAll("[data-i18n]").forEach(el => {
      const key = el.getAttribute("data-i18n");
      if (key) {
        const translated = t(key);
        if (translated !== key) el.textContent = translated;
      }
    });

    // Update dynamic content
    page.querySelectorAll("[data-now-content]").forEach(article => {
      try {
        const content = JSON.parse(article.getAttribute("data-now-content") || "");
        const textEl = article.querySelector(".now-text");
        if (textEl) textEl.textContent = content[lang] || content.en;

        const secondaryData = article.getAttribute("data-now-content-secondary");
        const subTextEl = article.querySelector(".now-subtext");
        if (secondaryData && subTextEl) {
          const secondary = JSON.parse(secondaryData);
          subTextEl.textContent = secondary[lang] || secondary.en;
        }
      } catch {}
    });

    // Update dates
    page.querySelectorAll("[data-date]").forEach(el => {
      const dateStr = el.getAttribute("data-date");
      if (dateStr) {
        el.textContent = new Date(dateStr).toLocaleDateString(lang, {
          year: "numeric", month: "long", day: "numeric",
          hour: "2-digit", minute: "2-digit", timeZoneName: "short",
        });
      }
    });
  };

  const setupNowPage = async () => {
    await enhanceWithLiveData();
    updateNowPageTranslations();
  };

  // Initialize
  setupNowPage();

  declare global { interface Window { __nowPageInitialized?: boolean; } }

  if (!window.__nowPageInitialized) {
    window.__nowPageInitialized = true;
    languageStore.subscribe(updateNowPageTranslations);
    window.addEventListener("languageChange", updateNowPageTranslations);
    document.addEventListener("astro:after-swap", setupNowPage);
  }
</script>
