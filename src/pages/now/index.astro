---
// Now page
import BaseLayout from "@/layouts/BaseLayout.astro";
import T from "@/components/T.astro";
import { nowItems } from "@/content/now-items";
import { translations } from "@/i18n";

// Icon mapping
const iconMap: Record<string, string> = {
  Headphones: "🎧",
  BookOpen: "📚",
  Code: "💻",
  Coffee: "☕",
  Brain: "🧠",
  GraduationCap: "🎓",
  Activity: "📡",
  Lightbulb: "💡",
};

// Sort items by date descending
const sortedItems = [...nowItems].sort((a, b) => new Date(b.date).getTime() - new Date(a.date).getTime(),
);

// Helper function to get category translation
function getCategoryTranslation(category: string): string {
  return translations.en.now?.categories?.[category] || category;
}
---

<BaseLayout title="Now" description="What I'm currently up to, thinking about, and focused on.">
  <div class="container mx-auto px-4 py-8 lg:py-12" id="now-page">
    <div class="max-w-3xl mx-auto">
      <header class="text-center mb-10">
        <T key="now.title" tag="h1" class="text-4xl font-bold mb-4" />
        <T key="now.description" tag="p" class="text-muted-foreground text-lg mx-auto" />
        <p class="text-sm text-muted-foreground/70 mt-4">
          <span data-i18n="now.lastUpdated">Last updated</span>: <time id="last-updated-date"
            data-date={sortedItems.length > 0 ? sortedItems[0].date : ""}
            datetime={sortedItems.length > 0 ? sortedItems[0].date : ""}
            >{
              sortedItems.length > 0
                ? new Date(sortedItems[0].date).toLocaleDateString("en", { year: "numeric", month: "long", day: "numeric", }) : ""
            }</time>
        </p>
      </header>

      <!-- What is a /now page? -->
      <div class="mb-8 p-6 border rounded-lg bg-muted/30">
        <T key="now.whatIsNow" tag="h2" class="font-semibold mb-2" />
        <p class="text-muted-foreground text-sm">
          <span data-i18n="now.whatIsNowDescription">A now page is a page on a personal website that tells you what a person is focused on at the current time, day, or very recently. You can learn more at</span>
          {" "}
          <a href="https://nownownow.com/about" target="_blank" rel="noopener noreferrer" class="text-primary hover:underline">nownownow.com</a>
        </p>
      </div>

      <div class="grid gap-6" id="now-items-container">
        {sortedItems.map((item) => (
            <article
              class="border rounded-lg p-6 bg-card hover:shadow-md transition-shadow"
              data-category={item.category}
              data-now-content={JSON.stringify(item.content)}
              data-now-content-secondary={item.contentSecondary ? JSON.stringify(item.contentSecondary) : undefined}
            >
              <div class="flex items-start gap-4">
                <span class="text-3xl flex-shrink-0" aria-hidden="true">
                  {iconMap[item.icon] || "📌"}
                </span>
                <div class="flex-1 min-w-0">
                  <h2 class="font-semibold text-lg mb-2" data-i18n={`now.categories.${item.category}`}>
                    {getCategoryTranslation(item.category)}
                  </h2>
                  {item.contentSecondary ? (
                    <div class="flex items-center gap-3 overflow-hidden">
                      {item.image ? (
                        <img
                          src={item.image}
                          alt="Cover art"
                          class="w-12 h-12 rounded-lg flex-shrink-0"
                          loading="lazy"
                          decoding="async"
                        />
                      ) : null}
                      <div class="flex-1 min-w-0 overflow-hidden">
                        <p class="now-text font-semibold break-words block">{item.content.en}</p>
                        <p class="now-subtext text-sm text-muted-foreground break-words">{item.contentSecondary.en}</p>
                      </div>
                    </div>
                  ) : item.image ? (
                    <div class="flex items-center gap-3 overflow-hidden">
                      <img
                        src={item.image}
                        alt="Cover art"
                        class="w-12 h-12 rounded-lg flex-shrink-0"
                        loading="lazy"
                        decoding="async"
                      />
                      <p class="now-text min-w-0">{item.content.en}</p>
                    </div>
                  ) : (
                    <p class="now-text">{item.content.en}</p>
                  )}
                  <time
                    class="text-xs text-muted-foreground/70 mt-3 block"
                    datetime={item.date}
                    data-date={item.date}
                  >
                    {new Date(item.date).toLocaleDateString("en", {
                      year: "numeric",
                      month: "long",
                      day: "numeric",
                      hour: "2-digit",
                      minute: "2-digit",
                      timeZoneName: "short",
                    })}
                  </time>
                </div>
              </div>
            </article>
          ))}
      </div>
    </div>
  </div>
</BaseLayout>

<script>
  import { languageStore, t } from "@/i18n";

  interface PremidActivity {
    name: string;
    details?: string;
    state?: string;
    assets?: {
      large_image?: string;
      large_text?: string;
      small_image?: string;
      small_text?: string;
    };
  }

  const iconMap: Record<string, string> = {
    Headphones: "🎧",
    BookOpen: "📚",
    Code: "💻",
    Coffee: "☕",
    Brain: "🧠",
    GraduationCap: "🎓",
    Activity: "📡",
    Lightbulb: "💡",
  };

  function createActivityCard(activity: PremidActivity): string {
    let html = '<div class="flex items-center gap-3 overflow-hidden">';

    if (activity.assets?.large_image) {
      html += '<div class="relative w-12 h-12 flex-shrink-0">';
      html += `<img src="${activity.assets.large_image}" alt="${activity.assets.large_text || activity.name}" class="w-12 h-12 rounded-lg" loading="lazy" />`;
      if (activity.assets?.small_image) {
        html += `<img src="${activity.assets.small_image}" alt="${activity.assets.small_text || ""}" class="absolute -bottom-1 -right-1 w-6 h-6 rounded-full border-1 border-background bg-background" loading="lazy" />`;
      }
      html += "</div>";
    }

    html += '<div class="flex-1 min-w-0 overflow-hidden">';
    html += `<span class="font-semibold break-words block">${activity.name}</span>`;
    if (activity.details) {
      html += `<p class="text-sm break-words">${activity.details}</p>`;
    }
    if (activity.state) {
      html += `<p class="text-sm text-muted-foreground break-words">${activity.state}</p>`;
    }
    html += "</div></div>";

    return html;
  }

  async function enhanceWithLiveData() {
    const page = document.getElementById("now-page");
    if (!page) return;

    const container = document.getElementById("now-items-container");
    if (!container) return;

    try {
      const [lastfmRes, premidRes] = await Promise.all([
        fetch("/api/lastfm").catch(() => null),
        fetch("/api/premid").catch(() => null),
      ]);

      const liveItems: any[] = [];

      // Parse Last.fm
      if (lastfmRes?.ok) {
        const xml = await lastfmRes.text();
        const doc = new window.DOMParser().parseFromString(xml, "application/xml");
        const tracks = doc.getElementsByTagName("track");

        if (tracks.length > 0) {
          const track = Array.from(tracks).find((t) => t.getAttribute("nowplaying") === "true",) || tracks[0];
          const nowplaying = track?.getAttribute("nowplaying") === "true";
          const name = track?.getElementsByTagName("name")[0]?.textContent || "";
          const artist = track?.getElementsByTagName("artist")[0]?.textContent || "";
          const url = track?.getElementsByTagName("url")[0]?.textContent || "";

          const mediumImage = Array.from(track?.getElementsByTagName("image") || [])
            .find((img) => img.getAttribute("size") === "medium")
            ?.textContent?.trim() || "";

          if (name && artist) {
            liveItems.push({
              type: "lastfm",
              category: "listening",
              name,
              artist,
              url,
              nowplaying,
              image: mediumImage,
              dateObj: new Date(),
            });
          }
        }
      }

      // Parse PreMID
      if (premidRes?.ok) {
        const data = await premidRes.json();
        if (data.activities?.length > 0) {
          liveItems.push({
            type: "premid",
            category: "premid",
            activities: data.activities.map((a: any) => a.activity),
            dateObj: new Date(),
          });
        }
      }

      // If we have live data, prepend it
      if (liveItems.length > 0) {
        // Remove static items that conflict with live data
        const staticArticles = Array.from(container.querySelectorAll("article"),);
        staticArticles.forEach((article) => {
          const category = article.getAttribute("data-category");
          if (category === "listening" && liveItems.some((i) => i.type === "lastfm")) {
            article.remove();
          } else if (category === "premid" && liveItems.some((i) => i.type === "premid")) {
            article.remove();
          }
        });

        // Create HTML for live items
        let html = "";
        liveItems.forEach((item) => {
          html += '<article class="border rounded-lg p-6 bg-card hover:shadow-md transition-shadow">';
          html += '<div class="flex items-start gap-4">';
          html += `<span class="text-3xl flex-shrink-0" aria-hidden="true">${iconMap[item.type === "lastfm" ? "Headphones" : "Activity"]}</span>`;
          html += '<div class="flex-1 min-w-0">';

          if (item.type === "lastfm") {
            html += '<div class="flex items-center gap-2 mb-2">';
            html += `<h2 class="font-semibold text-lg" data-i18n="now.categories.listening">${t("now.categories.listening") || "Listening"}</h2>`;
            if (item.nowplaying) {
              html += '<span class="ml-2 text-sm font-bold text-red-600 dark:text-white dark:bg-red-600 px-2 py-0.5 rounded">Live</span>';
            }
            html += "</div>";
            html += '<div class="flex items-center gap-3 overflow-hidden">';
            if (item.image) {
              html += `<img src="${item.image}" alt="${item.name} cover art" class="w-12 h-12 rounded-lg flex-shrink-0" loading="lazy" decoding="async" />`;
            }
            html += '<div class="flex-1 min-w-0 overflow-hidden">';
            html += `<a href="${item.url}" target="_blank" rel="noopener noreferrer" class="hover:underline font-semibold break-words block">${item.name}</a>`;
            html += `<p class="text-sm text-muted-foreground break-words">${item.artist}</p>`;
            html += "</div></div>";
          } else if (item.type === "premid") {
            html += '<div class="flex items-center gap-2 mb-2">';
            html += `<h2 class="font-semibold text-lg" data-i18n="now.categories.premid">${t("now.categories.premid") || "Discord activity"}</h2>`;
            html += '<span class="ml-2 text-sm font-bold text-red-600 dark:text-white dark:bg-red-600 px-2 py-0.5 rounded">Live</span>';
            html += "</div>";
            html += '<div class="space-y-3">';
            item.activities.forEach((a: PremidActivity) => {
              html += createActivityCard(a);
            });
            html += "</div>";
          }

          html += "</div></div></article>";
        });

        container.insertAdjacentHTML("afterbegin", html);
        // Update translations after adding live data
        updateNowPageTranslations();
      }
    } catch (error) {
      console.error("Failed to enhance with live data:", error);
    }
  }

  function updateNowPageTranslations() {
    const page = document.getElementById("now-page");
    if (!page) return;

    const lang = languageStore.get();

    // Update static i18n keys within the page
    page.querySelectorAll("[data-i18n]").forEach((el) => {
      const key = el.getAttribute("data-i18n");
      if (key) {
        const translated = t(key);
        if (translated !== key) {
          el.textContent = translated;
        }
      }
    });

    // Update dynamic now item content
    page.querySelectorAll("[data-now-content]").forEach((article) => {
      const contentData = article.getAttribute("data-now-content");
      if (contentData) {
        try {
          const content = JSON.parse(contentData);
          const langContent = content[lang] || content.en;
          const textEl = article.querySelector(".now-text");
          if (textEl) { textEl.textContent = langContent; }

          const secondaryData = article.getAttribute("data-now-content-secondary");
          const subTextEl = article.querySelector(".now-subtext");
          if (secondaryData && subTextEl) {
            const secondary = JSON.parse(secondaryData);
            const langSecondary = secondary[lang] || secondary.en;
            subTextEl.textContent = langSecondary;
          } else if (subTextEl) {
            subTextEl.textContent = "";
          }
        } catch (e) {
          // Ignore parse errors
        }
      }
    });

    // Update dates with locale
    page.querySelectorAll("[data-date]").forEach((el) => {
      const dateStr = el.getAttribute("data-date");
      if (dateStr) {
        const date = new Date(dateStr);
        el.textContent = date.toLocaleDateString(lang, {
          year: "numeric",
          month: "long",
          day: "numeric",
          hour: "2-digit",
          minute: "2-digit",
          timeZoneName: "short",
        });
      }
    });
  }

  // Setup function
  function setupNowPage() {
    async function initialize() {
      await enhanceWithLiveData();
      updateNowPageTranslations();
    }
    initialize();
  }

  // Run setup initially
  setupNowPage();

  // Subscribe to language changes
  declare global {
    interface Window {
      __nowPageInitialized?: boolean;
    }
  }

  if (!window.__nowPageInitialized) {
    window.__nowPageInitialized = true;

    languageStore.subscribe(() => {
      updateNowPageTranslations();
    });

    window.addEventListener("languageChange", () => {
      updateNowPageTranslations();
    });

    // Handle view transitions
    document.addEventListener("astro:after-swap", () => {
      setupNowPage();
    });
  }
</script>
