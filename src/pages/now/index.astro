---
import BaseLayout from "@/layouts/BaseLayout.astro";
import T from "@/components/T.astro";
import { nowItems } from "@/content/now-items";
import { t } from "@/i18n";
import type { NowItemContent, NowItemContentOptional } from "@/content/now-items";

const lang = Astro.locals?.lang || "en";
const k = lang as keyof NowItemContent;
const iconMap: Record<string, string> = {
  Headphones: "🎧", BookOpen: "📚", Code: "💻", Coffee: "☕",
  Brain: "🧠", GraduationCap: "🎓", Activity: "📡", Lightbulb: "💡",
};

const sortedItems = [...nowItems].sort((a, b) => new Date(b.date).getTime() - new Date(a.date).getTime());
---

<BaseLayout title="Now" description="What I'm currently up to, thinking about, and focused on.">
  <div class="container mx-auto px-4 py-8 lg:py-12" id="now-page">
    <div class="max-w-3xl mx-auto">
      <header class="text-center mb-10">
        <T key="now.title" tag="h1" class="text-4xl font-bold mb-4" />
        <T key="now.description" tag="p" class="text-muted-foreground text-lg mx-auto" />
        {sortedItems.length > 0 && (
          <p class="text-sm text-muted-foreground/70 mt-4">
            <T key="now.lastUpdated" />:
            <time id="last-updated-date" data-date={sortedItems[0].date} datetime={sortedItems[0].date}>
              {new Date(sortedItems[0].date).toLocaleDateString(lang === "vih" ? "vi" : lang, { year: "numeric", month: "long", day: "numeric" })}
            </time>
          </p>
        )}
      </header>

      <!-- What is a /now page? -->
      <div class="mb-8 p-6 border rounded-lg bg-muted/30">
        <T key="now.whatIsNow" tag="h2" class="font-semibold mb-2" />
        <p class="text-muted-foreground text-sm">
          <T key="now.whatIsNowDescription" />
          {" "}
          <a href="https://nownownow.com/about" target="_blank" rel="noopener noreferrer" class="text-primary hover:underline">nownownow.com</a>
        </p>
      </div>

      <div class="grid gap-6" id="now-items-container">
        {sortedItems.map((item) => (
          <article
            class="border rounded-lg p-6 bg-card hover:shadow-md transition-shadow"
            data-category={item.category}
            data-now-content={JSON.stringify(item.content)}
            data-now-content-secondary={item.contentSecondary && JSON.stringify(item.contentSecondary)}
          >
            <div class="flex items-start gap-4">
              <span class="text-3xl flex-shrink-0" aria-hidden="true">{iconMap[item.icon] || "📌"}</span>
              <div class="flex-1 min-w-0">
                <h2 class="font-semibold text-lg mb-2">
                  {t(lang, `now.categories.${item.category}`)}
                </h2>
                <div class="flex items-center gap-3 overflow-hidden">
                  {item.image && <img src={item.image} alt="Cover art" class="w-12 h-12 rounded-lg flex-shrink-0" loading="lazy" decoding="async" />}
                  {item.contentSecondary ? (
                    <div class="flex-1 min-w-0 overflow-hidden">
                      <p class="now-text font-semibold break-words block">{item.content[k] || item.content.en}</p>
                      <p class="now-subtext text-sm text-muted-foreground break-words">{(item.contentSecondary as NowItemContentOptional)[k] || item.contentSecondary.en}</p>
                    </div>
                  ) : (
                    <p class="now-text min-w-0">{item.content[k] || item.content.en}</p>
                  )}
                </div>
                <time class="text-xs text-muted-foreground mt-3 block" datetime={item.date} data-date={item.date}>
                  {new Date(item.date).toLocaleDateString(lang === "vih" ? "vi" : lang, {
                    year: "numeric", month: "long", day: "numeric",
                    hour: "2-digit", minute: "2-digit", timeZoneName: "short",
                  })}
                </time>
              </div>
            </div>
          </article>
        ))}
      </div>
    </div>
  </div>
</BaseLayout>

<script>
  import { getPageLocale } from "@/i18n/client";
  import { fetchLiveData, renderCard, updateI18nElements, conflictMap } from "@/lib/now-utils";
  import { updateDateElements, dateFull } from "@/lib/timezone-utils";

  const enhance = async () => {
    const container = document.getElementById("now-items-container");
    if (!container) return;
    try {
      const live = await fetchLiveData();
      if (!live.length) return;
      const types = new Set<string>(live.map(i => i.type));
      container.querySelectorAll("article").forEach(el => {
        const cat = el.getAttribute("data-category") || "";
        if (conflictMap[cat] && types.has(conflictMap[cat])) el.remove();
      });
      container.insertAdjacentHTML("afterbegin", live.map(renderCard).join(""));
      translate();
    } catch (e) { console.error("Failed to enhance with live data:", e); }
  };

  const translate = () => {
    const page = document.getElementById("now-page");
    if (!page) return;
    const lang = getPageLocale();
    updateI18nElements(page, lang);
    updateDateElements(page, lang, dateFull);
  };

  const setup = async () => { await enhance(); translate(); };
  setup();

  document.addEventListener("timezone-change", translate);
</script>
