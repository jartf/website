---
// Contact page
import BaseLayout from "@/layouts/BaseLayout.astro";
import T from "@/components/T.astro";
import { Image } from 'astro:assets';
import { author, socialLinks } from "@/lib/constants";

// Contact links data
const contactLinks = [
  { id: "matrix", name: "Matrix", url: "https://matrix.to/#/@jar:envs.net", icon: "mail", color: "hover:bg-blue-600 hover:text-white" },
  { id: "discord", name: "Discord", url: "https://discord.com/users/444078929314185217", icon: "message-square", color: "hover:bg-indigo-600 hover:text-white" },
  { id: "email", name: "Email", url: `mailto:${author.email}`, displayUrl: author.email, icon: "mail", color: "hover:bg-blue-600 hover:text-white" },
  { id: "signal", name: "Signal", url: "https://signal.me/#eu/wHpqXqMSQ6LSg0zijVcCCWm5PK5gwshaDFOAg0aj-aq5BSs94E9CLJ5ThNuy4t6A", icon: "phone", color: "hover:bg-blue-400 hover:text-white" },
  { id: "telegram", name: "Telegram", url: "https://t.me/jaremame", icon: "send", color: "hover:bg-sky-500 hover:text-white" },
  { id: "calendar", name: "Cal.com", url: "https://cal.com/jaremaa/secret", icon: "calendar", color: "hover:bg-gray-800 hover:text-white dark:hover:bg-white dark:hover:text-black" },
];

const socialLinksData = [
  { id: "akkoma", name: "Akkoma", url: "https://blob.cat/jar", icon: "message-square", color: "hover:bg-purple-600 hover:text-white" },
  { id: "mastodon", name: "Mastodon", url: "https://toot.io/@jar", icon: "message-square", color: "hover:bg-purple-600 hover:text-white" },
  { id: "bluesky", name: "Bluesky", url: "https://bsky.app/profile/jarema.me", icon: "cloud", color: "hover:bg-sky-500 hover:text-white" },
  { id: "twitter", name: "Twitter/X", url: "https://twitter.com/jarema_me", icon: "twitter", color: "hover:bg-gray-800 hover:text-white" },
  { id: "devto", name: "dev.to", url: "https://dev.to/jartf", icon: "file-code", color: "hover:bg-gray-800 hover:text-white" },
  { id: "threads", name: "Threads", url: "https://threads.net/@jarema.me", icon: "at-sign", color: "hover:bg-gray-800 hover:text-white" },
  { id: "instagram", name: "Instagram", url: "https://instagram.com/jarema.me", icon: "image", color: "hover:bg-pink-600 hover:text-white" },
  { id: "messenger", name: "Messenger", url: "https://m.me/jaremame", icon: "facebook", color: "hover:bg-blue-500 hover:text-white", note: "might not respond here" },
];

// Pronouns.page language-specific URLs
const pronounsUrls: Record<string, string> = {
  ru: "https://ru.pronouns.page/@jerryv",
  vi: "https://vi.pronouns.page/@jerryv",
  tr: "https://tr.pronouns.page/@jerryv",
  zh: "https://zh.pronouns.page/@jerryv",
  default: "https://en.pronouns.page/@jerryv",
};

const otherLinks = [
  { id: "pronouns", name: "Pronouns.page", urls: pronounsUrls, icon: "user", color: "hover:bg-violet-600 hover:text-white", hasLanguageNote: true },
  { id: "github", name: "GitHub", url: socialLinks.github, icon: "github", color: "hover:bg-gray-800 hover:text-white" },
  { id: "gitlab", name: "GitLab", url: "https://gitlab.com/jartf", icon: "code", color: "hover:bg-orange-600 hover:text-white" },
  { id: "googledev", name: "Google Dev", url: "https://g.dev/jarema", icon: "code", color: "hover:bg-blue-600 hover:text-white" },
  { id: "indieweb", name: "IndieWeb", url: "https://indieweb.org/User:Jarema.me", icon: "globe", color: "hover:bg-indigo-600 hover:text-white" },
  { id: "osm", name: "OpenStreetMap", url: "https://openstreetmap.org/user/Equate", icon: "map", color: "hover:bg-green-600 hover:text-white" },
  { id: "waze", name: "Waze", url: "https://www.waze.com/en/user/editor/vanhv", icon: "map", color: "hover:bg-blue-500 hover:text-white" },
];

// Icons as SVG (Lucide icons)
const icons: Record<string, string> = {
  mail: '<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect width="20" height="16" x="2" y="4" rx="2"/><path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"/></svg>',
  "message-square": '<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"/></svg>',
  phone: '<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"/></svg>',
  send: '<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m22 2-7 20-4-9-9-4Z"/><path d="M22 2 11 13"/></svg>',
  calendar: '<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect width="18" height="18" x="3" y="4" rx="2" ry="2"/><line x1="16" x2="16" y1="2" y2="6"/><line x1="8" x2="8" y1="2" y2="6"/><line x1="3" x2="21" y1="10" y2="10"/></svg>',
  cloud: '<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M17.5 19H9a7 7 0 1 1 6.71-9h1.79a4.5 4.5 0 1 1 0 9Z"/></svg>',
  twitter: '<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 4s-.7 2.1-2 3.4c1.6 10-9.4 17.3-18 11.6 2.2.1 4.4-.6 6-2C3 15.5.5 9.6 3 5c2.2 2.6 5.6 4.1 9 4-.9-4.2 4-6.6 7-3.8 1.1 0 3-1.2 3-1.2z"/></svg>',
  "file-code": '<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M4 22h14a2 2 0 0 0 2-2V7l-5-5H6a2 2 0 0 0-2 2v4"/><path d="M14 2v4a2 2 0 0 0 2 2h4"/><path d="m5 12-3 3 3 3"/><path d="m9 18 3-3-3-3"/></svg>',
  "at-sign": '<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="4"/><path d="M16 8v5a3 3 0 0 0 6 0v-1a10 10 0 1 0-4 8"/></svg>',
  image: '<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect width="18" height="18" x="3" y="3" rx="2" ry="2"/><circle cx="9" cy="9" r="2"/><path d="m21 15-3.086-3.086a2 2 0 0 0-2.828 0L6 21"/></svg>',
  facebook: '<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M18 2h-3a5 5 0 0 0-5 5v3H7v4h3v8h4v-8h3l1-4h-4V7a1 1 0 0 1 1-1h3z"/></svg>',
  user: '<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M19 21v-2a4 4 0 0 0-4-4H9a4 4 0 0 0-4 4v2"/><circle cx="12" cy="7" r="4"/></svg>',
  github: '<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M15 22v-4a4.8 4.8 0 0 0-1-3.5c3 0 6-2 6-5.5.08-1.25-.27-2.48-1-3.5.28-1.15.28-2.35 0-3.5 0 0-1 0-3 1.5-2.64-.5-5.36-.5-8 0C6 2 5 2 5 2c-.3 1.15-.3 2.35 0 3.5A5.403 5.403 0 0 0 4 9c0 3.5 3 5.5 6 5.5-.39.49-.68 1.05-.85 1.65-.17.6-.22 1.23-.15 1.85v4"/><path d="M9 18c-4.51 2-5-2-7-2"/></svg>',
  code: '<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="16 18 22 12 16 6"/><polyline points="8 6 2 12 8 18"/></svg>',
  globe: '<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><path d="M12 2a14.5 14.5 0 0 0 0 20 14.5 14.5 0 0 0 0-20"/><path d="M2 12h20"/></svg>',
  map: '<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M14.106 5.553a2 2 0 0 0 1.788 0l3.659-1.83A1 1 0 0 1 21 4.619v12.764a1 1 0 0 1-.553.894l-4.553 2.277a2 2 0 0 1-1.788 0l-4.212-2.106a2 2 0 0 0-1.788 0l-3.659 1.83A1 1 0 0 1 3 19.381V6.618a1 1 0 0 1 .553-.894l4.553-2.277a2 2 0 0 1 1.788 0z"/><path d="M15 5.764v15"/><path d="M9 3.236v15"/></svg>',
  info: '<svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><path d="M12 16v-4"/><path d="M12 8h.01"/></svg>',
  external: '<svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6"/><polyline points="15 3 21 3 21 9"/><line x1="10" x2="21" y1="14" y2="3"/></svg>',
};
---

<BaseLayout title="Contact" description="Get in touch with me.">
  <div class="container mx-auto px-4 py-8 lg:py-12">
    <div class="max-w-3xl mx-auto">
      <header class="mb-10 text-center">
        <T key="contact.title" tag="h1" class="text-4xl font-bold mb-4" />
        <T key="contact.description" tag="p" class="text-muted-foreground text-lg" />
        <T key="contact.message" tag="p" class="text-lg mt-4 lowercase" />
        <T key="contact.disclaimer" tag="p" class="text-sm text-muted-foreground/70 mt-2 italic lowercase" />
      </header>

      <!-- Contact me section -->
      <section class="mb-12">
        <T key="contact.sectionTitles.contactMe" tag="h2" class="text-2xl font-bold mb-6" />
        <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
          {contactLinks.map((link) => (
            <a
              href={link.url}
              target={link.url.startsWith("mailto:") ? undefined : "_blank"}
              rel={link.url.startsWith("mailto:") ? undefined : "noopener noreferrer"}
              class={`flex items-center justify-center gap-3 p-4 rounded-lg border transition-colors ${link.color}`}
            >
              <span set:html={icons[link.icon] || icons.mail} />
              <span class="font-medium">{link.name}</span>
              {!link.url.startsWith("mailto:") && (
                <span class="opacity-70" set:html={icons.external} />
              )}
            </a>
          ))}
        </div>

        <!-- QR code sections for Vietnamese/Chinese users -->
        <div id="qr-zalo" class="mt-4 hidden border rounded-lg p-6 bg-card">
          <h3 class="font-semibold mb-4 text-center">Zalo</h3>
          <div class="flex flex-col items-center">
            <Image src="/zalo-qr.jpeg" alt="Zalo QR Code" width={192} height={192} class="w-48 h-48 object-contain mb-4" />
            <p class="text-sm text-muted-foreground text-center">Quét mã QR để kết nối với tôi trên Zalo</p>
            <a href="https://zaloapp.com/qr/p/ryw96g1vmzmw" target="_blank" rel="noopener noreferrer" class="mt-2 text-primary hover:underline">
              Mở Zalo
            </a>
          </div>
        </div>

        <div id="qr-wechat" class="mt-4 hidden border rounded-lg p-6 bg-card">
          <h3 class="font-semibold mb-4 text-center">微信</h3>
          <div class="flex flex-col items-center">
            <Image src="/wechat-qr.png" alt="WeChat QR Code" width={192} height={192} class="w-48 h-48 object-contain mb-4" />
            <p class="text-sm text-muted-foreground text-center">扫一扫上面的二维码图案，加我为朋友。</p>
          </div>
        </div>
      </section>

      <!-- Social media section -->
      <section class="mb-12">
        <T key="contact.sectionTitles.socialMedia" tag="h2" class="text-2xl font-bold mb-6" />
        <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
          {socialLinksData.map((link) => (
            <a
              href={link.url}
              target="_blank"
              rel="noopener noreferrer me"
              class={`flex flex-col md:flex-row items-center justify-center gap-2 md:gap-3 p-4 rounded-lg border transition-colors ${link.color} w-full`}
            >
              <div class="flex items-center gap-3">
                <span set:html={icons[link.icon] || icons["message-square"]} />
                <span class="font-medium">{link.name}</span>
                <span class="opacity-70" set:html={icons.external} />
                {link.note && (
                  <span class="hidden md:inline opacity-70" set:html={icons.info} title={link.note} />
                )}
              </div>
              {link.note && (
                <p class="text-xs mt-1 md:hidden text-center opacity-80">{link.note}</p>
              )}
            </a>
          ))}
        </div>
      </section>

      <!-- Other platforms section -->
      <section class="mb-12">
        <T key="contact.sectionTitles.otherPlatforms" tag="h2" class="text-2xl font-bold mb-6" />
        <div class="grid grid-cols-1 md:grid-cols-2 gap-4" id="other-platforms">
          {otherLinks.map((link) => {
            if (link.urls) {
              // Pronouns.page
              return (
                <a
                  id="pronouns-link"
                  href={link.urls.default}
                  data-urls={JSON.stringify(link.urls)}
                  target="_blank"
                  rel="noopener noreferrer"
                  class={`flex flex-col items-center justify-center gap-2 p-4 rounded-lg border transition-colors ${link.color}`}
                >
                  <div class="flex items-center gap-3">
                    <span set:html={icons[link.icon] || icons.globe} />
                    <span class="font-medium" id="pronouns-name">{link.name}</span>
                    <span class="opacity-70" set:html={icons.external} />
                    <span class="hidden md:inline opacity-70" id="pronouns-info-icon" set:html={icons.info} />
                  </div>
                  <p class="text-xs mt-1 text-center opacity-80 hidden" id="pronouns-note"></p>
                </a>
              );
            }
            return (
              <a
                href={link.url}
                target="_blank"
                rel="noopener noreferrer"
                class={`flex items-center justify-center gap-3 p-4 rounded-lg border transition-colors ${link.color}`}
              >
                <span set:html={icons[link.icon] || icons.globe} />
                <span class="font-medium">{link.name}</span>
                <span class="opacity-70" set:html={icons.external} />
              </a>
            );
          })}
        </div>
      </section>

      <!-- PGP/security note -->
      <div class="text-center text-sm text-muted-foreground p-4 border rounded-lg bg-muted/30">
        <T key="contact.pgpNote" tag="p" />
      </div>
    </div>
  </div>
</BaseLayout>

<script>
  import { languageStore, initLanguage } from '@/i18n';

  // Show QR codes based on language
  function updateQRVisibility() {
    const lang = languageStore.get();
    const zaloQR = document.getElementById('qr-zalo');
    const wechatQR = document.getElementById('qr-wechat');

    if (zaloQR) {
      zaloQR.classList.toggle('hidden', !['vi', 'vih'].includes(lang));
    }
    if (wechatQR) {
      wechatQR.classList.toggle('hidden', lang !== 'zh');
    }
  }

  // Update Pronouns.page URL based on language
  function updatePronounsLink() {
    const lang = languageStore.get();
    const pronounsLink = document.getElementById('pronouns-link') as HTMLAnchorElement;
    const pronounsName = document.getElementById('pronouns-name');
    const pronounsNote = document.getElementById('pronouns-note');
    const pronounsInfoIcon = document.getElementById('pronouns-info-icon');

    if (pronounsLink) {
      const urlsData = pronounsLink.getAttribute('data-urls');
      if (urlsData) {
        const urls = JSON.parse(urlsData);
        const url = urls[lang] || urls.default;
        pronounsLink.href = url;

        // Show Russian 18+ note
        if (lang === 'ru') {
          const ruNote = 'Этот сайт имеет возрастное ограничение 18+. Оставаясь на сайте, вы подтверждаете, что достигли совершеннолетия, и самостоятельно несёте ответственность за свои действия.';
          if (pronounsName) {
            pronounsName.textContent = 'Pronouns.page (18+)';
          }
          if (pronounsNote) {
            pronounsNote.textContent = ruNote;
            pronounsNote.classList.remove('hidden');
          }
          if (pronounsInfoIcon) {
            pronounsInfoIcon.setAttribute('title', ruNote);
          }
        } else {
          if (pronounsName) {
            pronounsName.textContent = 'Pronouns.page';
          }
          if (pronounsNote) {
            pronounsNote.classList.add('hidden');
          }
        }
      }
    }
  }

  initLanguage();
  updateQRVisibility();
  updatePronounsLink();

  languageStore.subscribe(() => {
    updateQRVisibility();
    updatePronounsLink();
  });

  window.addEventListener('languageChange', () => {
    updateQRVisibility();
    updatePronounsLink();
  });
</script>
