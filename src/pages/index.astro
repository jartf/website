---
import BaseLayout from "@/layouts/BaseLayout.astro";
import T from "@/components/T.astro";
import { routes, siteName, author, services, friendSites, authorTimezone, authorTimezoneLabel } from "@/lib/constants";
import { getData } from "@/content.config";
import MoodCat from "@/components/home/MoodCat.astro";
import NowSection from "@/components/home/NowSection.astro";
import RecentPosts from "@/components/home/RecentPosts.astro";

const activeWebringItems = (await getData("webrings")).filter(w => w.status === "active");

const btnBase = "w-full sm:w-auto inline-flex items-center justify-center gap-2 whitespace-nowrap rounded-md text-sm font-medium ring-offset-background transition-colors focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-ring focus-visible:ring-offset-2 h-11 px-8";
const btnPrimary = `${btnBase} bg-primary text-primary-foreground hover:bg-primary/90`;
const btnSecondary = `${btnBase} border border-input bg-background hover:bg-accent hover:text-accent-foreground`;
---

<BaseLayout title={siteName} isHomePage={true}>
  <div class="relative min-h-screen w-full overflow-hidden">
    <div class="container mx-auto px-2 sm:px-4 lg:px-6 py-8 lg:py-12 relative z-10">
      <div class="max-w-5xl mx-auto">
        <!-- Hero Section -->
        <div class="relative pt-6 lg:pt-0 pb-6 mb-6 text-center">
          <p class="text-lg text-muted-foreground mb-2" id="greeting"><span id="greeting-emoji">👋</span> <T key="greetings.morning" /></p>
          <T key="home.heading" tag="h1" class="text-3xl md:text-4xl lg:text-5xl font-bold mb-4" />
          <T key="home.subheading" tag="p" class="text-lg md:text-xl text-muted-foreground mb-8" />
          <div class="flex flex-col sm:flex-row gap-4 justify-center">
            <a href={routes.contact} class={btnPrimary}><T key="home.contactButton" /></a>
            <a href={routes.about} class={btnSecondary}><T key="home.aboutButton" /></a>
            <a href={routes.blog} class={btnSecondary}><T key="home.blogButton" /></a>
            <a href={routes.guestbook} class={btnSecondary}><T key="home.guestbookButton" /></a>
          </div>
        </div>

        <!-- Row 1: Status, Mood, Timezone -->
        <div class="grid grid-cols-1 sm:grid-cols-[1.75fr_1fr_1.75fr] gap-4 min-h-32">
          <section class="border rounded-lg p-4 bg-card card-hover-effect hover:scale-[1.02]" aria-labelledby="status-cafe-heading">
            <T key="home.currentStatus" tag="h3" id="status-cafe-heading" class="text-lg font-bold mb-3 text-center" />
            <div class="text-center">
              <div id="statuscafe" class="w-full text-sm" data-statuscafe-user={author.statusCafeUsername}><div id="statuscafe-username"></div><div id="statuscafe-content"></div></div>
              <noscript>
                <div class="text-sm text-muted-foreground text-center">
                  <a href={services.statusCafe.profileUrl} class="text-primary hover:underline">status.cafe</a>
                </div>
              </noscript>
            </div>
          </section>

          <section class="border rounded-lg p-4 bg-card card-hover-effect hover:scale-[1.02]" aria-labelledby="current-mood-heading">
            <T key="home.currentMood" tag="h3" id="current-mood-heading" class="text-lg font-bold mb-3 text-center" />
            <div class="text-center flex items-center justify-center">
              <a href={services.iMood.profileUrl} target="_blank" rel="noopener noreferrer" class="focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-ring focus-visible:ring-offset-2 focus-visible:ring-offset-background rounded">
                <img src={services.iMood.widgetUrl} alt="My current mood, loaded from imood" class="inline-block h-[25px]" width="80" height="25" loading="lazy" decoding="async" />
              </a>
            </div>
          </section>

          <section class="border rounded-lg p-4 bg-card card-hover-effect hover:scale-[1.02]" aria-labelledby="timezone-heading">
            <h3 id="timezone-heading" class="text-lg font-bold mb-3 text-center">Timezone</h3>
            <div class="flex items-center justify-center gap-6">
              <div class="text-center">
                <p id="user-time" class="text-xl font-mono font-bold">--:--:--</p>
                <p class="text-xs text-muted-foreground mt-1">Your time</p>
              </div>
              <div class="text-center">
                <p id="author-time" class="text-xl font-mono font-bold" data-timezone={authorTimezone}>--:--:--</p>
                <p class="text-xs text-muted-foreground mt-1">My time ({authorTimezoneLabel})</p>
              </div>
            </div>
          </section>
        </div>

        <!-- Row 2: Now + MoodCat -->
        <div class="mt-10 lg:mt-12 grid grid-cols-1 lg:grid-cols-2 gap-6 lg:gap-8 items-start">
          <NowSection />
          <MoodCat />
        </div>

        <!-- Row 3: Blog Posts -->
        <div class="mt-10 lg:mt-12">
          <RecentPosts />
        </div>

        <!-- Row 4: Webrings -->
        <section class="mt-10 lg:mt-12" aria-labelledby="webrings-heading">
          <h2 id="webrings-heading" class="text-2xl font-bold mb-4 text-center">
            <a href="/webrings/" tabindex="-1" class="no-underline hover:underline focus:underline text-inherit"><T key="webrings.title" /></a>
          </h2>
          <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4">
            {activeWebringItems.map((ring) => (
              <div class="border rounded-lg p-3 bg-card card-hover-effect hover:scale-[1.02]">
                <div class="flex items-center justify-between gap-1 text-sm" role="group" aria-label={`Navigate ${ring.name}`}>
                  <a href={ring.previous} class="text-primary hover:text-primary/80 transition-colors focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-ring focus-visible:ring-offset-2 focus-visible:ring-offset-background rounded px-1" title={`Previous site in ${ring.name}`}>←</a>
                  <a href={ring.url} class="text-primary hover:underline font-medium focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-ring focus-visible:ring-offset-2 focus-visible:ring-offset-background rounded-sm mx-2 truncate flex-1 text-center" target="_blank" rel="noopener noreferrer">{ring.name}</a>
                  <a href={ring.next} class="text-primary hover:text-primary/80 transition-colors focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-ring focus-visible:ring-offset-2 focus-visible:ring-offset-background rounded px-1" title={`Next site in ${ring.name}`}>→</a>
                </div>
              </div>
            ))}
          </div>
          <div class="mt-4 text-center">
            <a href={routes.webring} id="view-all-webrings" class="inline-flex items-center gap-2 px-3 py-1.5 text-sm border rounded-lg hover:bg-accent transition-colors group focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-ring focus-visible:ring-offset-2 focus-visible:ring-offset-background" aria-label="See all webrings">
              <T key="home.viewAllWebrings" /> →
            </a>
          </div>
        </section>

        <!-- Friend sites -->
        <section class="mt-10 lg:mt-12" aria-labelledby="check-out-heading">
          <T key="home.checkOutSites" tag="h2" id="check-out-heading" class="text-2xl font-bold mb-4 text-center" />
          {friendSites.length > 0 ? (
            <div class="border rounded-lg p-4 bg-card flex flex-wrap justify-center gap-2">
              {friendSites.map(({ src, alt, href }) =>
                href ? (
                  <a
                    href={href}
                    target="_blank"
                    rel="noopener noreferrer"
                    aria-label={alt}
                    class="focus:outline-none focus-visible:ring-2 focus-visible:ring-ring focus-visible:ring-offset-2 focus-visible:ring-offset-background rounded transition-transform duration-200 hover:-translate-y-1"
                  >
                    <img src={src} alt={alt} width={100} height={38} loading="lazy" decoding="async" class="transition-all duration-200 hover:brightness-110" />
                  </a>
                ) : (
                  <img src={src} alt={alt} width={100} height={38} loading="lazy" decoding="async" class="transition-all duration-200 hover:brightness-110 hover:-translate-y-1" />
                )
              )}
            </div>
          ) : (
            <p class="text-center text-sm text-muted-foreground border rounded-lg p-6 bg-card">
              Nothing here yet :p
            </p>
          )}
        </section>

      </div>
    </div>
  </div>
</BaseLayout>

<script>
  import { t } from "@/i18n/client";
  import { services } from "@/lib/constants";

  const statusCafeProfileUrl = services.statusCafe.profileUrl;

  const greetings = [
    { hours: [5, 12], emoji: "🌅", key: "greetings.morning" },
    { hours: [12, 17], emoji: "☀️", key: "greetings.afternoon" },
    { hours: [17, 21], emoji: "🌆", key: "greetings.evening" },
    { hours: [21, 5], emoji: "🌙", key: "greetings.night" }
  ];

  function updateGreetingEmoji() {
    const hour = new Date().getHours();
    const emojiEl = document.getElementById("greeting-emoji");
    const greetingEl = document.getElementById("greeting");
    if (!emojiEl || !greetingEl) return;

    const greeting = greetings.find(g => hour >= g.hours[0] && hour < g.hours[1]) || greetings[3];
    emojiEl.textContent = greeting.emoji;
    const textEl = greetingEl.querySelector("span:last-child");
    if (textEl) {
      const translated = t(greeting.key);
      if (translated !== greeting.key) textEl.textContent = translated;
    }
  }

  updateGreetingEmoji();

  // Timezone clocks - update both user's and author's time
  function updateTimes() {
    const userTimeEl = document.getElementById("user-time");
    const authorTimeEl = document.getElementById("author-time");
    if (!userTimeEl || !authorTimeEl) return;

    const now = new Date();
    const authorTimezone = authorTimeEl.getAttribute("data-timezone");

    // User's local time
    const userTime = now.toLocaleTimeString("en-GB", {
      hour: "2-digit",
      minute: "2-digit",
      second: "2-digit"
    });
    userTimeEl.textContent = userTime;

    // Author's time
    if (authorTimezone) {
      const authorTime = now.toLocaleTimeString("en-GB", {
        timeZone: authorTimezone,
        hour: "2-digit",
        minute: "2-digit",
        second: "2-digit"
      });
      authorTimeEl.textContent = authorTime;
    }
  }

  updateTimes();
  setInterval(updateTimes, 1000);

  const u = document.getElementById("statuscafe-username"), c = document.getElementById("statuscafe-content");
  if (u && c) {
    const ac = new AbortController();
    setTimeout(() => ac.abort(), 5000);
    fetch(`${statusCafeProfileUrl}/status.json`, { headers: { Accept: "application/json" }, signal: ac.signal })
      .then(r => r.ok ? r.json() : Promise.reject())
      .then(r => {
        if (!r?.content?.length) return c.textContent = "No status yet.";
        // Avoid injecting raw API data as HTML
        u.textContent = '';
        const link = document.createElement('a');
        link.href = statusCafeProfileUrl;
        link.target = '_blank';
        link.rel = 'noopener noreferrer';
        link.textContent = `@${r.author}`;
        u.appendChild(link);
        u.append(` · ${r.face || ''} · ${r.timeAgo || ''}`);
        c.textContent = r.content;
      })
      .catch(() => c.textContent = "Couldn't load status.");
  }
</script>
