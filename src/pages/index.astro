---
import BaseLayout from "@/layouts/BaseLayout.astro";
import T from "@/components/T.astro";
import { routes, siteName, author, services, friendSites, authorTimezone, authorTimezoneLabel } from "@/lib/constants";
import { getData } from "@/content.config";
import MoodCat from "@/components/home/MoodCat.astro";
import NowSection from "@/components/home/NowSection.astro";
import RecentPosts from "@/components/home/RecentPosts.astro";

const activeWebringItems = (await getData("webrings")).filter(w => w.status === "active");

const btn = "w-full sm:w-auto inline-flex items-center justify-center gap-2 whitespace-nowrap rounded-md text-sm font-medium ring-offset-background transition-colors h-11 px-8";
const card = "border rounded-lg p-4 bg-card card-hover-effect";
---

<BaseLayout title={siteName} isHomePage={true}>
  <div class="relative min-h-screen w-full overflow-hidden">
    <div class="container mx-auto px-2 sm:px-4 lg:px-6 py-8 lg:py-12 relative z-10">
      <div class="max-w-5xl mx-auto">
        <div class="relative pt-6 lg:pt-0 pb-6 mb-6 text-center">
          <p class="text-lg text-muted-foreground mb-2" id="greeting"><span id="greeting-emoji">👋</span> <T key="greetings.morning" /></p>
          <T key="home.heading" tag="h1" class="text-3xl md:text-4xl lg:text-5xl font-bold mb-4" />
          <T key="home.subheading" tag="p" class="text-lg md:text-xl text-muted-foreground mb-8" />
          <div class="flex flex-col sm:flex-row gap-4 justify-center">
            <a href={routes.contact} class:list={[btn, "bg-primary text-primary-foreground hover:bg-primary/90"]}><T key="home.contactButton" /></a>
            <a href={routes.about} class:list={[btn, "border border-input bg-background hover:bg-accent hover:text-accent-foreground"]}><T key="home.aboutButton" /></a>
            <a href={routes.blog} class:list={[btn, "border border-input bg-background hover:bg-accent hover:text-accent-foreground"]}><T key="home.blogButton" /></a>
            <a href={routes.guestbook} class:list={[btn, "border border-input bg-background hover:bg-accent hover:text-accent-foreground"]}><T key="home.guestbookButton" /></a>
          </div>
        </div>

        <div class="grid grid-cols-1 sm:grid-cols-[1.75fr_1fr_1.75fr] gap-4 min-h-32">
          <section class={card} aria-labelledby="status-cafe-heading">
            <T key="home.currentStatus" tag="h2" id="status-cafe-heading" class="text-lg font-bold mb-3 text-center" />
            <div class="text-center">
              <div id="statuscafe" class="w-full text-sm" data-statuscafe-user={author.statusCafeUsername}><div id="statuscafe-username"></div><div id="statuscafe-content"></div></div>
              <noscript><a href={services.statusCafe.profileUrl} class="text-sm text-primary hover:underline">See my status.cafe profile here!</a></noscript>
            </div>
          </section>

          <section class={card} aria-labelledby="current-mood-heading">
            <T key="home.currentMood" tag="h2" id="current-mood-heading" class="text-lg font-bold mb-3 text-center" />
            <div class="text-center flex items-center justify-center">
              <a href={services.iMood.profileUrl} target="_blank" rel="noopener noreferrer">
                <img src={services.iMood.widgetUrl} alt="My current mood, loaded from imood" class="inline-block pixelated h-[25px]" width="80" height="25" loading="lazy" decoding="async" />
              </a>
            </div>
          </section>

          <section class={card} aria-labelledby="timezone-heading">
            <T key="home.time" tag="h2" id="timezone-heading" class="text-lg font-bold mb-3 text-center" />
            <div class="flex items-center justify-center gap-6">
              <div class="text-center">
                <p id="user-time" class="text-xl font-mono font-bold">--:--:--</p>
                <p class="text-xs text-muted-foreground mt-1"><T key="home.yourTime" /></p>
              </div>
              <div class="text-center">
                <p id="author-time" class="text-xl font-mono font-bold" data-timezone={authorTimezone}>--:--:--</p>
                <p class="text-xs text-muted-foreground mt-1"><T key="home.myTime" /> ({authorTimezoneLabel})</p>
              </div>
            </div>
          </section>
        </div>

        <div class="mt-10 lg:mt-12 grid grid-cols-1 lg:grid-cols-2 gap-6 lg:gap-8 items-start">
          <NowSection />
          <MoodCat />
        </div>

        <div class="mt-10 lg:mt-12">
          <RecentPosts />
        </div>

        <section class="mt-10 lg:mt-12" aria-labelledby="webrings-heading">
          <h2 id="webrings-heading" class="text-2xl font-bold mb-4 text-center">
            <a href="/webrings/" class="no-underline hover:underline focus:underline text-inherit"><T key="webrings.title" /></a>
          </h2>
          <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4">
            {activeWebringItems.map((ring) => (
              <div class="border rounded-lg p-3 bg-card card-hover-effect">
                <nav class="flex items-center justify-between gap-1 text-sm" aria-label={`Navigate ${ring.name}`}>
                  <a href={ring.previous} class="text-primary hover:text-primary/80 transition-colors px-1" aria-label={`Previous site in ${ring.name}`}>←</a>
                  <a href={ring.url} class="text-primary hover:underline font-medium mx-2 truncate flex-1 text-center" target="_blank" rel="noopener noreferrer">{ring.name}</a>
                  {ring.random && <a href={ring.random} class="text-primary hover:text-primary/80 transition-colors px-1" aria-label={`Random site in ${ring.name}`}>🎲</a>}
                  <a href={ring.next} class="text-primary hover:text-primary/80 transition-colors px-1" aria-label={`Next site in ${ring.name}`}>→</a>
                </nav>
              </div>
            ))}
          </div>
          <div class="mt-4 text-center">
            <a href={routes.webring} class="inline-flex items-center gap-2 px-3 py-1.5 text-sm border rounded-lg hover:bg-accent transition-colors">
              <T key="home.viewAllWebrings" /> →
            </a>
          </div>
        </section>

        <section class="mt-10 lg:mt-12" aria-labelledby="check-out-heading">
          <T key="home.checkOutSites" tag="h2" id="check-out-heading" class="text-2xl font-bold mb-4 text-center" />
          {friendSites.length > 0 ? (
            <div class="border rounded-lg p-4 bg-card flex flex-wrap justify-center gap-2">
              {friendSites.map(({ src, alt, href }) =>
                href ? (
                  <a href={href} target="_blank" rel="noopener noreferrer" class="transition-transform duration-200 hover:-translate-y-1">
                    <img src={src} alt={alt} width={100} height={38} loading="lazy" decoding="async" class="transition-all duration-200 hover:brightness-110" />
                  </a>
                ) : (
                  <img src={src} alt={alt} width={100} height={38} loading="lazy" decoding="async" class="transition-all duration-200 hover:brightness-110 hover:-translate-y-1" />
                )
              )}
            </div>
          ) : (
            <p class="text-center text-sm text-muted-foreground border rounded-lg p-6 bg-card">Nothing here yet :p</p>
          )}
        </section>

      </div>
    </div>
  </div>
</BaseLayout>

<script>
  import { t } from "@/i18n/client";
  import { services } from "@/lib/constants";

  const greetings = [
    { start: 5, end: 12, emoji: "🌅", key: "greetings.morning" },
    { start: 12, end: 17, emoji: "☀️", key: "greetings.afternoon" },
    { start: 17, end: 21, emoji: "🌆", key: "greetings.evening" },
    { start: 21, end: 5, emoji: "🌙", key: "greetings.night" }
  ];

  function updateGreeting() {
    const hour = new Date().getHours();
    const g = greetings.find(g => g.start === 21 ? hour >= 21 || hour < 5 : hour >= g.start && hour < g.end) || greetings[0];
    const emoji = document.getElementById("greeting-emoji");
    const text = document.getElementById("greeting")?.querySelector("span:last-child");
    if (emoji) emoji.textContent = g.emoji;
    if (text) { const tr = t(g.key); if (tr !== g.key) text.textContent = tr; }
  }

  function updateTimes() {
    const userEl = document.getElementById("user-time");
    const authorEl = document.getElementById("author-time");
    if (!userEl || !authorEl) return;
    const now = new Date();
    const fmt = (tz?: string) => now.toLocaleTimeString("en-GB", { hour: "2-digit", minute: "2-digit", second: "2-digit", ...(tz && { timeZone: tz }) });
    userEl.textContent = fmt();
    const tz = authorEl.dataset.timezone;
    if (tz) authorEl.textContent = fmt(tz);
  }

  function loadStatus() {
    const u = document.getElementById("statuscafe-username"), c = document.getElementById("statuscafe-content");
    if (!u || !c) return;
    const url = services.statusCafe.profileUrl;
    const ac = new AbortController();
    setTimeout(() => ac.abort(), 5000);
    fetch(`${url}/status.json`, { signal: ac.signal })
      .then(r => r.ok ? r.json() : Promise.reject())
      .then(r => {
        if (!r?.content?.length) { c.textContent = "No status yet."; return; }
        u.textContent = '';
        const a = document.createElement('a');
        a.href = url; a.target = '_blank'; a.rel = 'noopener noreferrer'; a.textContent = `@${r.author}`;
        u.append(a, ` · ${r.face || ''} · ${r.timeAgo || ''}`);
        c.textContent = r.content;
      })
      .catch(() => c.textContent = "Couldn't load status.");
  }

  updateGreeting();
  updateTimes();
  loadStatus();
  setInterval(updateTimes, 1000);
</script>
