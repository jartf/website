---
// Homepage
import BaseLayout from "@/layouts/BaseLayout.astro";
import T from "@/components/T.astro";
import { routes } from "@/lib/constants";
import { activeWebringItems } from "@/content/webring-items";
import MoodCat from "@/components/MoodCat.astro";
import NowSection from "@/components/NowSection.astro";
import RecentPosts from "@/components/RecentPosts.astro";
---

<BaseLayout title="Jarema's digital garden" isHomePage={true}>
  <div class="relative min-h-screen w-full overflow-hidden">
    <div class="container mx-auto px-2 sm:px-4 lg:px-6 py-8 lg:py-12 relative z-10">
      <div class="max-w-6xl mx-auto">
        <!-- Hero Section -->
        <div class="relative pt-10 pb-10 mb-8">
          <div class="text-center">
            <p class="text-lg text-muted-foreground mb-2" id="greeting"><span id="greeting-emoji">👋</span> <T key="greetings.morning" /></p>
            <T key="home.heading" tag="h1" class="text-4xl md:text-5xl lg:text-6xl font-bold mb-4" />
            <T key="home.subheading" tag="p" class="text-lg md:text-xl text-muted-foreground mb-8" />
            <div class="flex flex-col sm:flex-row gap-4 justify-center">
              <a href={routes.contact} class="w-full sm:w-auto inline-flex items-center justify-center gap-2 whitespace-nowrap rounded-md text-sm font-medium ring-offset-background transition-colors focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-ring focus-visible:ring-offset-2 bg-primary text-primary-foreground hover:bg-primary/90 h-11 px-8">
                <T key="home.contactButton" />
              </a>
              <a href={routes.about} class="w-full sm:w-auto inline-flex items-center justify-center gap-2 whitespace-nowrap rounded-md text-sm font-medium ring-offset-background transition-colors focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-ring focus-visible:ring-offset-2 border border-input bg-background hover:bg-accent hover:text-accent-foreground h-11 px-8">
                <T key="home.aboutButton" />
              </a>
              <a href={routes.blog} class="w-full sm:w-auto inline-flex items-center justify-center gap-2 whitespace-nowrap rounded-md text-sm font-medium ring-offset-background transition-colors focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-ring focus-visible:ring-offset-2 border border-input bg-background hover:bg-accent hover:text-accent-foreground h-11 px-8">
                <T key="home.blogButton" />
              </a>
              <a href={routes.guestbook} class="w-full sm:w-auto inline-flex items-center justify-center gap-2 whitespace-nowrap rounded-md text-sm font-medium ring-offset-background transition-colors focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-ring focus-visible:ring-offset-2 border border-input bg-background hover:bg-accent hover:text-accent-foreground h-11 px-8">
                <T key="home.guestbookButton" />
              </a>
            </div>
          </div>
        </div>

        <!-- Main content grid -->
        <div class="grid grid-cols-1 lg:grid-cols-2 lg:gap-8 items-start lg:min-h-[490px]">
          <div class="lg:order-2">
            <NowSection />
          </div>
          <RecentPosts />
        </div>

        <!-- Current mood & Status -->
        <div class="mt-10 lg:mt-12 grid grid-cols-1 lg:grid-cols-2 gap-6 lg:gap-8 lg:items-stretch">
          <section class="flex flex-col" aria-labelledby="current-mood-heading">
            <T key="home.currentMood" tag="h2" id="current-mood-heading" class="text-2xl font-bold mb-4 text-center" />
            <div class="border rounded-lg p-6 bg-card text-center flex-1 flex items-center justify-center">
              <a href="https://www.imood.com/users/jarema" target="_blank" rel="noopener noreferrer" class="focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-ring focus-visible:ring-offset-2 focus-visible:ring-offset-background rounded">
                <img
                  src="https://moods.imood.com/display/uname-jarema/fg-FFFFFF/bg-2c2e84/imood.gif"
                  alt="The current mood of jarema at www.imood.com"
                  height="15"
                  class="inline-block"
                />
              </a>
            </div>
          </section>

          <section class="flex flex-col" aria-labelledby="status-cafe-heading">
            <T key="home.currentStatus" tag="h2" id="status-cafe-heading" class="text-2xl font-bold mb-4 text-center" />
            <div class="border rounded-lg p-6 bg-card text-center flex-1 flex items-center justify-center">
              <div class="w-full max-w-xl mx-auto">
                <div id="statuscafe" class="w-full"><div id="statuscafe-username"></div><div id="statuscafe-content"></div></div>
                <noscript>
                  <div class="text-sm text-muted-foreground text-center">
                    Status updates require JavaScript. You can see my status on
                    <a href="https://status.cafe/users/jarema" class="text-primary hover:underline">status.cafe</a>.
                  </div>
                </noscript>
              </div>
              <script src="https://status.cafe/current-status.js?name=jarema" defer></script>
            </div>
          </section>
        </div>

        <!-- MoodCat and Webrings -->
        <div class="mt-10 lg:mt-12 grid grid-cols-1 lg:grid-cols-2 gap-6 lg:gap-8 lg:items-stretch">
          <MoodCat />

          <section aria-labelledby="webrings-heading" class="flex flex-col">
            <h2 id="webrings-heading" class="text-2xl font-bold mb-4 text-center">
              <a href="/webrings/" tabindex="-1" class="no-underline hover:underline focus:underline text-inherit">
                <T key="webrings.title" />
              </a>
            </h2>
            <nav class="border rounded-lg p-4 bg-card divide-y text-sm" aria-label="Webring navigation">
              {activeWebringItems.map((ring) => (
                  <div class="flex items-center justify-between py-1.5 first:pt-0 last:pb-0">
                    <a href={ring.url} class="text-primary hover:underline font-medium focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-ring focus-visible:ring-offset-2 focus-visible:ring-offset-background rounded-sm" target="_blank" rel="noopener noreferrer">
                      {ring.name}
                    </a>
                    <div class="flex items-center gap-2" role="group" aria-label={`Navigate ${ring.name}`}>
                      <a href={ring.previous} class="text-primary hover:bg-primary/10 rounded px-2 py-1 transition-colors focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-ring focus-visible:ring-offset-2 focus-visible:ring-offset-background" title={`Previous site in ${ring.name}`}>←</a>
                      {ring.random ? (
                        <a href={ring.random} class="text-primary hover:bg-primary/10 rounded px-2 py-1 transition-colors focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-ring focus-visible:ring-offset-2 focus-visible:ring-offset-background" title={`Random site in ${ring.name}`}>🎲</a>
                      ) : (
                        <span class="px-2 py-1 invisible" aria-hidden="true">🎲</span>
                      )}
                      <a href={ring.next} class="text-primary hover:bg-primary/10 rounded px-2 py-1 transition-colors focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-ring focus-visible:ring-offset-2 focus-visible:ring-offset-background" title={`Next site in ${ring.name}`}>→</a>
                    </div>
                  </div>
                ))}
                <div class="pt-4 text-center">
                  <a
                    href={routes.webring}
                    id="view-all-webrings"
                    class="inline-flex items-center gap-2 px-3 py-2 text-sm border rounded-lg hover:bg-accent transition-colors group focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-ring focus-visible:ring-offset-2 focus-visible:ring-offset-background"
                    aria-label="See all webrings"
                  >
                    <T key="home.viewAllWebrings" /> →
                  </a>
                </div>
            </nav>
          </section>
        </div>

      </div>
    </div>
  </div>
</BaseLayout>

<script>
  import { languageStore, initLanguage, t } from "@/i18n";

  // Time-based greeting emoji update
  function updateGreetingEmoji() {
    const hour = new Date().getHours();
    const emojiEl = document.getElementById("greeting-emoji");
    if (!emojiEl) return;

    let emoji = "🌅";
    let greetingKey = "greetings.morning";

    if (hour >= 5 && hour < 12) {
      emoji = "🌅";
      greetingKey = "greetings.morning";
    } else if (hour >= 12 && hour < 17) {
      emoji = "☀️";
      greetingKey = "greetings.afternoon";
    } else if (hour >= 17 && hour < 21) {
      emoji = "🌆";
      greetingKey = "greetings.evening";
    } else {
      emoji = "🌙";
      greetingKey = "greetings.night";
    }

    emojiEl.textContent = emoji;

    // Update the T component's key
    const greetingTComponent = document.querySelector('#greeting [data-t-key="greetings.morning"]');
    if (greetingTComponent) {
      greetingTComponent.setAttribute("data-t-key", greetingKey);
      const translated = t(greetingKey);
      if (translated && translated !== greetingKey) greetingTComponent.textContent = translated;
    }
  }

  // Use pre-detected language if available
  const initialLang = (window as any).__INITIAL_LANG__;
  if (initialLang && initialLang !== "en") {
    languageStore.set(initialLang);
  } else {
    initLanguage();
  }

  updateGreetingEmoji();

  // Listen for language changes to update dynamic greeting
  languageStore.subscribe(() => {
    updateGreetingEmoji();
  });

  window.addEventListener("languageChange", () => {
    updateGreetingEmoji();
  });
</script>
