---
import BaseLayout from "@/layouts/BaseLayout.astro";
import T from "@/components/T.astro";
import { routes, siteName, author, services } from "@/lib/constants";
import { getData } from "@/content/config";
import MoodCat from "@/components/MoodCat.astro";
import NowSection from "@/components/NowSection.astro";
import RecentPosts from "@/components/RecentPosts.astro";

const activeWebringItems = (await getData("webrings")).filter(w => w.status === "active");

const btnBase = "w-full sm:w-auto inline-flex items-center justify-center gap-2 whitespace-nowrap rounded-md text-sm font-medium ring-offset-background transition-colors focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-ring focus-visible:ring-offset-2 h-11 px-8";
const btnPrimary = `${btnBase} bg-primary text-primary-foreground hover:bg-primary/90`;
const btnSecondary = `${btnBase} border border-input bg-background hover:bg-accent hover:text-accent-foreground`;
---

<BaseLayout title={siteName} isHomePage={true}>
  <div class="relative min-h-screen w-full overflow-hidden">
    <div class="container mx-auto px-2 sm:px-4 lg:px-6 py-8 lg:py-12 relative z-10">
      <div class="max-w-6xl mx-auto">
        <!-- Hero Section -->
        <div class="relative pt-10 pb-10 mb-8 text-center">
          <p class="text-lg text-muted-foreground mb-2" id="greeting"><span id="greeting-emoji">👋</span> <T key="greetings.morning" /></p>
          <T key="home.heading" tag="h1" class="text-3xl md:text-4xl lg:text-5xl font-bold mb-4" />
          <T key="home.subheading" tag="p" class="text-lg md:text-xl text-muted-foreground mb-8" />
          <div class="flex flex-col sm:flex-row gap-4 justify-center">
            <a href={routes.contact} class={btnPrimary}><T key="home.contactButton" /></a>
            <a href={routes.about} class={btnSecondary}><T key="home.aboutButton" /></a>
            <a href={routes.blog} class={btnSecondary}><T key="home.blogButton" /></a>
            <a href={routes.guestbook} class={btnSecondary}><T key="home.guestbookButton" /></a>
          </div>
        </div>

        <!-- Main content grid -->
        <div class="grid grid-cols-1 lg:grid-cols-2 lg:gap-8 items-start lg:min-h-[490px]">
          <div class="lg:order-2">
            <NowSection />
          </div>
          <RecentPosts />
        </div>

        <!-- Current mood & Status -->
        <div class="mt-10 lg:mt-12 grid grid-cols-1 lg:grid-cols-2 gap-6 lg:gap-8 lg:items-stretch">
          <section class="flex flex-col" aria-labelledby="current-mood-heading">
            <T key="home.currentMood" tag="h2" id="current-mood-heading" class="text-2xl font-bold mb-4 text-center" />
            <div class="border rounded-lg p-3 bg-card text-center flex-1 flex items-center justify-center">
              <a href={services.iMood.profileUrl} target="_blank" rel="noopener noreferrer" class="focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-ring focus-visible:ring-offset-2 focus-visible:ring-offset-background rounded">
                <img src={services.iMood.widgetUrl} alt="My current mood, loaded from imood" class="inline-block h-[25px]" width="80" height="25" loading="lazy" decoding="async" />
              </a>
            </div>
          </section>

          <section class="flex flex-col" aria-labelledby="status-cafe-heading">
            <T key="home.currentStatus" tag="h2" id="status-cafe-heading" class="text-2xl font-bold mb-4 text-center" />
            <div class="border rounded-lg p-3 bg-card text-center flex-1 flex items-center justify-center">
              <div class="w-full max-w-xl mx-auto h-[64px]">
                <div id="statuscafe" class="w-full" data-statuscafe-user={author.statusCafeUsername}><div id="statuscafe-username"></div><div id="statuscafe-content"></div></div>
                <noscript>
                  <div class="text-sm text-muted-foreground text-center">
                    Status updates require JavaScript. You can see my status on <a href={services.statusCafe.profileUrl} class="text-primary hover:underline">status.cafe</a>.
                  </div>
                </noscript>
              </div>
            </div>
          </section>
        </div>

        <!-- MoodCat and Webrings -->
        <div class="mt-10 lg:mt-12 grid grid-cols-1 lg:grid-cols-2 gap-6 lg:gap-8 lg:items-stretch">
          <MoodCat />

          <section aria-labelledby="webrings-heading" class="flex flex-col">
            <h2 id="webrings-heading" class="text-2xl font-bold mb-4 text-center">
              <a href="/webrings/" tabindex="-1" class="no-underline hover:underline focus:underline text-inherit"><T key="webrings.title" /></a>
            </h2>
            <nav class="border rounded-lg p-4 bg-card divide-y text-sm" aria-label="Webring navigation">
              {activeWebringItems.map((ring) => (
                <div class="flex items-center justify-between py-1.5 first:pt-0 last:pb-0">
                  <a href={ring.url} class="text-primary hover:underline font-medium focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-ring focus-visible:ring-offset-2 focus-visible:ring-offset-background rounded-sm" target="_blank" rel="noopener noreferrer">{ring.name}</a>
                  <div class="flex items-center gap-2" role="group" aria-label={`Navigate ${ring.name}`}>
                    <a href={ring.previous} class="text-primary hover:bg-primary/10 rounded px-2 py-1 transition-colors focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-ring focus-visible:ring-offset-2 focus-visible:ring-offset-background" title={`Previous site in ${ring.name}`}>←</a>
                    {ring.random ? <a href={ring.random} class="text-primary hover:bg-primary/10 rounded px-2 py-1 transition-colors focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-ring focus-visible:ring-offset-2 focus-visible:ring-offset-background" title={`Random site in ${ring.name}`}>🎲</a> : <span class="px-2 py-1 invisible" aria-hidden="true">🎲</span>}
                    <a href={ring.next} class="text-primary hover:bg-primary/10 rounded px-2 py-1 transition-colors focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-ring focus-visible:ring-offset-2 focus-visible:ring-offset-background" title={`Next site in ${ring.name}`}>→</a>
                  </div>
                </div>
              ))}
              <div class="pt-4 text-center">
                <a href={routes.webring} id="view-all-webrings" class="inline-flex items-center gap-2 px-3 py-2 text-sm border rounded-lg hover:bg-accent transition-colors group focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-ring focus-visible:ring-offset-2 focus-visible:ring-offset-background" aria-label="See all webrings">
                  <T key="home.viewAllWebrings" /> →
                </a>
              </div>
            </nav>
          </section>
        </div>

      </div>
    </div>
  </div>
</BaseLayout>

<script>
  import { t } from "@/i18n/client";
  import { services } from "@/lib/constants";

  const statusCafeProfileUrl = services.statusCafe.profileUrl;

  const greetings = [
    { hours: [5, 12], emoji: "🌅", key: "greetings.morning" },
    { hours: [12, 17], emoji: "☀️", key: "greetings.afternoon" },
    { hours: [17, 21], emoji: "🌆", key: "greetings.evening" },
    { hours: [21, 5], emoji: "🌙", key: "greetings.night" }
  ];

  function updateGreetingEmoji() {
    const hour = new Date().getHours();
    const emojiEl = document.getElementById("greeting-emoji");
    const greetingEl = document.getElementById("greeting");
    if (!emojiEl || !greetingEl) return;

    const greeting = greetings.find(g => hour >= g.hours[0] && hour < g.hours[1]) || greetings[3];
    emojiEl.textContent = greeting.emoji;
    const textEl = greetingEl.querySelector("span:last-child");
    if (textEl) {
      const translated = t(greeting.key);
      if (translated !== greeting.key) textEl.textContent = translated;
    }
  }

  updateGreetingEmoji();

  const u = document.getElementById("statuscafe-username"), c = document.getElementById("statuscafe-content");
  if (u && c) {
    const ac = new AbortController();
    setTimeout(() => ac.abort(), 5000);
    fetch(`${statusCafeProfileUrl}/status.json`, { headers: { Accept: "application/json" }, signal: ac.signal })
      .then(r => r.ok ? r.json() : Promise.reject())
      .then(r => {
        if (!r?.content?.length) return c.textContent = "No status yet.";
        // Avoid injecting raw API data as HTML
        u.textContent = '';
        const link = document.createElement('a');
        link.href = statusCafeProfileUrl;
        link.target = '_blank';
        link.rel = 'noopener noreferrer';
        link.textContent = `@${r.author}`;
        u.appendChild(link);
        u.append(` · ${r.face || ''} · ${r.timeAgo || ''}`);
        c.textContent = r.content;
      })
      .catch(() => c.textContent = "Couldn't load status.");
  }
</script>
