---
import BaseLayout from "@/layouts/BaseLayout.astro";
import Game2048 from "@/components/game/Game2048";
---

<BaseLayout title="2048">
  <div class="container mx-auto px-4">
    <div class="relative">
      <noscript>
        <div class="flex items-center justify-center bg-background/90 p-6">
          <div class="max-w-md w-full bg-card border rounded-lg p-6 text-center">
            <h1 class="text-2xl font-bold mb-2">JavaScript required</h1>
            <p class="text-muted-foreground">
              This game needs JavaScript to run. Please enable JavaScript and reload the page.
            </p>
          </div>
        </div>
      </noscript>

      <Game2048 client:only="preact" />
    </div>
  </div>
</BaseLayout>
