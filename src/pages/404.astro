---
// 404 Page with i18n support - styled like the old version
import BaseLayout from "@/layouts/BaseLayout.astro";
---

<BaseLayout title="404 - Page Not Found">
  <div class="container mx-auto px-4 py-16 lg:py-24">
    <div class="max-w-md mx-auto text-center">
      <!-- Cat icon -->
      <div class="mb-8 flex justify-center">
        <div class="bg-primary rounded-full p-6">
          <svg xmlns="http://www.w3.org/2000/svg" width="64" height="64" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-primary-foreground">
            <path d="M12 5c.67 0 1.35.09 2 .26 1.78-2 5.03-2.84 6.42-2.26 1.4.58-.42 7-.42 7 .57 1.07 1 2.24 1 3.44C21 17.9 16.97 21 12 21s-9-3.1-9-7.56c0-1.25.5-2.4 1-3.44 0 0-1.89-6.42-.5-7 1.39-.58 4.72.23 6.5 2.23A9.04 9.04 0 0 1 12 5Z"/>
            <path d="M8 14v.5"/>
            <path d="M16 14v.5"/>
            <path d="M11.25 16.25h1.5L12 17l-.75-.75Z"/>
          </svg>
        </div>
      </div>

      <h1 class="text-4xl font-bold mb-4" data-i18n="404.title">Page not found</h1>

      <p class="text-muted-foreground mb-8" data-i18n="404.description">
        The page you're looking for doesn't exist or has been moved.
      </p>

      <div class="flex flex-col sm:flex-row gap-4 justify-center">
        <a
          href="/"
          class="inline-flex items-center justify-center gap-2 rounded-md text-sm font-medium bg-primary text-primary-foreground hover:bg-primary/90 h-10 px-4"
        >
          <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <path d="m3 9 9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"/>
            <polyline points="9 22 9 12 15 12 15 22"/>
          </svg>
          <span data-i18n="404.button">Go home</span>
        </a>
        <a
          href="/slashes/"
          class="inline-flex items-center justify-center gap-2 rounded-md text-sm font-medium border border-input bg-background hover:bg-accent h-10 px-4"
        >
          <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <polygon points="3 6 9 3 15 6 21 3 21 18 15 21 9 18 3 21"/>
            <line x1="9" x2="9" y1="3" y2="18"/>
            <line x1="15" x2="15" y1="6" y2="21"/>
          </svg>
          <span data-i18n="404.sitemap">Site directory</span>
        </a>
      </div>

      <!-- Animated compass -->
      <div class="mt-12 flex justify-center">
        <div class="animate-spin-slow">
          <svg xmlns="http://www.w3.org/2000/svg" width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-muted-foreground/50">
            <circle cx="12" cy="12" r="10"/>
            <polygon points="16.24 7.76 14.12 14.12 7.76 16.24 9.88 9.88 16.24 7.76"/>
          </svg>
        </div>
      </div>

      <!-- MoodCat section -->
      <div class="mt-16">
        <h2 class="text-2xl font-bold mb-4" data-i18n="404.enjoycat">
          Here's a cat to cheer you up
        </h2>
        <div class="border rounded-lg p-4 bg-card">
          <div class="w-[280px] h-[200px] mx-auto overflow-hidden rounded-lg">
            <img
              src="https://cataas.com/cat"
              alt="A random cat to cheer you up"
              class="w-full h-full object-cover object-center"
              loading="lazy"
            />
          </div>
          <button
            id="refresh-cat-404"
            class="mt-3 text-sm text-muted-foreground hover:text-primary transition-colors flex items-center gap-1 mx-auto"
          >
            <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <path d="M21 12a9 9 0 1 1-9-9c2.52 0 4.93 1 6.74 2.74L21 8" />
              <path d="M21 3v5h-5" />
            </svg>
            <span data-i18n="moodCat.refresh">New cat</span>
          </button>
        </div>
      </div>
    </div>
  </div>
</BaseLayout>

<style>
  @keyframes spin-slow {
    from {
      transform: rotate(0deg);
    }
    to {
      transform: rotate(360deg);
    }
  }
  .animate-spin-slow {
    animation: spin-slow 8s linear infinite;
  }
</style>

<script>
  import { languageStore, t, initLanguage } from '@/i18n';

  const refreshBtn = document.getElementById('refresh-cat-404');
  const catImage = document.querySelector('#refresh-cat-404')?.parentElement?.querySelector('img') as HTMLImageElement;

  if (refreshBtn && catImage) {
    refreshBtn.addEventListener('click', () => {
      const timestamp = Date.now();
      catImage.src = `https://cataas.com/cat?t=${timestamp}`;
    });
  }

  function updateTranslations() {
    document.querySelectorAll('[data-i18n]').forEach((el) => {
      const key = el.getAttribute('data-i18n');
      if (key) {
        const translated = t(key);
        if (translated !== key) {
          el.textContent = translated;
        }
      }
    });
  }

  initLanguage();
  updateTranslations();

  languageStore.subscribe(() => {
    updateTranslations();
  });

  window.addEventListener('languageChange', () => {
    updateTranslations();
  });
</script>
