---
import BaseLayout from "@/layouts/BaseLayout.astro";
import T from "@/components/T.astro";

const iconClass = "fill-none stroke-current stroke-2 stroke-linecap-round stroke-linejoin-round";
const btnClass = "inline-flex items-center justify-center gap-2 rounded-md text-sm font-medium h-10 px-4";
---

<BaseLayout title="404 - Page Not Found">
  <div class="container mx-auto px-4 py-16 lg:py-24">
    <div class="max-w-md mx-auto text-center">
      <div class="mb-8 flex bg-primary rounded-full p-6 w-fit mx-auto">
        <svg width="64" height="64" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-primary-foreground">
          <path d="M12 5c.67 0 1.35.09 2 .26 1.78-2 5.03-2.84 6.42-2.26 1.4.58-.42 7-.42 7 .57 1.07 1 2.24 1 3.44C21 17.9 16.97 21 12 21s-9-3.1-9-7.56c0-1.25.5-2.4 1-3.44 0 0-1.89-6.42-.5-7 1.39-.58 4.72.23 6.5 2.23A9.04 9.04 0 0 1 12 5Z"/>
          <path d="M8 14v.5 M16 14v.5 M11.25 16.25h1.5L12 17l-.75-.75Z"/>
        </svg>
      </div>

      <T key="404.title" tag="h1" class="text-4xl font-bold mb-4" />
      <T key="404.description" tag="p" class="text-muted-foreground mb-8" />

      <div class="flex flex-col sm:flex-row gap-4 justify-center">
        <a href="/" class={`${btnClass} bg-primary text-primary-foreground hover:bg-primary/90`}>
          <svg width="16" height="16" viewBox="0 0 24 24" class={iconClass}>
            <path d="m3 9 9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"/><polyline points="9 22 9 12 15 12 15 22"/>
          </svg>
          <T key="404.button" />
        </a>
        <a href="/slashes/" class={`${btnClass} border border-input bg-background hover:bg-accent`}>
          <svg width="16" height="16" viewBox="0 0 24 24" class={iconClass}>
            <polygon points="3 6 9 3 15 6 21 3 21 18 15 21 9 18 3 21"/><line x1="9" x2="9" y1="3" y2="18"/><line x1="15" x2="15" y1="6" y2="21"/>
          </svg>
          <T key="404.sitemap" />
        </a>
      </div>

      <div class="mt-12 animate-spin-slow w-fit mx-auto">
        <svg width="48" height="48" viewBox="0 0 24 24" class={`${iconClass} text-muted-foreground/50`}>
          <circle cx="12" cy="12" r="10"/><polygon points="16.24 7.76 14.12 14.12 7.76 16.24 9.88 9.88 16.24 7.76"/>
        </svg>
      </div>

      <div class="mt-16">
        <T key="404.enjoycat" tag="h2" class="text-2xl font-bold mb-4" />
        <div class="border rounded-lg p-4 bg-card">
          <img id="cat-img" src="https://cataas.com/cat" alt="A random cat to cheer you up"
               class="w-[280px] h-[200px] mx-auto rounded-lg object-cover" loading="lazy" />
          <button id="refresh-cat" class="mt-3 text-sm text-muted-foreground hover:text-primary flex items-center gap-1 mx-auto">
            <svg width="14" height="14" viewBox="0 0 24 24" class={iconClass}>
              <path d="M21 12a9 9 0 1 1-9-9c2.52 0 4.93 1 6.74 2.74L21 8M21 3v5h-5"/>
            </svg>
            <T key="moodCat.refresh" />
          </button>
        </div>
      </div>
    </div>
  </div>
</BaseLayout>

<style>
  .animate-spin-slow {
    animation: spin-slow 8s linear infinite;
  }
  @keyframes spin-slow {
    to { transform: rotate(360deg); }
  }
  @media (prefers-reduced-motion: reduce) {
    .animate-spin-slow { animation: none; }
  }
</style>

<script>
  document.getElementById('refresh-cat')?.addEventListener('click', () => {
    const img = document.getElementById('cat-img') as HTMLImageElement;
    if (img) img.src = `https://cataas.com/cat?t=${Date.now()}`;
  });
</script>
