---
// Guestbook Page with atabook
import BaseLayout from "@/layouts/BaseLayout.astro";
import T from "@/components/T.astro";
---

<BaseLayout title="Guestbook" description="Leave a message in my guestbook!">
  <div class="container mx-auto px-4 py-8 lg:py-12">
    <div class="max-w-2xl mx-auto">
      <header class="mb-8 text-center">
        <T key="guestbook.title" tag="h1" class="text-4xl font-bold mb-4" />
        <T key="guestbook.description" tag="p" class="text-muted-foreground" />
      </header>

      <!-- Atabook guestbook iframe -->
      <div class="border rounded-lg overflow-hidden bg-card">
        <iframe
          src="https://jarema.atabook.org"
          class="w-full min-h-[800px] border-0"
          title="Guestbook"
          loading="lazy"
        ></iframe>
        <noscript>
          <div class="p-6 text-center">
            <p class="text-muted-foreground">
              The guestbook requires JavaScript to be enabled.
              Alternatively, you can <a href="mailto:hello@jarema.me" class="text-primary hover:underline">email me</a> directly.
            </p>
          </div>
        </noscript>
      </div>

      <div class="mt-8 text-center text-sm text-muted-foreground">
        <p>
          Powered by <a href="https://atabook.org" target="_blank" rel="noopener noreferrer" class="text-primary hover:underline">Atabook</a>.
          Be kind and respectful. 💜
        </p>
      </div>
    </div>
  </div>
</BaseLayout>
