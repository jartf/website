---
import BaseLayout from "@/layouts/BaseLayout.astro";
import T from "@/components/T.astro";
import { routes } from "@/lib/constants";

const slashPages = [
  { path: routes.about, name: "nav.about", nameDefault: "About", desc: "about.description", descDefault: "Learn about me" },
  { path: routes.blog, name: "nav.blog", nameDefault: "Blog", desc: "blog.description", descDefault: "Read my posts" },
  { path: routes.contact, name: "nav.contact", nameDefault: "Contact", desc: "contact.description", descDefault: "Get in touch" },
  { path: routes.now, name: "nav.now", nameDefault: "Now", desc: "now.description", descDefault: "What I'm doing now" },
  { path: routes.uses, name: "nav.uses", nameDefault: "Uses", desc: "uses.description", descDefault: "Tech and tools I use" },
  { path: routes.colophon, name: "nav.colophon", nameDefault: "Colophon", desc: "colophon.description", descDefault: "How this site is built" },
  { path: routes.guestbook, name: "nav.guestbook", nameDefault: "Guestbook", desc: "guestbook.description", descDefault: "Leave a message" },
  { path: routes.webring, name: "nav.webring", nameDefault: "Webrings", desc: "webrings.description", descDefault: "Web communities" },
  { path: routes.badges, name: "keyboardShortcuts.navigation", nameDefault: "Badges", desc: "badges.description", descDefault: "88x31 badges" },
  { path: routes.projects, name: "nav.projects", nameDefault: "Projects", desc: "projects.description", descDefault: "Things I've built" },
  { path: routes.scrapbook, name: "nav.scrapbook", nameDefault: "Devlog", desc: "scrapbook.description", descDefault: "Development log" },
  { path: routes.brand, name: "nav.brand", nameDefault: "Brand", desc: "brand.pageDescription", descDefault: "Visual identity and brand elements" },
];
---

<BaseLayout title="Slashes" description="Common slash pages on this site.">
  <div class="container mx-auto px-4 py-8 lg:py-12">
    <div class="max-w-2xl mx-auto">
      <header class="mb-8 text-center">
        <T key="slashes.title" tag="h1" class="text-4xl font-bold mb-4" />
        <p class="text-muted-foreground">
          <T key="slashes.descriptionStart" />
          {' '}
          <a href="https://slashpages.net/" target="_blank" rel="noopener noreferrer" class="text-primary hover:underline"><T key="slashes.linkText" /></a>
          {' '}
          <T key="slashes.descriptionEnd" />
        </p>
      </header>

      <div class="space-y-3">
        {slashPages.map(({ path, name, nameDefault, desc, descDefault }) => (
          <a href={path} class="flex items-start justify-between p-4 border rounded-lg bg-card hover:border-primary/50 transition-colors group">
            <div class="flex-1">
              <span class="font-medium group-hover:text-primary transition-colors" data-i18n={name}>{nameDefault}</span>
              <p class="text-sm text-muted-foreground" data-i18n={desc}>{descDefault}</p>
            </div>
            <span class="text-muted-foreground font-mono text-sm self-start text-right ml-4">{path}</span>
          </a>
        ))}
      </div>
    </div>
  </div>
</BaseLayout>

<script>
  import { languageStore, t, initLanguage } from '@/i18n';

  function updateTranslations() {
    document.querySelectorAll('[data-i18n]').forEach((el) => {
      const key = el.getAttribute('data-i18n');
      if (key) {
        const translated = t(key);
        if (translated !== key) el.textContent = translated;
      }
    });
  }

  initLanguage();
  updateTranslations();
  languageStore.subscribe(updateTranslations);
  window.addEventListener('languageChange', updateTranslations);
</script>
