---
// Dynamic blog post page
import BaseLayout from "@/layouts/BaseLayout.astro";
import { getCollection, render, type CollectionEntry } from "astro:content";
import ShareButtons from "@/components/blog/ShareButtons.astro";
import T from "@/components/T.astro";
import { t } from "@/i18n";
import { supportedLanguages, siteUrl, siteName, author, routes } from "@/lib/constants";
import { localePath, stripLocale } from "@/i18n/routing";
import { dateFull } from "@/lib/utils/timezone-utils";

const lang = Astro.locals?.lang || "en";

export async function getStaticPaths() {
  const posts = await getCollection("blog");
  return posts.map((post: CollectionEntry<"blog">) => ({
    params: { slug: post.id },
    props: { post },
  }));
}

interface Props {
  post: CollectionEntry<"blog">;
}

const { post } = Astro.props;
const { Content } = await render(post);
const { title, excerpt, date, updated, language, tags, category, readingTime, mood, catApproved, alternates } = post.data;

const postUrl = Astro.url.href;
const postLang = language ?? "en";
const description = excerpt || `Read "${title}" on ${siteName}.`;
const hasUpdatedDate = Boolean(updated && updated.getTime() > date.getTime());

// Structured data
const blogPostingStructuredData: Record<string, unknown> = {
  "@context": "https://schema.org",
  "@type": "BlogPosting",
  "@id": `${postUrl}#blogposting`,
  mainEntityOfPage: { "@type": "WebPage", "@id": postUrl },
  headline: title,
  description,
  datePublished: date.toISOString(),
  inLanguage: postLang,
  url: postUrl,
  author: { "@id": `${siteUrl}/#person` },
  publisher: { "@id": `${siteUrl}/#person` },
  image: [`${siteUrl}/android-chrome-512x512.png`],
  isAccessibleForFree: true,
  ...(updated && { dateModified: updated.toISOString() }),
  ...(tags?.length && { keywords: tags.join(", ") }),
  ...(category && { articleSection: category }),
  ...(readingTime && { timeRequired: `PT${Math.max(1, Math.round(readingTime))}M` }),
};

// Post navigation
const allPosts = await getCollection("blog", ({ data }: CollectionEntry<"blog">) => !data.draft);
const sortedPosts = allPosts.sort((a: CollectionEntry<"blog">, b: CollectionEntry<"blog">) =>
  b.data.date.getTime() - a.data.date.getTime()
);
const currentIndex = sortedPosts.findIndex((p: CollectionEntry<"blog">) => p.id === post.id);
const prevPost = currentIndex < sortedPosts.length - 1 ? sortedPosts[currentIndex + 1] : null;
const nextPost = currentIndex > 0 ? sortedPosts[currentIndex - 1] : null;

// Webmentions
interface WebmentionAuthor {
  type?: string;
  name?: string;
  url?: string;
  photo?: string;
}
interface Webmention {
  type?: string;
  author?: WebmentionAuthor;
  url?: string;
  published?: string;
  "wm-received"?: string;
  "wm-id"?: number;
  "wm-property"?: string;
  content?: { text?: string; html?: string };
}

const webmentionPath = stripLocale(new URL(postUrl).pathname);
const webmentionUrl = import.meta.env.DEV ? new URL(siteUrl) : new URL(postUrl);
webmentionUrl.pathname = webmentionPath;
webmentionUrl.search = "";
webmentionUrl.hash = "";
const webmentionTarget = webmentionUrl.href.endsWith("/") ? webmentionUrl.href : `${webmentionUrl.href}/`;
let webmentions: Webmention[] = [];
try {
  const wmResponse = await fetch(`https://webmention.io/api/mentions.jf2?target=${encodeURI(webmentionTarget)}`);
  if (wmResponse.ok) {
    const wmJson = await wmResponse.json();
    webmentions = wmJson.children ?? [];
  }
} catch { /* silent fail */ }

const wmLikes = webmentions.filter((wm) => wm["wm-property"] === "like-of");
const wmReposts = webmentions.filter((wm) => wm["wm-property"] === "repost-of");
const wmReplies = webmentions.filter((wm) => wm["wm-property"] === "in-reply-to");
const wmMentions = webmentions.filter((wm) => wm["wm-property"] === "mention-of");
const hasWebmentions = webmentions.length > 0;

// Helper: format date for display
const formatDate = (d: Date) => d.toLocaleDateString("en", dateFull);
---

<BaseLayout title={title} description={description} lang={postLang} structuredData={blogPostingStructuredData}>
  <article class="h-entry container mx-auto px-4 py-8 lg:py-12 max-w-3xl">
    <header class="mb-8">
      <div class="text-sm text-muted-foreground mb-4">
        <a href={localePath(lang, routes.blog)} class="hover:text-primary transition-colors">
          ← <T key="blog.back" />
        </a>
      </div>

      <h1 class="p-name text-3xl md:text-4xl font-bold mb-4">{title}</h1>
      {excerpt && <p class="p-summary hidden">{excerpt}</p>}
      <a href={postUrl} class="u-url u-uid hidden" aria-hidden="true">{postUrl}</a>

      <div class="flex flex-wrap items-center gap-3 text-sm text-muted-foreground">
        <time class="dt-published" datetime={date.toISOString()} data-date={date.toISOString()}>
          {formatDate(date)}
        </time>
        {hasUpdatedDate && updated && (
          <>
            <span aria-hidden="true">•</span>
            <span>
              <T key="now.lastUpdated" />{" "}
              <time class="dt-updated" datetime={updated.toISOString()} data-date={updated.toISOString()}>
                {formatDate(updated)}
              </time>
            </span>
          </>
        )}
        <span aria-hidden="true">•</span>
        <span><span id="reading-time-value">{readingTime || 5}</span> <T key="blog.minRead" /></span>
        {mood && (
          <>
            <span aria-hidden="true">•</span>
            <span><T key="blog.mood" />: {mood}</span>
          </>
        )}
        {catApproved && (
          <>
            <span aria-hidden="true">•</span>
            <span title="Cat approved!" aria-label="Cat approved">🐱 ✓</span>
          </>
        )}
      </div>

      {tags?.length && (
        <div class="flex gap-2 flex-wrap mt-4" role="list" aria-label="Tags">
          {tags.map((tag: string) => (
            <span role="listitem" class="p-category text-xs px-2 py-1 rounded bg-muted text-muted-foreground">
              {tag}
            </span>
          ))}
        </div>
      )}

      <div class="mt-6">
        <ShareButtons title={title} url={postUrl} />
      </div>

      {alternates?.length && (
        <div class="mt-4 p-3 rounded-lg bg-muted/50 border">
          <T key="blog.availableIn" class="text-sm text-muted-foreground" />
          <span class="text-sm text-muted-foreground"> </span>
          {alternates.map((alt: { slug: string; language: string }, i: number) => (
            <>
              <a href={`/blog/${alt.slug}/`} class="text-sm text-primary hover:underline">
                {supportedLanguages.find((l) => l.code === alt.language)?.name || alt.language.toUpperCase()}
              </a>{i < alternates.length - 1 && <span class="text-muted-foreground">, </span>}
            </>
          ))}
        </div>
      )}
    </header>

    <div class="p-author h-card hidden" aria-hidden="true">
      <a class="p-name u-url" href={siteUrl}>{author.name}</a>
    </div>

    <div class="e-content prose dark:prose-invert max-w-none blog-content">
      <Content />
    </div>

    <!-- Webmentions -->
    <section class="mt-12 pt-8 border-t" aria-labelledby="webmentions-heading">
      <h2 id="webmentions-heading" class="text-2xl font-bold mb-6"><T key="blog.webmentions" /></h2>

      {hasWebmentions ? (
        <div class="space-y-8">
          {/* Likes */}
          {wmLikes.length > 0 && (
            <div>
              <h3 class="text-sm font-semibold text-muted-foreground mb-3">❤️ {wmLikes.length} <T key="blog.webmentionLike" /></h3>
              <div class="flex flex-wrap gap-1" role="list" aria-label={t(lang, "blog.webmentionLike")}>
                {wmLikes.map((wm) => (
                  <a
                    role="listitem"
                    href={wm.author?.url || wm.url}
                    target="_blank"
                    rel="noopener noreferrer"
                    title={wm.author?.name || "Anonymous"}
                    class="block"
                  >
                    {wm.author?.photo ? (
                      <img
                        src={wm.author.photo}
                        alt={wm.author?.name || "Anonymous"}
                        width="32"
                        height="32"
                        class="rounded-full"
                        loading="lazy"
                      />
                    ) : (
                      <span class="inline-flex items-center justify-center w-8 h-8 rounded-full bg-muted text-xs font-medium">
                        {(wm.author?.name || "?")[0]}
                      </span>
                    )}
                  </a>
                ))}
              </div>
            </div>
          )}

          {/* Reposts */}
          {wmReposts.length > 0 && (
            <div>
              <h3 class="text-sm font-semibold text-muted-foreground mb-3">🔁 {wmReposts.length} <T key="blog.webmentionRepost" /></h3>
              <div class="flex flex-wrap gap-1" role="list" aria-label={t(lang, "blog.webmentionRepost")}>
                {wmReposts.map((wm) => (
                  <a
                    role="listitem"
                    href={wm.author?.url || wm.url}
                    target="_blank"
                    rel="noopener noreferrer"
                    title={wm.author?.name || "Anonymous"}
                    class="block"
                  >
                    {wm.author?.photo ? (
                      <img
                        src={wm.author.photo}
                        alt={wm.author?.name || "Anonymous"}
                        width="32"
                        height="32"
                        class="rounded-full"
                        loading="lazy"
                      />
                    ) : (
                      <span class="inline-flex items-center justify-center w-8 h-8 rounded-full bg-muted text-xs font-medium">
                        {(wm.author?.name || "?")[0]}
                      </span>
                    )}
                  </a>
                ))}
              </div>
            </div>
          )}

          {/* Replies */}
          {wmReplies.length > 0 && (
            <div>
              <h3 class="text-sm font-semibold text-muted-foreground mb-3">💬 {wmReplies.length} <T key="blog.webmentionReply" /></h3>
              <ol class="space-y-4" aria-label={t(lang, "blog.webmentionReply")}>
                {wmReplies.map((wm) => (
                  <li class="flex gap-3 p-3 rounded-lg bg-muted/30">
                    <a href={wm.author?.url} target="_blank" rel="noopener noreferrer" class="shrink-0">
                      {wm.author?.photo ? (
                        <img src={wm.author.photo} alt="" width="40" height="40" class="rounded-full" loading="lazy" />
                      ) : (
                        <span class="inline-flex items-center justify-center w-10 h-10 rounded-full bg-muted text-sm font-medium">
                          {(wm.author?.name || "?")[0]}
                        </span>
                      )}
                    </a>
                    <div class="min-w-0">
                      <div class="flex items-baseline gap-2 text-sm">
                        <a href={wm.author?.url} target="_blank" rel="noopener noreferrer" class="font-semibold hover:underline truncate">
                          {wm.author?.name || "Anonymous"}
                        </a>
                        {wm.published && (
                          <time class="text-xs text-muted-foreground shrink-0" datetime={wm.published}>
                            {formatDate(new Date(wm.published))}
                          </time>
                        )}
                      </div>
                      {wm.content?.text && (
                        <p class="mt-1 text-sm text-muted-foreground line-clamp-3">{wm.content.text}</p>
                      )}
                      {wm.url && (
                        <a href={wm.url} target="_blank" rel="noopener noreferrer" class="text-xs text-primary hover:underline mt-1 inline-block">↗</a>
                      )}
                    </div>
                  </li>
                ))}
              </ol>
            </div>
          )}

          {/* Generic mentions */}
          {wmMentions.length > 0 && (
            <div>
              <h3 class="text-sm font-semibold text-muted-foreground mb-3">🔗 {wmMentions.length} <T key="blog.webmentionMention" /></h3>
              <ul class="space-y-2" aria-label={t(lang, "blog.webmentionMention")}>
                {wmMentions.map((wm) => (
                  <li class="flex items-center gap-2 text-sm">
                    {wm.author?.photo ? (
                      <img src={wm.author.photo} alt="" width="24" height="24" class="rounded-full" loading="lazy" />
                    ) : (
                      <span class="inline-flex items-center justify-center w-6 h-6 rounded-full bg-muted text-[10px] font-medium">
                        {(wm.author?.name || "?")[0]}
                      </span>
                    )}
                    <a href={wm.url} target="_blank" rel="noopener noreferrer" class="text-primary hover:underline truncate">
                      {wm.author?.name || wm.url}
                    </a>
                  </li>
                ))}
              </ul>
            </div>
          )}
        </div>
      ) : (
        <p class="text-muted-foreground"><T key="blog.webmentionsNone" /></p>
      )}
    </section>

    <!-- Post navigation -->
    <nav class="mt-12 pt-8 border-t" aria-label="Post navigation">
      <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
        {prevPost && (
          <a href={localePath(lang, `/blog/${prevPost.id}/`)} class="group p-4 border rounded-lg hover:border-primary/50 transition-colors">
            <span class="text-xs text-muted-foreground">← </span>
            <T key="blog.prev" class="text-xs text-muted-foreground" />
            <p class="font-medium group-hover:text-primary transition-colors line-clamp-1">{prevPost.data.title}</p>
          </a>
        )}
        {nextPost && (
          <a href={localePath(lang, `/blog/${nextPost.id}/`)} class="group p-4 border rounded-lg hover:border-primary/50 transition-colors md:text-right md:ml-auto">
            <T key="blog.next" class="text-xs text-muted-foreground" />
            <span class="text-xs text-muted-foreground"> →</span>
            <p class="font-medium group-hover:text-primary transition-colors line-clamp-1">{nextPost.data.title}</p>
          </a>
        )}
      </div>
    </nav>
  </article>
</BaseLayout>

<script>
  import { getPageLocale } from "@/i18n/client";
  import { updateDateElements, dateFull } from "@/lib/utils/timezone-utils";

  updateDateElements(document, getPageLocale(), dateFull);

  const copyIcon = '<svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M16 4h2a2 2 0 0 1 2 2v14a2 2 0 0 1-2 2H6a2 2 0 0 1-2-2V6a2 2 0 0 1 2-2h2"></path><rect x="8" y="2" width="8" height="4" rx="1" ry="1"></rect></svg>';
  const checkIcon = '<svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"></polyline></svg>';

  async function copyHandler(button: HTMLButtonElement, text: string): Promise<void> {
    if (!text?.trim()) return;
    try {
      await navigator.clipboard.writeText(text);
      button.classList.add('copied');
      button.innerHTML = checkIcon;
      setTimeout(() => {
        button.classList.remove('copied');
        button.innerHTML = copyIcon;
      }, 2000);
    } catch (err) {
      console.error('Copy failed:', err);
    }
  }

  function createButton(label: string): HTMLButtonElement {
    const btn = document.createElement('button');
    btn.className = 'copy-button';
    btn.type = 'button';
    btn.setAttribute('aria-label', label);
    btn.setAttribute('title', 'Copy to clipboard');
    btn.innerHTML = copyIcon;
    return btn;
  }

  function addCopyButtons(): void {
    const blogContent = document.querySelector<HTMLElement>('.blog-content');
    if (!blogContent) return;

    [
      { selector: 'pre', label: 'Copy code', textSel: 'code' },
      { selector: 'blockquote', label: 'Copy quote', textSel: null }
    ].forEach(({ selector, label, textSel }) => {
      blogContent.querySelectorAll(selector).forEach((el) => {
        if (el.querySelector('.copy-button')) return;
        const btn = createButton(label);
        btn.addEventListener('click', () => copyHandler(btn, (textSel ? el.querySelector(textSel) : el)?.textContent || ''));
        el.appendChild(btn);
      });
    });
  }

  document.readyState === 'loading'
    ? document.addEventListener('DOMContentLoaded', addCopyButtons)
    : addCopyButtons();
</script>
