---
// Dynamic blog post page
import BaseLayout from "@/layouts/BaseLayout.astro";
import { getCollection, type CollectionEntry } from "astro:content";
import ShareButtons from "@/components/blog/ShareButtons.astro";
import T from "@/components/T.astro";
import { supportedLanguages, siteUrl, siteName, author, services, routes } from "@/lib/constants";

export async function getStaticPaths() {
  const posts = await getCollection("blog");
  return posts.map((post: CollectionEntry<"blog">) => ({
    params: { slug: post.slug },
    props: { post },
  }));
}

interface Props {
  post: CollectionEntry<"blog">;
}

const { post } = Astro.props;
const { Content } = await post.render();

const postUrl = Astro.url.href;
const postLang = post.data.language ?? "en";
const postInLanguage = postLang === "vih" ? "vi" : postLang;

const blogPostingStructuredData: Record<string, unknown> = {
  "@context": "https://schema.org",
  "@type": "BlogPosting",
  "@id": `${postUrl}#blogposting`,
  mainEntityOfPage: {
    "@type": "WebPage",
    "@id": postUrl,
  },
  headline: post.data.title,
  description: post.data.excerpt || `Read "${post.data.title}" on ${siteName}.`,
  datePublished: post.data.date.toISOString(),
  inLanguage: postInLanguage,
  url: postUrl,
  author: { "@id": `${siteUrl}/#person` },
  publisher: { "@id": `${siteUrl}/#person` },
  image: [`${siteUrl}/android-chrome-512x512.png`],
  isAccessibleForFree: true,
};

if (post.data.updated) {
  blogPostingStructuredData.dateModified = post.data.updated.toISOString();
}

if (post.data.tags?.length) {
  blogPostingStructuredData.keywords = post.data.tags.join(", ");
}

if (post.data.category) {
  blogPostingStructuredData.articleSection = post.data.category;
}

if (post.data.readingTime) {
  blogPostingStructuredData.timeRequired = `PT${Math.max(1, Math.round(post.data.readingTime))}M`;
}

// Get all posts for navigation
const allPosts = await getCollection("blog", ({ data }: CollectionEntry<"blog">) => !data.draft);
const sortedPosts = allPosts.sort((a: CollectionEntry<"blog">, b: CollectionEntry<"blog">) =>
  new Date(b.data.date).getTime() - new Date(a.data.date).getTime()
);
const currentIndex = sortedPosts.findIndex((p: CollectionEntry<"blog">) => p.slug === post.slug);
const prevPost = currentIndex < sortedPosts.length - 1 ? sortedPosts[currentIndex + 1] : null;
const nextPost = currentIndex > 0 ? sortedPosts[currentIndex - 1] : null;
---

<BaseLayout
  title={post.data.title}
  description={post.data.excerpt || `Read "${post.data.title}" on ${siteName}.`}
  lang={post.data.language ?? 'en'}
  structuredData={blogPostingStructuredData}
>
  <article class="h-entry container mx-auto px-4 py-8 lg:py-12 max-w-3xl">
    <header class="mb-8">
      <div class="flex items-center gap-3 text-sm text-muted-foreground mb-4">
        <a href={routes.blog} class="hover:text-primary transition-colors">
          ← <T key="blog.back" />
        </a>
      </div>

      <h1 class="p-name text-3xl md:text-4xl font-bold mb-4">{post.data.title}</h1>
      {post.data.excerpt && (
        <p class="p-summary hidden">{post.data.excerpt}</p>
      )}
      <a href={`${postUrl}/`} class="u-url u-uid hidden" aria-hidden="true">{`${postUrl}`}</a>

      <div class="flex flex-wrap items-center gap-3 text-sm text-muted-foreground">
        <time class="dt-published" datetime={post.data.date.toISOString()} data-date={post.data.date.toISOString()}>
          {post.data.date.toLocaleDateString('en', {
            year: 'numeric',
            month: 'long',
            day: 'numeric'
          })}
        </time>
        {post.data.updated && (
          <time class="dt-updated hidden" datetime={post.data.updated.toISOString()}>{post.data.updated.toISOString()}</time>
        )}
        <span>•</span>
        <span><span id="reading-time-value">{post.data.readingTime || 5}</span> <T key="blog.minRead" /></span>
        {post.data.mood && (
          <>
            <span>•</span>
            <span><span data-i18n="blog.mood">Mood</span>: {post.data.mood}</span>
          </>
        )}
        {post.data.catApproved && (
          <>
            <span>•</span>
            <span title="Cat approved!">🐱 ✓</span>
          </>
        )}
      </div>

      {post.data.tags && post.data.tags.length > 0 && (
        <div class="flex gap-2 flex-wrap mt-4">
          {post.data.tags.map((tag: string) => (
            <span class="p-category text-xs px-2 py-1 rounded bg-muted text-muted-foreground">
              {tag}
            </span>
          ))}
        </div>
      )}

      <div class="mt-6">
        <ShareButtons title={post.data.title} url={`${postUrl}`} />
      </div>

      {post.data.alternates && post.data.alternates.length > 0 && (
        <div class="mt-4 p-3 rounded-lg bg-muted/50 border">
          <T key="blog.availableIn" class="text-sm text-muted-foreground" />
          <span class="text-sm text-muted-foreground"> </span>
          {post.data.alternates.map((alt: { slug: string; language: string }, i: number) => (
            <>
              <a
                href={`/blog/${alt.slug}/`}
                class="text-sm text-primary hover:underline"
              >
                {supportedLanguages.find(l => l.code === alt.language)?.name || alt.language.toUpperCase()}</a>{i < post.data.alternates!.length - 1 && <span class="text-muted-foreground">, </span>}
            </>
          ))}
        </div>
      )}
    </header>

    <div class="p-author h-card hidden" aria-hidden="true">
      <a class="p-name u-url" href={siteUrl}>{author.name}</a>
    </div>

    <div class="e-content prose prose-lg dark:prose-invert max-w-none blog-content">
      <Content />
    </div>

    <!-- Post navigation -->
    <nav class="mt-12 pt-8 border-t" aria-label="Post navigation">
      <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
        {prevPost && (
          <a
            href={`/blog/${prevPost.slug}/`}
            class="group p-4 border rounded-lg hover:border-primary/50 transition-colors"
          >
            <span class="text-xs text-muted-foreground">← </span>
            <T key="blog.prev" class="text-xs text-muted-foreground" />
            <p class="font-medium group-hover:text-primary transition-colors line-clamp-1">
              {prevPost.data.title}
            </p>
          </a>
        )}
        {nextPost && (
          <a
            href={`/blog/${nextPost.slug}/`}
            class="group p-4 border rounded-lg hover:border-primary/50 transition-colors md:text-right md:ml-auto"
          >
            <T key="blog.next" class="text-xs text-muted-foreground" />
            <span class="text-xs text-muted-foreground"> →</span>
            <p class="font-medium group-hover:text-primary transition-colors line-clamp-1">
              {nextPost.data.title}
            </p>
          </a>
        )}
      </div>
    </nav>

    <!-- Comments section (Cusdis) -->
    <section class="mt-12 pt-8 border-t">
      <h2 class="text-2xl font-bold mb-6"><T key="blog.comments" /></h2>
      <div
        id="cusdis_thread"
        class="[&_iframe]:min-h-[380px] [&_iframe]:w-full"
        data-host={services.cusdis.host}
        data-app-id={services.cusdis.appId}
        data-page-id={post.slug}
        data-page-url={`${postUrl}`}
        data-page-title={post.data.title}
        data-theme="dark"
      >
      </div>
    </section>
  </article>
</BaseLayout>

<script>
  import { setupPageI18n } from '@/lib/i18n-page';
  import { languageStore, t } from '@/i18n';
  import { services } from '@/lib/constants';

  // Declare CUSDIS on window
  declare global {
    interface Window {
      CUSDIS?: {
        initial: () => void;
      };
    }
  }

  function updateTranslations() {
    document.querySelectorAll('[data-i18n]').forEach((el) => {
      const key = el.getAttribute('data-i18n');
      if (key) {
        const translated = t(key);
        if (translated !== key) {
          el.textContent = translated;
        }
      }
    });

    // Update date with locale
    const lang = languageStore.get();
    document.querySelectorAll('time[data-date]').forEach((el) => {
      const dateStr = el.getAttribute('data-date');
      if (dateStr) {
        const date = new Date(dateStr);
        el.textContent = date.toLocaleDateString(lang, {
          year: 'numeric',
          month: 'long',
          day: 'numeric'
        });
      }
    });
  }

  setupPageI18n(updateTranslations);

  // Load Cusdis script
  const script = document.createElement('script');
  script.src = services.cusdis.scriptUrl;
  script.async = true;
  script.defer = true;
  document.body.appendChild(script);

  script.onload = () => {
    if (window.CUSDIS) {
      window.CUSDIS.initial();
    }
  };

  // Cusdis theme management
  const cusdisEl = document.getElementById('cusdis_thread');
  if (cusdisEl) {
    const updateCusdisTheme = () => {
      const isDark = document.documentElement.classList.contains('dark');
      // If site is in dark mode, use dark theme
      // If site is in light mode, use auto to let Cusdis follow system preference
      const cusdisTheme = isDark ? 'dark' : 'auto';
      cusdisEl.setAttribute('data-theme', cusdisTheme);
    };

    // Watch for theme changes
    const themeObserver = new MutationObserver(updateCusdisTheme);
    themeObserver.observe(document.documentElement, { attributes: true, attributeFilter: ['class'] });

    // Initial update
    updateCusdisTheme();
  }
</script>
