---
import RetroLayout from "@/layouts/RetroLayout.astro";
---

<RetroLayout title="About me - Jarema's retro site">
  <!-- Page title -->
  <center>
    <font size="5">
      <b>About me</b>
    </font>
    <hr style="width: 50%">
  </center>

  <!-- Profile section -->
  <table width="100%" border="0" cellpadding="10" cellspacing="0">
    <tr>
      <td style="width: 20%; vertical-align: top; text-align: center;">
        <!-- Profile image placeholder -->
        <table border="0" cellpadding="5" cellspacing="0" bgcolor="#F4F4F5" style="border: 3px ridge #4A3F6F;">
          <tr>
            <td align="center">
              <font size="6">🧑‍💻</font>
              <br>
              <font size="2"><i>That's me!</i></font>
            </td>
          </tr>
        </table>
      </td>
      <td style="width: 80%; vertical-align: top;">
        <font size="3">
          <p>
            <b>Hello!</b> I'm <font color="#54D4FF"><b>Jarema</b></font>,
            a student from somewhere on Earth.
          </p>
          <p>
            I enjoy tinkering with my stuff, and sometimes you'll find me
            maintaining this little corner of the internet that I call home.
          </p>
          <p>
            When I'm not coding, you might find me:
          </p>
          <ul>
            <li>Reading about technology</li>
            <li>Watching something on YouTube</li>
            <li>Listening to music</li>
            <li>Drinking too much tea and coffee</li>
          </ul>
        </font>
      </td>
    </tr>
  </table>

  <hr>

  <!-- Skills section -->
  <font size="4">
    <b>Technical</b>
  </font>

  <table width="100%" border="1" cellpadding="5" cellspacing="0">
    <tr style="background-color: #2A1F45;">
      <th align="left"><font size="2">Category</font></th>
      <th align="left"><font size="2">Technologies</font></th>
    </tr>
    <tr>
      <td><font size="2"><b>Languages</b></font></td>
      <td><font size="2">JavaScript, TypeScript, Python, HTML, CSS</font></td>
    </tr>
    <tr>
      <td><font size="2"><b>Frontend</b></font></td>
      <td><font size="2">React, Next.js, Astro, Tailwind CSS</font></td>
    </tr>
    <tr>
      <td><font size="2"><b>Backend</b></font></td>
      <td><font size="2">Node.js, Express, PostgreSQL, MongoDB</font></td>
    </tr>
    <tr>
      <td><font size="2"><b>Tools</b></font></td>
      <td><font size="2">Git, VS Code, Docker, Linux</font></td>
    </tr>
  </table>

  <hr>

  <!-- Philosophy section -->
  <font size="4">
    <b>Philosophy</b>
  </font>

  <blockquote style="border-left: 4px solid #4A3F6F; padding-left: 15px; margin-left: 10px;">
    <font size="3">
      <i>
        "The web should be accessible to everyone, regardless of their browser
        or device. That's why this site works even on browsers from 1993!"
      </i>
    </font>
  </blockquote>

  <p>
    <font size="3">
      I believe in:
    </font>
  </p>
  <ul>
    <li><font size="3">Progressive enhancement</font></li>
    <li><font size="3">Semantic HTML</font></li>
    <li><font size="3">Accessibility for all</font></li>
    <li><font size="3">The indie web and personal websites</font></li>
    <li><font size="3">Open source software</font></li>
  </ul>

  <hr>

  <!-- Contact CTA -->
  <center>
    <font size="3">
      Want to get in touch?
      <br>
      <a href="/retro/contact/">
        <b>Contact me!</b>
      </a>
    </font>
  </center>

  <br>

  <!-- Back link -->
  <center>
    <font size="2">
      <a href="/retro/">&lt;&lt; Back to homepage</a>
    </font>
  </center>
</RetroLayout>
