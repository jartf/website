---
// Uses Page - tech and tools I use with i18n support
import BaseLayout from "@/layouts/BaseLayout.astro";
import { USES_CATEGORIES } from "@/content/uses-items";
import { t } from "@/i18n";

// Category icons mapping
const categoryIcons: Record<string, string> = {
  hardware: "💻",
  mobile: "📱",
  audio: "🎧",
  os: "🖥️",
  development: "⌨️",
  email: "📧",
  privacy: "🔒",
  mobile_tools: "🔧",
  mapping: "🗺️",
  gaming: "🎮",
  multimedia: "🎨",
  design: "🎨",
  photo: "📷",
  video: "🎬",
  media: "🎵",
};
---

<BaseLayout title="Uses" description="The tools and tech I use daily.">
  <div class="container mx-auto px-4 py-8 lg:py-12">
    <div class="max-w-6xl mx-auto">
      <header class="mb-10 text-center">
        <h1 class="text-4xl md:text-5xl font-bold mb-4" data-i18n="uses.title">Uses</h1>
        <p class="text-muted-foreground text-lg max-w-xl mx-auto">
          <span data-i18n="uses.description">All the things I use on a daily basis. Also available on</span>
          {" "}
          <a href="https://uses.tech" target="_blank" rel="noopener noreferrer" class="text-primary hover:underline">uses.tech</a>,
          {" "}
          <span data-i18n="uses.websiteDescription">a website where people share the stuff they use.</span>
        </p>
      </header>

      <!-- Two-column layout -->
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-8 lg:gap-12">
        {USES_CATEGORIES.map((category) => (
          <section id={category.title} class="scroll-mt-20">
            <div class="flex items-center gap-3 mb-6">
              <span class="text-2xl" aria-hidden="true">
                {categoryIcons[category.title] || "📌"}
              </span>
              <h2 class="text-2xl font-bold category-title" data-i18n={`uses.categories.${category.title}`}>
                {category.title}
              </h2>
            </div>

            {/* Main items */}
            {category.items.length > 0 && (
              <div class="space-y-4 ml-4">
                {category.items.map((item) => (
                  <div class="flex items-start gap-3">
                    <div class="flex-shrink-0 mt-1.5 w-3 h-3 rounded-full bg-primary" />
                    <div class="flex-1">
                      {item.link ? (
                        <a href={item.link} target="_blank" rel="noopener noreferrer" class="text-lg font-medium hover:text-primary flex items-center">
                          {item.name}
                          <span class="text-xs ml-1 opacity-70">↗</span>
                        </a>
                      ) : (
                        <h3 class="text-lg font-medium">{item.name}</h3>
                      )}
                      <p class="text-muted-foreground item-description" data-i18n={`uses.itemDescriptions.${item.descriptionKey}`}>
                        {t(`uses.itemDescriptions.${item.descriptionKey}`)}
                      </p>
                    </div>
                  </div>
                ))}
              </div>
            )}

            {/* Subsections */}
            {category.subsections && category.subsections.map((subsection) => (
              <div class="mt-6">
                <div class="flex items-center gap-2 mb-4">
                  <span class="text-lg" aria-hidden="true">
                    {categoryIcons[subsection.title] || "📌"}
                  </span>
                  <h3 class="text-xl font-medium subsection-title" data-i18n={`uses.subsections.${subsection.title}`}>
                    {subsection.title}
                  </h3>
                </div>
                <div class="space-y-4 ml-4">
                  {subsection.items.map((item) => (
                    item.name.startsWith('Unspeakable') ? (
                      <div
                        class="flex items-start gap-3 cursor-pointer group hidden-platform"
                        data-platform={item.name === 'Unspeakable Platform 1' ? 'revanced' : 'stremio'}
                        data-clicks="0"
                      >
                        <div class="flex-shrink-0 mt-1.5 w-3 h-3 rounded-full bg-primary" />
                        <div class="flex-1">
                          <h4 class="text-lg font-medium flex items-center gap-2">
                            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="platform-lock">
                              <rect width="18" height="11" x="3" y="11" rx="2" ry="2"/>
                              <path d="M7 11V7a5 5 0 0 1 10 0v4"/>
                            </svg>
                            <span class="platform-name">{item.name === 'Unspeakable Platform 1' ? 'Hidden Platform 1' : 'Hidden Platform 2'}</span>
                            <span class="text-xs text-muted-foreground platform-counter">(5 clicks to reveal)</span>
                          </h4>
                          <p class="text-muted-foreground platform-description">Click 5 times to reveal</p>
                        </div>
                      </div>
                    ) : (
                      <div class="flex items-start gap-3">
                        <div class="flex-shrink-0 mt-1.5 w-3 h-3 rounded-full bg-primary" />
                        <div class="flex-1">
                          {item.link ? (
                            <a href={item.link} target="_blank" rel="noopener noreferrer" class="text-lg font-medium hover:text-primary flex items-center">
                              {item.name}
                              <span class="text-xs ml-1 opacity-70">↗</span>
                            </a>
                          ) : (
                            <h4 class="text-lg font-medium">{item.name}</h4>
                          )}
                          {item.descriptionKey ? (
                            <p class="text-muted-foreground item-description" data-i18n={`uses.itemDescriptions.${item.descriptionKey}`}>
                              {t(`uses.itemDescriptions.${item.descriptionKey}`)}
                            </p>
                          ) : item.description && (
                            <p class="text-muted-foreground">{item.description}</p>
                          )}
                        </div>
                      </div>
                    )
                  ))}
                </div>
              </div>
            ))}
          </section>
        ))}
      </div>
    </div>
  </div>
</BaseLayout>

<script>
  import { languageStore, t, initLanguage } from '@/i18n';

  function updateTranslations() {
    // Update all data-i18n elements (includes categories, subsections, descriptions)
    document.querySelectorAll('[data-i18n]').forEach((el) => {
      const key = el.getAttribute('data-i18n');
      if (key) {
        const translated = t(key);
        if (translated !== key) {
          el.textContent = translated;
        }
      }
    });

    // Update item descriptions using uses.itemDescriptions from JSON
    document.querySelectorAll('.item-description').forEach((el) => {
      const key = el.getAttribute('data-description-key');
      if (key) {
        const translated = t(`uses.itemDescriptions.${key}`);
        if (translated !== `uses.itemDescriptions.${key}`) {
          el.textContent = translated;
        }
      }
    });
  }

  initLanguage();
  updateTranslations();

  languageStore.subscribe(() => {
    updateTranslations();
  });

  window.addEventListener('languageChange', () => {
    updateTranslations();
  });

  // Hidden platform reveal functionality
  const platformData: Record<string, { name: string; description: string; link: string }> = {
    revanced: {
      name: 'ReVanced',
      description: 'A patcher for YouTube that removes ads and adds features',
      link: 'https://revanced.app/'
    },
    stremio: {
      name: 'Stremio',
      description: 'A media center for streaming movies and TV shows',
      link: 'https://www.stremio.com/'
    }
  };

  document.querySelectorAll('.hidden-platform').forEach((el) => {
    const platform = el.getAttribute('data-platform');
    if (!platform) return;

    el.addEventListener('click', () => {
      let clicks = parseInt(el.getAttribute('data-clicks') || '0');
      clicks++;
      el.setAttribute('data-clicks', String(clicks));

      const counter = el.querySelector('.platform-counter');
      const remaining = 5 - clicks;

      if (remaining > 0 && counter) {
        counter.textContent = `(${remaining} click${remaining === 1 ? '' : 's'} to reveal)`;
      }

      if (clicks >= 5) {
        const data = platformData[platform];
        if (data) {
          const nameEl = el.querySelector('.platform-name');
          const descEl = el.querySelector('.platform-description');
          const lockEl = el.querySelector('.platform-lock');

          if (nameEl) {
            nameEl.innerHTML = `<a href="${data.link}" target="_blank" rel="noopener noreferrer" class="hover:text-primary">${data.name} <span class="text-xs opacity-70">↗</span></a>`;
          }
          if (descEl) {
            descEl.textContent = data.description;
          }
          if (counter) {
            counter.remove();
          }
          if (lockEl) {
            // Replace lock with unlock icon
            lockEl.outerHTML = `<svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-green-500">
              <rect width="18" height="11" x="3" y="11" rx="2" ry="2"/>
              <path d="M7 11V7a5 5 0 0 1 9.9-1"/>
            </svg>`;
          }

          el.classList.remove('cursor-pointer');
        }
      }
    });
  });
</script>
