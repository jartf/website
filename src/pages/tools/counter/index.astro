---
import BaseLayout from "@/layouts/BaseLayout.astro";
import T from "@/components/T.astro";
import { t } from "@/i18n";

const lang = Astro.locals?.lang || "en";
const tl = (key: string) => t(lang, `textCounter.${key}`);

const textLangs = ["en", "vi", "et", "zh", "ru", "custom", "advanced"] as const;
const stats = ["characters", "charactersNoSpaces", "words", "sentences", "paragraphs", "lines", "readingTime", "speakingTime"] as const;
const speedPresets = ["slow", "average", "fast", "custom"] as const;

const speeds: Record<string, { speaking: number[]; reading: number[] }> = {
  en: { speaking: [115, 145, 175], reading: [175, 225, 275] },
  vi: { speaking: [120, 160, 190], reading: [185, 245, 290] },
  et: { speaking: [115, 145, 175], reading: [160, 200, 240] },
  ru: { speaking: [95, 125, 155], reading: [150, 210, 270] },
  zh: { speaking: [120, 160, 200], reading: [200, 265, 330] },
};
const controlCls = "mt-1 w-full px-3 py-1.5 text-sm rounded-lg border bg-card text-foreground focus:outline-none focus:ring-2 focus:ring-ring";
---

<BaseLayout title={tl("title")}>
  <div class="container mx-auto px-4 py-8">
    <div class="max-w-4xl mx-auto">
      <header class="text-center mb-8">
        <T key="textCounter.title" tag="h1" class="text-4xl font-bold mb-4" />
        <T key="textCounter.description" tag="p" class="text-lg text-muted-foreground max-w-2xl mx-auto" />
      </header>

      <div class="flex flex-col md:flex-row md:items-end gap-4 mb-4">
        <div class="shrink-0">
          <label for="text-lang" class="text-sm font-medium"><T key="textCounter.textLanguage" /></label>
          <select id="text-lang" class:list={[controlCls, "block"]}>
            {textLangs.map((code) => <option value={code}>{tl(`languages.${code}`)}</option>)}
          </select>
        </div>

        <fieldset class="shrink-0">
          <T key="textCounter.speed.label" tag="legend" class="text-sm font-medium mb-1" />
          <div class="flex flex-wrap gap-2" role="group" aria-label={tl("speed.label")}>
            {speedPresets.map((s) => (
              <button type="button" aria-pressed={s === "average" ? "true" : "false"} data-speed={s}
                class:list={["speed-btn px-3 py-1.5 text-sm rounded-full border transition-colors", s === "average" && "bg-primary text-primary-foreground border-primary"]}>
                <T key={`textCounter.speed.${s}`} />
              </button>
            ))}
          </div>
        </fieldset>

        <div class="flex gap-3 grow">
          <label class="text-xs text-muted-foreground grow">
            <T key="textCounter.speed.readingWpm" />
            <input id="wpm-read" type="number" min="1" max="9999" value="225" readonly class:list={[controlCls, "tabular-nums read-only:opacity-60"]} />
          </label>
          <label class="text-xs text-muted-foreground grow">
            <T key="textCounter.speed.speakingWpm" />
            <input id="wpm-speak" type="number" min="1" max="9999" value="145" readonly class:list={[controlCls, "tabular-nums read-only:opacity-60"]} />
          </label>
        </div>
      </div>

      <T key="textCounter.speed.englishDefaultsWarning" tag="p" id="speed-warn" class="text-xs text-yellow-600 dark:text-yellow-400 -mt-2 mb-4 hidden" role="alert" />

      <fieldset class="mb-6 hidden" id="advanced-section">
        <T key="textCounter.advanced.title" tag="legend" class="text-sm font-medium mb-2" />
        <div class="space-y-3">
          <label class="flex items-start gap-3 cursor-pointer">
            <input type="checkbox" id="toggle-no-words" class="mt-1 accent-primary" role="switch" />
            <span>
              <T key="textCounter.advanced.disableWords" class="text-sm font-medium" />
              <T key="textCounter.advanced.disableWordsDesc" class="block text-xs text-muted-foreground" />
            </span>
          </label>
          <label class="flex items-start gap-3 cursor-pointer">
            <input type="checkbox" id="toggle-line-para" class="mt-1 accent-primary" role="switch" />
            <span>
              <T key="textCounter.advanced.newlineAsParagraph" class="text-sm font-medium" />
              <T key="textCounter.advanced.newlineAsParagraphDesc" class="block text-xs text-muted-foreground" />
            </span>
          </label>
        </div>
      </fieldset>

      <div class="grid grid-cols-2 sm:grid-cols-4 gap-3 mb-6" role="status" aria-live="polite" aria-atomic="true">
        {stats.map((key) => (
          <div class="bg-card border rounded-lg p-4 text-center" data-card={key}>
            <div class="text-2xl font-bold tabular-nums" data-stat={key}>{key.includes("Time") ? "0s" : "0"}</div>
            <T key={`textCounter.stats.${key}`} tag="div" class="text-xs text-muted-foreground mt-1" />
          </div>
        ))}
      </div>

      <div class="relative">
        <textarea id="text-input" placeholder={tl("placeholder")} autofocus aria-label={tl("description")}
          class="w-full min-h-[300px] md:min-h-[400px] p-4 rounded-lg border bg-card text-foreground placeholder:text-muted-foreground focus:outline-none focus:ring-2 focus:ring-ring resize-y font-monaspice text-sm leading-relaxed" />
        <button id="clear-btn" type="button" aria-label={tl("clear")} class="absolute top-3 right-3 text-xs px-2 py-1 rounded bg-muted text-muted-foreground hover:bg-muted/80 transition-colors hidden">
          <T key="textCounter.clear" />
        </button>
      </div>

      <div id="speed-data" hidden data-v={JSON.stringify(speeds)} />

      <details class="mt-8 text-sm border rounded-lg px-4 py-2 text-muted-foreground">
        <T key="textCounter.privacy.summary" tag="summary" class="cursor-pointer select-none font-medium text-foreground py-1" />
        <div class="mt-2 mb-1 space-y-2">
          <T key="textCounter.privacy.body" tag="p" />
          <p><T key="textCounter.privacy.technicalLabel" class="font-medium text-foreground" /> <T key="textCounter.privacy.technical" /></p>
        </div>
      </details>
    </div>
  </div>
</BaseLayout>

<script>
  type Speeds = Record<string, { speaking: number[]; reading: number[] }>;
  const speeds: Speeds = JSON.parse(document.getElementById("speed-data")!.dataset.v!);
  const presetIdx: Record<string, number> = { slow: 0, average: 1, fast: 2 };
  const sentRe = /[.!?…。！？⋯]+(?:\s|$)/g;

  // State
  let textLang = "en";
  let speedPreset = "average";
  let noWords = false;
  let linePara = false;

  // DOM refs
  const $ = <T extends HTMLElement>(id: string) => document.getElementById(id) as T;
  const textarea = $<HTMLTextAreaElement>("text-input");
  const clearBtn = $<HTMLButtonElement>("clear-btn");
  const langSelect = $<HTMLSelectElement>("text-lang");
  const advancedEl = $("advanced-section");
  const wpmRead = $<HTMLInputElement>("wpm-read");
  const wpmSpeak = $<HTMLInputElement>("wpm-speak");
  const warnEl = $("speed-warn");
  const toggleNoWords = $<HTMLInputElement>("toggle-no-words");
  const toggleLinePara = $<HTMLInputElement>("toggle-line-para");
  const speedBtns = document.querySelectorAll<HTMLButtonElement>(".speed-btn");
  const statEls = new Map(Array.from(document.querySelectorAll<HTMLElement>("[data-stat]"), (el) => [el.dataset.stat!, el]));
  const cardEls = new Map(Array.from(document.querySelectorAll<HTMLElement>("[data-card]"), (el) => [el.dataset.card!, el]));

  function getWpm(): [number, number] {
    const s = speeds[textLang] ?? speeds.en;
    const i = presetIdx[speedPreset];
    return i != null ? [s.reading[i], s.speaking[i]] : [+wpmRead.value || 225, +wpmSpeak.value || 140];
  }

  function syncWpm() {
    const [r, s] = getWpm();
    const isCustom = speedPreset === "custom";
    wpmRead.readOnly = wpmSpeak.readOnly = !isCustom;
    if (!isCustom) { wpmRead.value = String(r); wpmSpeak.value = String(s); }
    const hasNoData = textLang === "custom" || textLang === "advanced";
    warnEl.classList.toggle("hidden", !(hasNoData && !isCustom));
  }

  function fmtTime(units: number, wpm: number): string {
    if (!units || !wpm) return "0s";
    const sec = Math.ceil((units / wpm) * 60);
    const min = (sec / 60) | 0;
    return min ? `${min}m ${sec % 60}s` : `${sec % 60}s`;
  }

  function update() {
    syncWpm();
    const v = textarea.value;
    const trimmed = v.trim();
    const hideWords = noWords || textLang === "zh";
    const charsNoSpace = v.replace(/[\s\u3000]/g, "").length;
    const words = hideWords ? 0 : trimmed ? trimmed.split(/\s+/).length : 0;
    const sentences = trimmed ? (v.match(sentRe)?.length ?? 1) : 0;
    const paragraphs = trimmed
      ? linePara
        ? v.split("\n").filter(Boolean).length
        : v.split(/\n\s*\n/).filter((p) => p.trim()).length || 1
      : 0;
    const lines = v ? v.split("\n").length : 0;
    const [r, s] = getWpm();
    const timeUnits = textLang === "zh" ? charsNoSpace : words;

    const data: Record<string, string> = {
      characters: String(v.length),
      charactersNoSpaces: String(charsNoSpace),
      words: String(words),
      sentences: String(sentences),
      paragraphs: String(paragraphs),
      lines: String(lines),
      readingTime: fmtTime(timeUnits, r),
      speakingTime: fmtTime(timeUnits, s),
    };
    for (const [k, el] of statEls) el.textContent = data[k] ?? "";
    cardEls.get("words")?.classList.toggle("hidden", hideWords);
    cardEls.get("lines")?.classList.toggle("hidden", linePara);
    clearBtn.classList.toggle("hidden", !v.length);
  }

  function setActiveSpeed(preset: string) {
    speedPreset = preset;
    for (const b of speedBtns) {
      const on = b.dataset.speed === preset;
      b.classList.toggle("bg-primary", on);
      b.classList.toggle("text-primary-foreground", on);
      b.classList.toggle("border-primary", on);
      b.setAttribute("aria-pressed", String(on));
    }
    update();
  }

  for (const btn of speedBtns) {
    btn.addEventListener("click", () => setActiveSpeed(btn.dataset.speed!));
  }

  langSelect.addEventListener("change", () => {
    const prev = textLang;
    textLang = langSelect.value;
    advancedEl.classList.toggle("hidden", textLang !== "advanced");
    if (prev === "zh" && textLang !== "zh" && textLang !== "advanced") {
      noWords = false;
      toggleNoWords.checked = false;
    }
    if (textLang === "zh") {
      noWords = true;
      toggleNoWords.checked = true;
    }
    update();
  });

  toggleNoWords.addEventListener("change", () => { noWords = toggleNoWords.checked; update(); });
  toggleLinePara.addEventListener("change", () => { linePara = toggleLinePara.checked; update(); });
  wpmRead.addEventListener("input", update);
  wpmSpeak.addEventListener("input", update);
  textarea.addEventListener("input", update);
  clearBtn.addEventListener("click", () => { textarea.value = ""; update(); textarea.focus(); });

  syncWpm();
</script>
