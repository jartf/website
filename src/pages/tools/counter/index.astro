---
import BaseLayout from "@/layouts/BaseLayout.astro";
import T from "@/components/T.astro";
import { t } from "@/i18n";

const lang = Astro.locals?.lang || "en";
const stats = [
  "characters", "charactersNoSpaces", "words", "sentences",
  "paragraphs", "lines", "readingTime", "speakingTime",
] as const;
---

<BaseLayout title={t(lang, "textCounter.title")}>
  <div class="container mx-auto px-4 py-8">
    <div class="max-w-4xl mx-auto">
      <header class="text-center mb-8">
        <T key="textCounter.title" tag="h1" class="text-4xl font-bold mb-4" />
        <T key="textCounter.description" tag="p" class="text-lg text-muted-foreground max-w-2xl mx-auto" />
      </header>

      <div class="grid grid-cols-2 sm:grid-cols-4 gap-3 mb-6" role="status" aria-live="polite" aria-atomic="true">
        {stats.map((key) => (
          <div class="bg-card border rounded-lg p-4 text-center">
            <div class="text-2xl font-bold tabular-nums" data-stat={key}>
              {key.includes("Time") ? "0s" : "0"}
            </div>
            <div class="text-xs text-muted-foreground mt-1">
              {t(lang, `textCounter.stats.${key}`)}
            </div>
          </div>
        ))}
      </div>

      <div class="relative">
        <textarea
          id="text-input"
          placeholder={t(lang, "textCounter.placeholder")}
          class="w-full min-h-[300px] md:min-h-[400px] p-4 rounded-lg border bg-card text-foreground placeholder:text-muted-foreground focus:outline-none focus:ring-2 focus:ring-ring resize-y font-mono text-sm leading-relaxed"
          autofocus
          aria-label={t(lang, "textCounter.description")}
        />
        <button
          id="clear-btn"
          class="absolute top-3 right-3 text-xs px-2 py-1 rounded bg-muted text-muted-foreground hover:bg-muted/80 transition-colors hidden"
          type="button"
        >
          {t(lang, "textCounter.clear")}
        </button>
      </div>
    </div>
  </div>
</BaseLayout>

<script>
  const textarea = document.getElementById("text-input") as HTMLTextAreaElement;
  const clearBtn = document.getElementById("clear-btn") as HTMLButtonElement;
  const statMap = new Map(
    Array.from(document.querySelectorAll<HTMLElement>("[data-stat]"), (el) => [
      el.dataset.stat!,
      el,
    ])
  );

  function fmtTime(words: number, wpm: number) {
    const s = Math.ceil((words / wpm) * 60);
    const m = (s / 60) | 0;
    return m ? `${m}m ${s % 60}s` : `${s % 60}s`;
  }

  function update() {
    const v = textarea.value;
    const trimmed = v.trim();
    const words = trimmed ? trimmed.split(/\s+/).length : 0;

    const data: Record<string, string> = {
      characters: String(v.length),
      charactersNoSpaces: String(v.replace(/\s/g, "").length),
      words: String(words),
      sentences: String(trimmed ? (v.match(/[.!?…]+(?:\s|$)/g)?.length || 1) : 0),
      paragraphs: String(trimmed ? (v.split(/\n\s*\n/).filter((p) => p.trim()).length || 1) : 0),
      lines: String(v ? v.split("\n").length : 0),
      readingTime: fmtTime(words, 225),
      speakingTime: fmtTime(words, 140),
    };

    for (const [key, el] of statMap) el.textContent = data[key];
    clearBtn.classList.toggle("hidden", !v.length);
  }

  textarea.addEventListener("input", update);
  clearBtn.addEventListener("click", () => {
    textarea.value = "";
    update();
    textarea.focus();
  });
</script>
