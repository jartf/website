---
// Colophon page
import BaseLayout from "@/layouts/BaseLayout.astro";
import T from "@/components/T.astro";
---

<BaseLayout title="Colophon" description="Technical details and credits for this website.">
  <div class="container mx-auto px-4 py-8 lg:py-12">
    <div class="max-w-2xl mx-auto">
      <header class="mb-8 text-center">
        <T key="colophon.title" tag="h1" class="text-4xl font-bold mb-4" />
        <T key="colophon.description" tag="p" class="text-lg text-muted-foreground" />
      </header>

      <div class="prose text-md dark:prose-invert max-w-none space-y-8 text-justify">
        <!-- Site history -->
        <section id="site-history" class="scroll-mt-20">
          <T key="colophon.siteHistory.title" tag="h2" />
          <T key="colophon.siteHistory.content1" tag="p" />
          <T key="colophon.siteHistory.content2" tag="p" />
        </section>

        <!-- Technology stack -->
        <section id="technology-stack" class="scroll-mt-20">
          <T key="colophon.technologyStack.title" tag="h2" />
          <ul>
            <li><strong>Astro:</strong> <span data-i18n="colophon.technologyStack.astro">Static site generator with island architecture</span></li>
            <li><strong>Tailwind CSS:</strong> <span data-i18n="colophon.technologyStack.tailwind">Utility-first CSS framework</span></li>
            <li><strong>TypeScript:</strong> <span data-i18n="colophon.technologyStack.typescript">Strongly typed programming language that builds on JavaScript</span></li>
            <li><strong>nanostores:</strong> Lightweight state management for i18n</li>
            <li><strong>Typography:</strong> Space Grotesk (headings), Lexend (body)</li>
          </ul>
        </section>

        <!-- Hosting & deployment -->
        <section id="hosting" class="scroll-mt-20">
          <T key="colophon.hosting.title" tag="h2" />
          <p>
            <span data-i18n="colophon.hosting.content1">The site is hosted on</span>{" "}
            <a href="https://vercel.com" target="_blank" rel="noopener noreferrer">Vercel</a>,{" "}
            <span data-i18n="colophon.hosting.content2">which provides seamless deployment from GitHub, automatic HTTPS, and global CDN distribution.</span>
          </p>
          <p>
            <span data-i18n="colophon.hosting.content3">The domain is managed through</span>{" "}
            <a href="https://cloudflare.com" target="_blank" rel="noopener noreferrer">Cloudflare</a>,{" "}
            <span data-i18n="colophon.hosting.content4">which provides additional security and performance benefits.</span>
          </p>
        </section>

        <!-- Design philosophy -->
        <section id="design-philosophy" class="scroll-mt-20">
          <T key="colophon.design.title" tag="h2" />
          <T key="colophon.design.p1" tag="p" />
          <T key="colophon.design.p2" tag="p" />
        </section>

        <!-- Web standards -->
        <section id="web-standards" class="scroll-mt-20">
          <T key="colophon.webStandards.title" tag="h2" />
          <T key="colophon.webStandards.intro" tag="p" />
          <ul>
            <li>
              <a href="https://microformats.org/wiki/h-card" target="_blank" rel="noopener noreferrer">h-card</a>
              and
              <a href="https://microformats.org/wiki/h-entry" target="_blank" rel="noopener noreferrer">h-entry</a>
              <span data-i18n="colophon.webStandards.microformats">microformats</span>
            </li>
            <li data-i18n="colophon.webStandards.feeds">RSS, Atom, and JSON feeds</li>
            <li data-i18n="colophon.webStandards.robots">robots.txt and sitemap.xml</li>
            <li data-i18n="colophon.webStandards.humans">humans.txt</li>
          </ul>
        </section>

        <!-- Accessibility -->
        <section id="accessibility" class="scroll-mt-20">
          <T key="colophon.accessibility.title" tag="h2" />
          <T key="colophon.accessibility.intro" tag="p" />
          <ul>
            <li data-i18n="colophon.accessibility.item1">Semantic HTML structure</li>
            <li data-i18n="colophon.accessibility.item2">Skip-to-content links</li>
            <li data-i18n="colophon.accessibility.item3">Proper heading hierarchy</li>
            <li data-i18n="colophon.accessibility.item4">WCAG 2.1 AA color contrast</li>
            <li data-i18n="colophon.accessibility.item5">Keyboard navigable</li>
            <li data-i18n="colophon.accessibility.item6">Respects reduced motion preferences</li>
          </ul>
          <p>
            <span data-i18n="colophon.accessibility.reportText">If you encounter any accessibility issues, please</span>
            <a href="/contact/" data-i18n="colophon.accessibility.contactLink">let me know</a>.
          </p>
        </section>

        <!-- Inspiration -->
        <section id="inspiration" class="scroll-mt-20">
          <T key="colophon.inspiration.title" tag="h2" />
          <p>
            <span data-i18n="colophon.inspiration.content1">This page draws inspiration from</span>{" "}
            <a href="https://maggieappleton.com/colophon" target="_blank" rel="noopener noreferrer">Maggie Appleton's colophon</a>,{" "}
            <span data-i18n="colophon.inspiration.content2">which in turn draws inspiration from</span>{" "}
            <a href="https://www.gwern.net/Colophon" target="_blank" rel="noopener noreferrer">Gwern Branwen's colophon</a>.
          </p>
        </section>
      </div>
    </div>
  </div>
</BaseLayout>

<script>
  import { languageStore, t, initLanguage } from '@/i18n';

  // Only update inline spans with data-i18n (for complex mixed content)
  function updateInlineTranslations() {
    document.querySelectorAll('[data-i18n]').forEach((el) => {
      const key = el.getAttribute('data-i18n');
      if (key) {
        const translated = t(key);
        if (translated !== key) {
          el.textContent = translated;
        }
      }
    });
  }

  initLanguage();
  updateInlineTranslations();

  languageStore.subscribe(() => {
    updateInlineTranslations();
  });

  window.addEventListener('languageChange', () => {
    updateInlineTranslations();
  });
</script>
