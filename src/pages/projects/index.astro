---
import BaseLayout from "@/layouts/BaseLayout.astro";
import T from "@/components/T.astro";
import { projects } from "@/content/project-items";

const visibleProjects = projects.filter(p => !p.hidden);

const statusGroups = [
  { key: 'in-progress', indicator: 'bg-yellow-500 motion-safe:animate-pulse', projects: visibleProjects.filter(p => p.status === 'in-progress') },
  { key: 'completed', indicator: 'bg-green-500', projects: visibleProjects.filter(p => p.status === 'completed') },
  { key: 'planned', indicator: 'bg-blue-500', projects: visibleProjects.filter(p => p.status === 'planned') },
];

const statusColors = {
  'completed': 'bg-green-500/20 text-green-700 dark:text-green-300',
  'in-progress': 'bg-yellow-500/20 text-yellow-700 dark:text-yellow-300',
  'planned': 'bg-blue-500/20 text-blue-700 dark:text-blue-300',
};

const categoryIcons: Record<string, string> = { 'personal': '🧑‍💻', 'academic': '📚', 'activism': '✊' };
const categories = Object.keys(categoryIcons);
---

<BaseLayout title="Projects" description="A collection of my projects and experiments.">
  <div class="container mx-auto px-4 py-8 lg:py-12">
    <div class="max-w-4xl mx-auto">
      <header class="mb-10 text-center">
        <T key="projects.title" tag="h1" class="text-4xl md:text-5xl font-bold mb-4" />
        <T key="projects.description" tag="p" class="text-muted-foreground text-lg max-w-xl mx-auto" />
      </header>

      <div class="flex flex-wrap justify-center gap-2 mb-8">
        <button class="filter-btn active px-4 py-2 rounded-full border transition-colors" data-filter="all">
          <T key="projects.filters.all" />
        </button>
        {categories.map(cat => (
          <button class="filter-btn px-4 py-2 rounded-full border transition-colors" data-filter={cat}>
            {categoryIcons[cat]} <T key={`projects.filters.${cat}`} />
          </button>
        ))}
      </div>

      {statusGroups.map(({ key, indicator, projects: groupProjects }) => groupProjects.length > 0 && (
        <section class="mb-12">
          <h2 class="text-2xl font-semibold mb-6 flex items-center gap-2">
            <span class={`w-3 h-3 rounded-full ${indicator}`}></span>
            <T key={`projects.${key.replace('-', '')}`} />
          </h2>
          <div class="grid gap-6 md:grid-cols-2">
            {groupProjects.map((project) => (
              <article class="project-card group perspective" data-category={project.category} data-project-id={project.id} data-project-content={JSON.stringify(project.content)}>
                <div class="card-inner relative w-full h-64 transition-transform duration-500 transform-style-preserve-3d">
                  <div class="card-front absolute inset-0 backface-hidden rounded-xl border bg-card p-6 flex flex-col">
                    <div class="flex items-start justify-between mb-3">
                      <span class="text-2xl">{categoryIcons[project.category]}</span>
                      <span class={`text-xs px-2 py-1 rounded-full ${statusColors[project.status]}`}>
                        <span data-i18n={`projects.status.${project.status}`}>{project.status}</span>
                      </span>
                    </div>
                    <h3 class="text-xl font-bold mb-2 project-title">{project.content.en.title}</h3>
                    <p class="text-muted-foreground text-sm flex-1 project-description">{project.content.en.description}</p>
                    <div class="flex flex-wrap gap-1 mt-3">
                      {project.tags.slice(0, 4).map((tag) => <span class="text-xs px-2 py-0.5 rounded bg-muted">{tag}</span>)}
                    </div>
                    <T key="projects.clickToFlip" tag="p" class="text-xs text-muted-foreground mt-3 opacity-0 group-hover:opacity-100 transition-opacity" />
                  </div>
                  <div class="card-back absolute inset-0 backface-hidden rounded-xl border bg-card p-6 flex flex-col rotate-y-180">
                    <T key="projects.what" tag="h4" class="font-semibold text-sm text-muted-foreground mb-2" />
                    <p class="text-sm mb-3 project-what">{project.content.en.what}</p>
                    <T key="projects.learned" tag="h4" class="font-semibold text-sm text-muted-foreground mb-2" />
                    <p class="text-sm mb-3 project-learned">{project.content.en.learned}</p>
                    <T key="projects.why" tag="h4" class="font-semibold text-sm text-muted-foreground mb-2" />
                    <p class="text-sm flex-1 project-why">{project.content.en.why}</p>
                  </div>
                </div>
              </article>
            ))}
          </div>
        </section>
      ))}
    </div>
  </div>
</BaseLayout>

<style>
  .perspective {
    perspective: 1000px;
  }

  .transform-style-preserve-3d {
    transform-style: preserve-3d;
  }

  .backface-hidden {
    backface-visibility: hidden;
    -webkit-backface-visibility: hidden;
  }

  .rotate-y-180 {
    transform: rotateY(180deg);
  }

  .card-inner.flipped {
    transform: rotateY(180deg);
  }

  .project-card {
    cursor: pointer;
  }

  .project-card.hidden {
    display: none;
  }

  .filter-btn {
    opacity: 0.6;
  }

  .filter-btn.active {
    opacity: 1;
    background-color: hsl(var(--primary) / 0.1);
    border-color: hsl(var(--primary));
  }
</style>

<script>
  import { setupPageI18n } from '@/lib/i18n-page';
  import { languageStore } from '@/i18n';

  const cards = document.querySelectorAll('.project-card');
  const filterBtns = document.querySelectorAll('.filter-btn');

  // Flip cards on click
  cards.forEach(card => card.addEventListener('click', () =>
    card.querySelector('.card-inner')?.classList.toggle('flipped')
  ));

  // Filter by category
  filterBtns.forEach(btn => btn.addEventListener('click', () => {
    const filter = btn.getAttribute('data-filter');
    filterBtns.forEach(b => b.classList.remove('active'));
    btn.classList.add('active');
    cards.forEach(card => card.classList.toggle('hidden',
      filter !== 'all' && card.getAttribute('data-category') !== filter
    ));
  }));

  // Update content on language change
  const updateContent = () => {
    const lang = languageStore.get();
    cards.forEach(card => {
      try {
        const content = JSON.parse(card.getAttribute('data-project-content') || '{}');
        const langContent = content[lang] || content.en;
        const update = (sel: string, key: string) => {
          const el = card.querySelector(sel);
          if (el && langContent[key]) el.textContent = langContent[key];
        };
        update('.project-title', 'title');
        update('.project-description', 'description');
        update('.project-what', 'what');
        update('.project-learned', 'learned');
        update('.project-why', 'why');
      } catch {}
    });
  };

  setupPageI18n(updateContent);
</script>
