---
// Projects Page with i18n and flip cards
import BaseLayout from "@/layouts/BaseLayout.astro";
import { projects } from "@/content/project-items";

// Filter out hidden projects
const visibleProjects = projects.filter(p => !p.hidden);

// Group projects by status
const completedProjects = visibleProjects.filter(p => p.status === 'completed');
const inProgressProjects = visibleProjects.filter(p => p.status === 'in-progress');
const plannedProjects = visibleProjects.filter(p => p.status === 'planned');

// Status badge colors
const statusColors = {
  'completed': 'bg-green-500/20 text-green-700 dark:text-green-300',
  'in-progress': 'bg-yellow-500/20 text-yellow-700 dark:text-yellow-300',
  'planned': 'bg-blue-500/20 text-blue-700 dark:text-blue-300',
};

// Category icons
const categoryIcons = {
  'personal': '🧑‍💻',
  'academic': '📚',
  'activism': '✊',
};
---

<BaseLayout title="Projects" description="A collection of my projects and experiments.">
  <div class="container mx-auto px-4 py-8 lg:py-12">
    <div class="max-w-4xl mx-auto">
      <header class="mb-10 text-center">
        <h1 class="text-4xl md:text-5xl font-bold mb-4" data-i18n="projects.title">Projects</h1>
        <p class="text-muted-foreground text-lg max-w-xl mx-auto" data-i18n="projects.description">
          Things I've built, researched, and contributed to.
        </p>
      </header>

      <!-- Category filters -->
      <div class="flex flex-wrap justify-center gap-2 mb-8">
        <button class="filter-btn active px-4 py-2 rounded-full border transition-colors" data-filter="all">
          <span data-i18n="projects.filters.all">All</span>
        </button>
        <button class="filter-btn px-4 py-2 rounded-full border transition-colors" data-filter="personal">
          🧑‍💻 <span data-i18n="projects.filters.personal">Personal</span>
        </button>
        <button class="filter-btn px-4 py-2 rounded-full border transition-colors" data-filter="academic">
          📚 <span data-i18n="projects.filters.academic">Academic</span>
        </button>
        <button class="filter-btn px-4 py-2 rounded-full border transition-colors" data-filter="activism">
          ✊ <span data-i18n="projects.filters.activism">Activism</span>
        </button>
      </div>

      <!-- In Progress Section -->
      {inProgressProjects.length > 0 && (
        <section class="mb-12">
          <h2 class="text-2xl font-semibold mb-6 flex items-center gap-2">
            <span class="w-3 h-3 rounded-full bg-yellow-500 animate-pulse"></span>
            <span data-i18n="projects.inProgress">In Progress</span>
          </h2>
          <div class="grid gap-6 md:grid-cols-2">
            {inProgressProjects.map((project) => (
              <article
                class="project-card group perspective"
                data-category={project.category}
                data-project-id={project.id}
                data-project-content={JSON.stringify(project.content)}
              >
                <div class="card-inner relative w-full h-64 transition-transform duration-500 transform-style-preserve-3d">
                  <!-- Front of card -->
                  <div class="card-front absolute inset-0 backface-hidden rounded-xl border bg-card p-6 flex flex-col">
                    <div class="flex items-start justify-between mb-3">
                      <span class="text-2xl">{categoryIcons[project.category]}</span>
                      <span class={`text-xs px-2 py-1 rounded-full ${statusColors[project.status]}`}>
                        <span data-i18n={`projects.status.${project.status}`}>{project.status}</span>
                      </span>
                    </div>
                    <h3 class="text-xl font-bold mb-2 project-title">{project.content.en.title}</h3>
                    <p class="text-muted-foreground text-sm flex-1 project-description">{project.content.en.description}</p>
                    <div class="flex flex-wrap gap-1 mt-3">
                      {project.tags.slice(0, 4).map((tag) => (
                        <span class="text-xs px-2 py-0.5 rounded bg-muted">{tag}</span>
                      ))}
                    </div>
                    <p class="text-xs text-muted-foreground mt-3 opacity-0 group-hover:opacity-100 transition-opacity" data-i18n="projects.clickToFlip">
                      Click to see more
                    </p>
                  </div>
                  <!-- Back of card -->
                  <div class="card-back absolute inset-0 backface-hidden rounded-xl border bg-card p-6 flex flex-col rotate-y-180">
                    <h4 class="font-semibold text-sm text-muted-foreground mb-2" data-i18n="projects.what">What is it?</h4>
                    <p class="text-sm mb-3 project-what">{project.content.en.what}</p>
                    <h4 class="font-semibold text-sm text-muted-foreground mb-2" data-i18n="projects.learned">What I learned</h4>
                    <p class="text-sm mb-3 project-learned">{project.content.en.learned}</p>
                    <h4 class="font-semibold text-sm text-muted-foreground mb-2" data-i18n="projects.why">Why?</h4>
                    <p class="text-sm flex-1 project-why">{project.content.en.why}</p>
                  </div>
                </div>
              </article>
            ))}
          </div>
        </section>
      )}

      <!-- Completed Section -->
      {completedProjects.length > 0 && (
        <section class="mb-12">
          <h2 class="text-2xl font-semibold mb-6 flex items-center gap-2">
            <span class="w-3 h-3 rounded-full bg-green-500"></span>
            <span data-i18n="projects.completed">Completed</span>
          </h2>
          <div class="grid gap-6 md:grid-cols-2">
            {completedProjects.map((project) => (
              <article
                class="project-card group perspective"
                data-category={project.category}
                data-project-id={project.id}
                data-project-content={JSON.stringify(project.content)}
              >
                <div class="card-inner relative w-full h-64 transition-transform duration-500 transform-style-preserve-3d">
                  <div class="card-front absolute inset-0 backface-hidden rounded-xl border bg-card p-6 flex flex-col">
                    <div class="flex items-start justify-between mb-3">
                      <span class="text-2xl">{categoryIcons[project.category]}</span>
                      <span class={`text-xs px-2 py-1 rounded-full ${statusColors[project.status]}`}>
                        <span data-i18n={`projects.status.${project.status}`}>{project.status}</span>
                      </span>
                    </div>
                    <h3 class="text-xl font-bold mb-2 project-title">{project.content.en.title}</h3>
                    <p class="text-muted-foreground text-sm flex-1 project-description">{project.content.en.description}</p>
                    <div class="flex flex-wrap gap-1 mt-3">
                      {project.tags.slice(0, 4).map((tag) => (
                        <span class="text-xs px-2 py-0.5 rounded bg-muted">{tag}</span>
                      ))}
                    </div>
                    <p class="text-xs text-muted-foreground mt-3 opacity-0 group-hover:opacity-100 transition-opacity" data-i18n="projects.clickToFlip">
                      Click to see more
                    </p>
                  </div>
                  <div class="card-back absolute inset-0 backface-hidden rounded-xl border bg-card p-6 flex flex-col rotate-y-180">
                    <h4 class="font-semibold text-sm text-muted-foreground mb-2" data-i18n="projects.what">What is it?</h4>
                    <p class="text-sm mb-3 project-what">{project.content.en.what}</p>
                    <h4 class="font-semibold text-sm text-muted-foreground mb-2" data-i18n="projects.learned">What I learned</h4>
                    <p class="text-sm mb-3 project-learned">{project.content.en.learned}</p>
                    <h4 class="font-semibold text-sm text-muted-foreground mb-2" data-i18n="projects.why">Why?</h4>
                    <p class="text-sm flex-1 project-why">{project.content.en.why}</p>
                  </div>
                </div>
              </article>
            ))}
          </div>
        </section>
      )}

      <!-- Planned Section -->
      {plannedProjects.length > 0 && (
        <section class="mb-12">
          <h2 class="text-2xl font-semibold mb-6 flex items-center gap-2">
            <span class="w-3 h-3 rounded-full bg-blue-500"></span>
            <span data-i18n="projects.planned">Planned</span>
          </h2>
          <div class="grid gap-6 md:grid-cols-2">
            {plannedProjects.map((project) => (
              <article
                class="project-card group perspective"
                data-category={project.category}
                data-project-id={project.id}
                data-project-content={JSON.stringify(project.content)}
              >
                <div class="card-inner relative w-full h-64 transition-transform duration-500 transform-style-preserve-3d">
                  <div class="card-front absolute inset-0 backface-hidden rounded-xl border bg-card p-6 flex flex-col">
                    <div class="flex items-start justify-between mb-3">
                      <span class="text-2xl">{categoryIcons[project.category]}</span>
                      <span class={`text-xs px-2 py-1 rounded-full ${statusColors[project.status]}`}>
                        <span data-i18n={`projects.status.${project.status}`}>{project.status}</span>
                      </span>
                    </div>
                    <h3 class="text-xl font-bold mb-2 project-title">{project.content.en.title}</h3>
                    <p class="text-muted-foreground text-sm flex-1 project-description">{project.content.en.description}</p>
                    <div class="flex flex-wrap gap-1 mt-3">
                      {project.tags.slice(0, 4).map((tag) => (
                        <span class="text-xs px-2 py-0.5 rounded bg-muted">{tag}</span>
                      ))}
                    </div>
                    <p class="text-xs text-muted-foreground mt-3 opacity-0 group-hover:opacity-100 transition-opacity" data-i18n="projects.clickToFlip">
                      Click to see more
                    </p>
                  </div>
                  <div class="card-back absolute inset-0 backface-hidden rounded-xl border bg-card p-6 flex flex-col rotate-y-180">
                    <h4 class="font-semibold text-sm text-muted-foreground mb-2" data-i18n="projects.what">What is it?</h4>
                    <p class="text-sm mb-3 project-what">{project.content.en.what}</p>
                    <h4 class="font-semibold text-sm text-muted-foreground mb-2" data-i18n="projects.learned">What I learned</h4>
                    <p class="text-sm mb-3 project-learned">{project.content.en.learned}</p>
                    <h4 class="font-semibold text-sm text-muted-foreground mb-2" data-i18n="projects.why">Why?</h4>
                    <p class="text-sm flex-1 project-why">{project.content.en.why}</p>
                  </div>
                </div>
              </article>
            ))}
          </div>
        </section>
      )}
    </div>
  </div>
</BaseLayout>

<style>
  .perspective {
    perspective: 1000px;
  }

  .transform-style-preserve-3d {
    transform-style: preserve-3d;
  }

  .backface-hidden {
    backface-visibility: hidden;
    -webkit-backface-visibility: hidden;
  }

  .rotate-y-180 {
    transform: rotateY(180deg);
  }

  .card-inner.flipped {
    transform: rotateY(180deg);
  }

  .project-card {
    cursor: pointer;
  }

  .project-card.hidden {
    display: none;
  }

  .filter-btn {
    opacity: 0.6;
  }

  .filter-btn.active {
    opacity: 1;
    background-color: hsl(var(--primary) / 0.1);
    border-color: hsl(var(--primary));
  }
</style>

<script>
  import { languageStore, t, initLanguage } from '@/i18n';

  // Flip card functionality
  document.querySelectorAll('.project-card').forEach((card) => {
    card.addEventListener('click', () => {
      const inner = card.querySelector('.card-inner');
      inner?.classList.toggle('flipped');
    });
  });

  // Filter functionality
  const filterBtns = document.querySelectorAll('.filter-btn');
  const projectCards = document.querySelectorAll('.project-card');

  filterBtns.forEach((btn) => {
    btn.addEventListener('click', () => {
      const filter = btn.getAttribute('data-filter');

      // Update active state
      filterBtns.forEach((b) => b.classList.remove('active'));
      btn.classList.add('active');

      // Filter cards
      projectCards.forEach((card) => {
        const category = card.getAttribute('data-category');
        if (filter === 'all' || category === filter) {
          card.classList.remove('hidden');
        } else {
          card.classList.add('hidden');
        }
      });
    });
  });

  // i18n updates
  function updateTranslations() {
    const lang = languageStore.get();

    // Update static translations
    document.querySelectorAll('[data-i18n]').forEach((el) => {
      const key = el.getAttribute('data-i18n');
      if (key) {
        const translated = t(key);
        if (translated !== key) {
          el.textContent = translated;
        }
      }
    });

    // Update project content
    document.querySelectorAll('.project-card').forEach((card) => {
      const contentData = card.getAttribute('data-project-content');
      if (contentData) {
        try {
          const content = JSON.parse(contentData);
          const langContent = content[lang] || content.en;

          const titleEl = card.querySelector('.project-title');
          const descEl = card.querySelector('.project-description');
          const whatEl = card.querySelector('.project-what');
          const learnedEl = card.querySelector('.project-learned');
          const whyEl = card.querySelector('.project-why');

          if (titleEl) titleEl.textContent = langContent.title;
          if (descEl) descEl.textContent = langContent.description;
          if (whatEl) whatEl.textContent = langContent.what;
          if (learnedEl) learnedEl.textContent = langContent.learned;
          if (whyEl) whyEl.textContent = langContent.why;
        } catch (e) {
          // Ignore parse errors
        }
      }
    });
  }

  initLanguage();
  updateTranslations();

  languageStore.subscribe(() => {
    updateTranslations();
  });

  window.addEventListener('languageChange', () => {
    updateTranslations();
  });
</script>
