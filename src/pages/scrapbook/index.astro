---
import BaseLayout from "@/layouts/BaseLayout.astro";
import T from "@/components/T.astro";
import { getCollection, type CollectionEntry } from "astro:content";

const entries = (await getCollection("scrapbook")).sort(
  (a: CollectionEntry<"scrapbook">, b: CollectionEntry<"scrapbook">) => 
    new Date(b.data.date).getTime() - new Date(a.data.date).getTime()
);
---

<BaseLayout title="Devlog" description="Some development logs when I was building this site.">
  <div class="container mx-auto px-4 py-8 lg:py-12">
    <div class="max-w-3xl mx-auto">
      <header class="mb-8 text-center">
        <T key="scrapbook.title" tag="h1" class="text-4xl font-bold" />
        <T key="scrapbook.description" tag="p" class="mt-3 text-lg text-muted-foreground" />
      </header>

      {entries.length === 0 ? (
        <p class="text-muted-foreground">No entries yet.</p>
      ) : (
        <ol class="space-y-6">
          {entries.map((entry: CollectionEntry<"scrapbook">) => (
            <li class="relative pl-6">
              <span class="absolute left-0 top-2 h-2 w-2 rounded-full bg-primary" aria-hidden="true" />

              <div class="rounded-lg border bg-card p-5">
                <time
                  class="block font-mono text-sm text-muted-foreground"
                  datetime={entry.data.date.toISOString()}
                  data-date={entry.data.date.toISOString()}
                >
                  {entry.data.date.toLocaleDateString("en", {
                    year: "numeric",
                    month: "long",
                    day: "numeric",
                  })}
                </time>

                <p
                  class="mt-3 text-muted-foreground"
                  data-scrapbook-content={JSON.stringify(entry.data.content)}
                >
                  {entry.data.content.en}
                </p>
              </div>
            </li>
          ))}
        </ol>
      )}
    </div>
  </div>
</BaseLayout>

<script>
  import { languageStore, initLanguage } from "@/i18n";

  initLanguage();

  function updateScrapbook() {
    const lang = languageStore.get();

    // Update dates
    document.querySelectorAll("time[data-date]").forEach((el) => {
      const dateStr = el.getAttribute("data-date");
      if (!dateStr) return;

      const date = new Date(dateStr);
      if (Number.isNaN(date.getTime())) return;

      el.textContent = date.toLocaleDateString(lang, {
        year: "numeric",
        month: "long",
        day: "numeric",
      });
    });

    // Update scrapbook content
    document.querySelectorAll("[data-scrapbook-content]").forEach((el) => {
      const contentStr = el.getAttribute("data-scrapbook-content");
      if (!contentStr) return;

      try {
        const content = JSON.parse(contentStr);
        const translatedText = content[lang] || content.en;
        el.textContent = translatedText;
      } catch (e) {
        console.error("Failed to parse scrapbook content:", e);
      }
    });
  }

  updateScrapbook();
  languageStore.subscribe(updateScrapbook);
  window.addEventListener("languageChange", updateScrapbook);
  document.addEventListener("astro:after-swap", updateScrapbook);
</script>
