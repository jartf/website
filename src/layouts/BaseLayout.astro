---
// Base Layout for website

import "@/styles/globals.css";
import Header from "@/components/layout/Header.astro";
import Footer from "@/components/layout/Footer.astro";
import Galaxy from "@/components/layout/Galaxy.astro";
import BarListener from "@/components/layout/BarListener.astro";
import Banners from "@/components/layout/Banners.astro";
import { hrefLangLanguages, siteUrl, siteName, siteDescription, siteKeywords, author, socialLinks, alternativeDomains, services, themeColors } from "@/lib/constants";
import { localePath, stripLocale } from "@/i18n/routing";

const analyticsWebsiteIds = services.analytics.websiteIds;
const analyticsScriptUrl = services.analytics.scriptUrl;

interface BreadcrumbItem {
  name: string;
  url: string;
}

interface MetaTag {
  name?: string;
  property?: string;
  content: string;
}

interface Props {
  title?: string;
  description?: string;
  isHomePage?: boolean;
  lang?: string;
  breadcrumbs?: BreadcrumbItem[];
  structuredData?: unknown | unknown[];
  keywords?: string | string[];
  canonicalUrl?: string;
  ogType?: string;
  ogImage?: string;
  metaTags?: MetaTag[];
}

const {
  title = siteName,
  description = siteDescription,
  isHomePage = false,
  lang: langProp,
  breadcrumbs = [],
  structuredData: structuredDataProp = [],
  keywords = siteKeywords,
  canonicalUrl,
  ogType = "website",
  ogImage,
  metaTags = [],
} = Astro.props;

const lang = langProp || Astro.locals?.lang || "en";
const basePath = stripLocale(Astro.url.pathname);

const extraStructuredData = Array.isArray(structuredDataProp)
  ? structuredDataProp
  : structuredDataProp
    ? [structuredDataProp]
    : [];

const fullTitle = isHomePage ? title : `${title} - ${siteName}`;
const canonicalHref = canonicalUrl ?? new URL(localePath(lang, basePath), siteUrl).href;
const resolvedKeywords = Array.isArray(keywords) ? keywords.join(", ") : keywords;
const resolvedOgImage = ogImage
  ? /^https?:\/\//.test(ogImage)
    ? ogImage
    : new URL(ogImage, siteUrl).href
  : `${siteUrl}/android-chrome-512x512.png`;

const defaultBreadcrumbs: BreadcrumbItem[] = (() => {
  const pathname = Astro.url.pathname;
  const segments = pathname.split("/").filter(Boolean);

  const isBlogDatedPath =
    segments[0] === "blog" &&
    /^\d{4}$/.test(segments[1] ?? "") &&
    /^(0?[1-9]|1[0-2])$/.test(segments[2] ?? "");

  const items: BreadcrumbItem[] = [
    {
      name: "Home",
      url: siteUrl,
    },
  ];

  if (segments.length === 0) return items;

  const titleCrumb = title?.trim();
  const prettify = (segment: string) =>
    decodeURIComponent(segment)
      .replace(/[-_]+/g, " ")
      .replace(/\b\w/g, (c) => c.toUpperCase());

  segments.forEach((segment, index) => {
    const partialPath = `/${segments.slice(0, index + 1).join("/")}`;
    const isLast = index === segments.length - 1;

    // For blog posts stored at /blog/YYYY/MM/slug, skip YYYY and MM crumbs
    if (isBlogDatedPath && (index === 1 || index === 2)) return;

    items.push({
      name: isLast && titleCrumb ? titleCrumb : prettify(segment),
      url: new URL(partialPath, siteUrl).href,
    });
  });

  return items;
})();

const personName = author.name;
const personEmail = author.email;
const personNote = author.note;
const personImage = `${siteUrl}${author.image}`;
const personKeyUrl = `${siteUrl}${author.keyUrl}`;
const personSameAs = [
  ...alternativeDomains,
  socialLinks.github,
];
// Map site language codes to Open Graph locale values
const ogLocaleMap: Record<string, string> = {
  en: "en_US",
  vi: "vi_VN",
  "vi-Hani": "vi_VN",
  zh: "zh_CN",
  ru: "ru_RU",
  da: "da_DK",
  et: "et_EE",
  tr: "tr_TR",
  pl: "pl_PL",
  sv: "sv_SE",
  fi: "fi_FI",
  tok: "en_US",
};

const ogLocale = ogLocaleMap[lang] ?? "en_US";

const structuredDataGraph: any[] = [
  {
    "@type": "Person",
    "@id": `${siteUrl}/#person`,
    name: personName,
    url: siteUrl,
    image: personImage,
    email: `mailto:${personEmail}`,
    sameAs: personSameAs,
  },
  {
    "@type": "WebSite",
    "@id": `${siteUrl}/#website`,
    url: siteUrl,
    name: siteName,
    description: siteDescription,
    inLanguage: lang,
    publisher: { "@id": `${siteUrl}/#person` },
  },
];

const breadcrumbItems = breadcrumbs.length > 0 ? breadcrumbs : defaultBreadcrumbs;

const breadcrumbStructuredData = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  itemListElement: breadcrumbItems.map((item, index) => ({
    "@type": "ListItem",
    position: index + 1,
    name: item.name,
    item: item.url,
  })),
};

const structuredData = {
  "@context": "https://schema.org",
  "@graph": structuredDataGraph,
};
---

<!doctype html>
<!--- Hello from Jarema :D --->
<!--- My code's a lil messy, please bear with me :p --->
<html lang={lang} data-locale={lang} class="dark">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="generator" content={Astro.generator} />

    <!-- Primary Meta Tags -->
    <title>{fullTitle}</title>
    <meta name="title" content={fullTitle} />
    <meta name="description" content={description} />
    <meta name="keywords"
      content={resolvedKeywords}
    />
    <meta name="author" content={author.name} />

    <!-- Favicons -->
    <link rel="icon" href="/favicon.png" type="image/png" />
    <link rel="alternate icon" href="/favicon.ico" />
    <link rel="apple-touch-icon" href="/apple-touch-icon.png" />
    <link rel="manifest" href="/site.webmanifest" />

    <!-- Theme colors -->
    <meta name="theme-color" content={themeColors.dark} media="(prefers-color-scheme: dark)" />
    <meta name="theme-color" content={themeColors.light} media="(prefers-color-scheme: light)" />

    <!-- Open Graph / Facebook -->
    <meta property="og:type" content={ogType} />
    <meta property="og:url" content={canonicalHref} />
    <meta property="og:title" content={fullTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={resolvedOgImage} />
    <meta property="og:site_name" content={siteName} />
    <meta property="og:locale" content={ogLocale} />

    <!-- Twitter -->
    <meta name="twitter:card" content="summary" />
    <meta name="twitter:title" content={fullTitle} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={resolvedOgImage} />

    {metaTags.map((tag) => (
      tag.property ? (
        <meta property={tag.property} content={tag.content} />
      ) : tag.name ? (
        <meta name={tag.name} content={tag.content} />
      ) : null
    ))}

    <!-- Identity verification -->
    <link rel="me" href={socialLinks.github} />
    <link rel="me" href={socialLinks.pronounsPage} />

    <!-- IndieAuth endpoints -->
    <link rel="authorization_endpoint" href={services.indieAuth.authEndpoint} />
    <link rel="token_endpoint" href={services.indieAuth.tokenEndpoint} />

    <!-- Webmention endpoint -->
    <link rel="webmention" href={services.webmention.endpoint} />
    <link rel="microsub" href={services.webmention.microsubEndpoint} />
    <link rel="pingback" href={services.webmention.pingbackEndpoint} />

    <!-- RSS/Atom Feeds -->
    <link rel="alternate" type="application/rss+xml" href={`${siteUrl}/rss.xml`} title={`${siteName} - RSS Feed`} />
    <link rel="alternate" type="application/atom+xml" href={`${siteUrl}/atom.xml`} title={`${siteName} - Atom Feed`} />
    <link rel="alternate" type="application/json" href={`${siteUrl}/feed.json`} title={`${siteName} - JSON Feed`} />

    <!-- Alternate language feeds -->
    {hrefLangLanguages.map((lang) => (
      <>
        <link rel="alternate" type="application/rss+xml" href={`${siteUrl}/rss/${lang.code}.xml`} title={`RSS Feed - ${lang.code.toUpperCase()}`} hreflang={lang.code} />
        <link rel="alternate" type="application/atom+xml" href={`${siteUrl}/atom/${lang.code}.xml`} title={`Atom Feed - ${lang.code.toUpperCase()}`} hreflang={lang.code} />
      </>
    ))}

    <!-- hreflang tags -->
    <link rel="canonical" href={canonicalHref} />
    {hrefLangLanguages.map((l) => (
        <link rel="alternate" hreflang={l.code} href={new URL(localePath(l.code, basePath), siteUrl).href} />
      ))}
    <link rel="alternate" hreflang="x-default" href={new URL(basePath, siteUrl).href} />

    <!-- Structured data -->
    <script type="application/ld+json" is:inline set:html={JSON.stringify(structuredData)}></script>
    <script type="application/ld+json" is:inline set:html={JSON.stringify(breadcrumbStructuredData)}></script>
    {extraStructuredData.map((data) => (
      <script type="application/ld+json" is:inline set:html={JSON.stringify(data)}></script>
    ))}

    <!-- Theme initialization script (runs before page render) -->
    <script is:inline>
      (function () {
        try {
          var stored = localStorage.getItem("theme");
          var resolved = stored === "light" ? "light"
            : stored === "system" ? (window.matchMedia("(prefers-color-scheme: dark)").matches ? "dark" : "light")
            : "dark";
          document.documentElement.classList.remove("light", "dark");
          document.documentElement.classList.add(resolved);
          document.documentElement.style.colorScheme = resolved;
        } catch (e) {
          document.documentElement.classList.add("dark");
        }
      })();
    </script>


    <script is:inline define:vars={{ analyticsWebsiteIds, analyticsScriptUrl }}>
      (function () {
        try {
          const host = location.hostname;

          // Don't load analytics on development
          if (
            host === "localhost" ||
            host === "127.0.0.1" ||
            host === "::1" ||
            host === "0.0.0.0" ||
            host.startsWith("127.")
          ) {
            return;
          }

          // Use website IDs from constants
          const websiteIds = analyticsWebsiteIds;

          // Default to jarema.me ID
          let siteId = websiteIds["jarema.me"];

          // Check if running on alternative domain
          if (host === "z.is-a.dev" || host.endsWith(".z.is-a.dev")) {
            siteId = websiteIds["z.is-a.dev"];
          }

          const s = document.createElement("script");
          s.defer = true;
          s.src = analyticsScriptUrl;
          s.setAttribute("data-website-id", siteId);
          document.head.appendChild(s);
        } catch (e) {
          // Silence errors during script injection
        }
      })();
    </script>

    <style>
      .emoji-flag {
        font-family: "Twemoji Country Flags", "Twemoji Mozilla", "Noto Color Emoji", "Apple Color Emoji", "Segoe UI Emoji", "Segoe UI Symbol", sans-serif;
        font-variant-emoji: emoji;
      }
    </style>
  </head>
  <body class="min-h-screen bg-background">
    <!-- h-card -->
    <div class="sr-only">
      <div class="h-card vcard">
        <a class="p-name u-url u-uid fn url uid" href={siteUrl}>{personName}</a>
        <img class="u-photo u-logo photo logo" src={personImage} alt="" />
        <span class="p-note note">{personNote}</span>
        <a class="u-email email" href={`mailto:${personEmail}`}>{personEmail}</a>
        <a class="u-key key" href={personKeyUrl}>{personKeyUrl}</a>
        <span class="p-category category">{author.category}</span>
        <span class="p-country-name country-name">{author.country}</span>

        {personSameAs.map((url) => (
          <a class="u-url url" rel="me" href={url}>{url}</a>
        ))}

        <!-- Mark h-card as representative for current page URL -->
        <a class="u-url url" rel="me" href={Astro.url.href}>{Astro.url.href}</a>
      </div>
    </div>

    <Galaxy />

    <div class="flex flex-col min-h-screen relative z-10">
      <nav aria-label="Skip navigation">
        <a
          href="#main-content"
          class="sr-only focus:not-sr-only focus:absolute focus:top-4 focus:left-4 focus:z-[100] focus:bg-background focus:text-foreground focus:px-4 focus:py-2 focus:rounded-md focus:shadow-lg focus:ring-2 focus:ring-ring focus:outline-none"
        >
          Skip to main content
        </a>
      </nav>

      <Header />

      <main id="main-content" class="flex-1">
        <slot />
      </main>

      <Footer />
    </div>

    <BarListener transition:persist />
    <Banners transition:persist />
  </body>
</html>
