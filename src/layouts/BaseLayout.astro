---
// Base Layout for website

import "@/styles/globals.css";
import Header from "@/components/Header.astro";
import Footer from "@/components/Footer.astro";
import Galaxy from "@/components/Galaxy.astro";
import { KeyboardNavigation } from "@/components/KeyboardNavigation";
import { CommandBarLazy } from "@/components/CommandBarLazy";
import { FirstVisitHint } from "@/components/FirstVisitHint";
import { LanguageNotice } from "@/components/LanguageNotice";
import { EasterEgg } from "@/components/EasterEgg";
import { hrefLangLanguages } from "@/lib/constants";

interface Props {
  title?: string;
  description?: string;
  isHomePage?: boolean;
  lang?: string;
}

const {
  title = "Jarema's digital garden",
  description = "This site is the personal playground and digital garden for Jarema. I write some blog posts, sometimes content about economics, coding, and occasionally I post some cats too.",
  isHomePage = false,
  lang = "en",
} = Astro.props;

const siteUrl = "https://jarema.me";
const fullTitle = isHomePage ? title : `${title} - Jarema's digital garden`;

const personName = "Jarema";
const personEmail = "hello@jarema.me";
const personNote = "Economics major, sometimes coder, most times cat whisperer.";
const personImage = `${siteUrl}/favicons.png`;
const personKeyUrl = `${siteUrl}/keys/gpg`;
const personSameAs = [
  "https://github.com/jartf",
  "https://pronouns.page/@jerryv",
];
// Map site language codes to Open Graph locale values
const ogLocaleMap: Record<string, string> = {
  en: "en_US",
  vi: "vi_VN",
  vih: "vi_VN",
  zh: "zh_CN",
  ru: "ru_RU",
  da: "da_DK",
  et: "et_EE",
  tr: "tr_TR",
  pl: "pl_PL",
  sv: "sv_SE",
  fi: "fi_FI",
  tok: "en_US",
};

const ogLocale = ogLocaleMap[lang] ?? "en_US";
---

<!doctype html>
<html lang={lang === "vih" ? "vi" : lang} class="dark">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="generator" content={Astro.generator} />

    <!-- Primary Meta Tags -->
    <title>{fullTitle}</title>
    <meta name="title" content={fullTitle} />
    <meta name="description" content={description} />
    <meta name="keywords"
      content="Jarema, jartf, digital garden, personal website, blog, economics, coding, tech, multilingual, student, cat, personal blog, digital playground, independent blog, independent writer, indie web, technology, now page, about page, personal reflections, ideas, thoughts, observation journal, how to build a personal site, economics and coding personal site"
    />
    <meta name="author" content="Jarema" />

    <!-- Favicons -->
    <link rel="icon" href="/favicon.png" type="image/png" />
    <link rel="alternate icon" href="/favicon.ico" />
    <link rel="apple-touch-icon" href="/apple-touch-icon.png" />
    <link rel="manifest" href="/site.webmanifest" />

    <!-- Theme colors -->
    <meta name="theme-color" content="#2c2e84" media="(prefers-color-scheme: dark)" />
    <meta name="theme-color" content="#ffffff" media="(prefers-color-scheme: light)" />

    <!-- Open Graph / Facebook -->
    <meta property="og:type" content="website" />
    <meta property="og:url" content={siteUrl} />
    <meta property="og:title" content={fullTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={`${siteUrl}/android-chrome-512x512.png`} />
    <meta property="og:site_name" content="Jarema's digital garden" />
    <meta property="og:locale" content={ogLocale} />

    <!-- Twitter -->
    <meta name="twitter:card" content="summary" />
    <meta name="twitter:title" content={fullTitle} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={`${siteUrl}/android-chrome-512x512.png`} />

    <!-- Identity verification -->
    <link rel="me" href="https://github.com/jartf" />
    <link rel="me" href="https://pronouns.page/@jerryv" />

    <!-- IndieAuth endpoints -->
    <link rel="authorization_endpoint" href="https://indieauth.com/auth" />
    <link rel="token_endpoint" href="https://tokens.indieauth.com/token" />

    <!-- Webmention endpoint -->
    <link rel="webmention" href="https://webmention.io/jarema.me/webmention" />
    <link rel="microsub" href="https://aperture.p3k.io/microsub/1060" />

    <!-- RSS/Atom Feeds -->
    <link rel="alternate" type="application/rss+xml" href={`${siteUrl}/rss.xml`} title="Jarema's digital garden - RSS Feed" />
    <link rel="alternate" type="application/atom+xml" href={`${siteUrl}/atom.xml`} title="Jarema's digital garden - Atom Feed" />
    <link rel="alternate" type="application/json" href={`${siteUrl}/feed.json`} title="Jarema's digital garden - JSON Feed" />

    <!-- Alternate language feeds -->
    {hrefLangLanguages.map((lang) => (
      <>
        <link rel="alternate" type="application/rss+xml" href={`${siteUrl}/rss/${lang.code}.xml`} title={`RSS Feed - ${lang.code.toUpperCase()}`} hreflang={lang.code} />
        <link rel="alternate" type="application/atom+xml" href={`${siteUrl}/atom/${lang.code}.xml`} title={`Atom Feed - ${lang.code.toUpperCase()}`} hreflang={lang.code} />
      </>
    ))}

    <!-- hreflang tags -->
    <link rel="canonical" href={Astro.url.href} />
    {hrefLangLanguages.map((lang) => (
        <link rel="alternate" hreflang={lang.code} href={Astro.url.href} />
      ))}
    <link rel="alternate" hreflang="x-default" href={Astro.url.href} />

    <!-- Structured data -->
    <script type="application/ld+json" is:inline>
      {JSON.stringify({
        "@context": "https://schema.org",
        "@graph": [
          {
            "@type": "Person",
            "@id": `${siteUrl}/#person`,
            name: personName,
            url: siteUrl,
            image: personImage,
            email: `mailto:${personEmail}`,
            sameAs: personSameAs,
          },
          {
            "@type": "WebSite",
            "@id": `${siteUrl}/#website`,
            url: siteUrl,
            name: "Jarema's digital garden",
            description: "Personal playground and digital garden.",
            inLanguage: lang === "vih" ? "vi" : lang,
            publisher: { "@id": `${siteUrl}/#person` },
          },
        ],
      })}
    </script>

    <!-- Theme initialization script (runs before page render) -->
    <script is:inline>
      (function () {
        try {
          const stored = localStorage.getItem("theme");
          // Default to dark mode if no preference is stored
          const theme = stored === "dark" || stored === "light" ? stored : "dark";
          document.documentElement.classList.remove("light", "dark");
          document.documentElement.classList.add(theme);
          document.documentElement.style.colorScheme = theme;
        } catch (e) {
          // Fallback to dark mode
          document.documentElement.classList.add("dark");
        }
      })();
    </script>

    <!-- Language initialization script (runs before page render) -->
    <script is:inline>
      (function () {
        try {
          const stored = localStorage.getItem("i18nextLng");
          const lang = stored || "en";

          // Set lang attribute immediately
          document.documentElement.lang = lang === "vih" ? "vi" : lang;

          // Store the detected language for quick access
          window.__INITIAL_LANG__ = lang;

          // Avoid flashes of English content: hide translatable text until i18n applies.
          if (lang && lang !== "en") {
            document.documentElement.classList.add("i18n-pending");
          }
        } catch (e) {
          window.__INITIAL_LANG__ = "en";
          document.documentElement.lang = "en";
        }
      })();
    </script>

    <!-- i18n runtime (single initializer + View Transitions re-apply) -->
    <script>
      import { applyDomTranslations, initLanguage, languageStore } from "@/i18n";

      // Avoid duplicate listeners/subscriptions across View Transitions.
      // (Astro may execute head scripts on navigation.)
      if (!(window as any).__I18N_RUNTIME_INIT__) {
        (window as any).__I18N_RUNTIME_INIT__ = true;

        initLanguage();
        applyDomTranslations(document);

        document.documentElement.classList.remove("i18n-pending");

        // Prevent FOEC during View Transitions swaps.
        document.addEventListener("astro:before-swap", () => {
          document.documentElement.classList.add("i18n-updating");
        });

        const apply = () => applyDomTranslations(document);
        window.addEventListener("languageChange", apply);
        document.addEventListener("astro:after-swap", apply);
        languageStore.subscribe(apply);
      }
    </script>

    <script is:inline>
      (function () {
        try {
          const host = location.hostname;

          // Don't load analytics on development
          if (
            host === "localhost" ||
            host === "127.0.0.1" ||
            host === "::1" ||
            host === "0.0.0.0" ||
            host.startsWith("127.")
          ) {
            return;
          }

          // Default website ID for jarema.me
          let siteId = "2e9dfa41-fbe7-4799-9adb-0a57b8141a54";

          // If running on z.is-a.dev use the alternate website ID
          if (host === "z.is-a.dev" || host.endsWith(".z.is-a.dev")) {
            siteId = "bea729d4-bbf9-494e-a4d9-bcbf2a2ab2f3";
          }

          const s = document.createElement("script");
          s.defer = true;
          s.src = "/stats/script.js";
          s.setAttribute("data-website-id", siteId);
          document.head.appendChild(s);
        } catch (e) {
          // Silence errors during script injection
        }
      })();
    </script>

    <style>
      .emoji-flag {
        font-family: "Twemoji Country Flags", "Twemoji Mozilla", "Noto Color Emoji", "Apple Color Emoji", "Segoe UI Emoji", "Segoe UI Symbol", sans-serif;
        font-variant-emoji: emoji;
      }
    </style>
  </head>
  <body class="min-h-screen bg-background">
    <!-- h-card -->
    <div class="sr-only">
      <div class="h-card vcard">
        <a class="p-name u-url u-uid fn url uid" href={siteUrl}>{personName}</a>
        <img class="u-photo u-logo photo logo" src={personImage} alt="" />
        <span class="p-note note">{personNote}</span>
        <a class="u-email email" href={`mailto:${personEmail}`}>{personEmail}</a>
        <a class="u-key key" href={personKeyUrl}>{personKeyUrl}</a>
        <span class="p-category category">student</span>
        <span class="p-country-name country-name">Vietnam/Estonia</span>

        {personSameAs.map((url) => (
          <a class="u-url url" rel="me" href={url}>{url}</a>
        ))}

        <!-- Mark h-card as representative for current page URL -->
        <a class="u-url url" rel="me" href={Astro.url.href}>{Astro.url.href}</a>
      </div>
    </div>

    <Galaxy />

    <div class="flex flex-col min-h-screen relative z-10">
      <nav aria-label="Skip navigation">
        <a
          href="#main-content"
          class="sr-only focus:not-sr-only focus:absolute focus:top-4 focus:left-4 focus:z-[100] focus:bg-background focus:text-foreground focus:px-4 focus:py-2 focus:rounded-md focus:shadow-lg focus:ring-2 focus:ring-ring focus:outline-none"
        >
          Skip to main content
        </a>
      </nav>

      <Header />

      <main id="main-content" class="flex-1">
        <slot />
      </main>

      <Footer />
    </div>

    <!-- Global React components for keyboard navigation and search -->
    <!-- transition:persist keeps these components alive across page navigations -->
    <KeyboardNavigation client:only="react" transition:persist />
    <CommandBarLazy client:only="react" transition:persist />
    <FirstVisitHint client:only="react" transition:persist />

    <!-- Global notices/easter eggs -->
    <LanguageNotice client:only="react" transition:persist />
    <EasterEgg client:idle transition:persist />
  </body>
</html>
