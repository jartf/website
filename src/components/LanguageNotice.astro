---
// Language notice: warns when current language translation is incomplete
---

<div id="language-notice" class="fixed top-16 inset-x-0 z-50 flex justify-center p-4 hidden">
  <div class="bg-amber-100 dark:bg-amber-900 border border-amber-200 dark:border-amber-800 text-amber-800 dark:text-amber-100 px-4 py-3 rounded-lg shadow-md flex items-center max-w-xl">
    <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="mr-3 flex-shrink-0" aria-hidden="true">
      <circle cx="12" cy="12" r="10" /><line x1="12" x2="12" y1="8" y2="12" /><line x1="12" x2="12.01" y1="16" y2="16" />
    </svg>
    <p id="language-notice-msg" class="text-sm" data-i18n="languageNotice.message"></p>
    <button id="language-notice-dismiss" class="ml-4 p-1 rounded-full hover:bg-amber-200 dark:hover:bg-amber-800 transition-colors" aria-label="Dismiss" data-i18n-aria="languageNotice.dismiss">
      <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
        <path d="M18 6 6 18" /><path d="m6 6 12 12" />
      </svg>
    </button>
  </div>
</div>

<script>
  import { languageStore, t } from "@/i18n";
  import { completedLanguages } from "@/lib/constants";

  const STORAGE_KEY = "languageNoticeDismissed";
  const el = document.getElementById("language-notice")!;
  const msg = document.getElementById("language-notice-msg")!;
  const btn = document.getElementById("language-notice-dismiss")!;

  let dismissed = false;
  try { dismissed = localStorage.getItem(STORAGE_KEY) === "true"; } catch {}

  function isComplete(lang: string): boolean {
    const base = lang.split("-")[0];
    return (completedLanguages as readonly string[]).some(
      l => lang === l || lang.startsWith(l + "-") || base === l
    );
  }

  function update(lang: string) {
    if (dismissed || isComplete(lang)) {
      el.classList.add("hidden");
    } else {
      msg.textContent = t("languageNotice.message");
      btn.setAttribute("aria-label", t("languageNotice.dismiss"));
      el.classList.remove("hidden");
    }
  }

  update(languageStore.get());
  languageStore.subscribe(update);

  btn.addEventListener("click", () => {
    dismissed = true;
    el.classList.add("hidden");
    try { localStorage.setItem(STORAGE_KEY, "true"); } catch {}
  });
</script>
