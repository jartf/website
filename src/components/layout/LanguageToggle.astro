---
// Language toggle
import { supportedLanguages } from "@/lib/constants";
import { localePath, stripLocale } from "@/i18n/routing";
import { t } from "@/i18n";

const lang = Astro.locals?.lang || "en";
const basePath = stripLocale(Astro.url.pathname);
const currentInfo = supportedLanguages.find(l => l.code === lang) || supportedLanguages[0];

const sections = [
  { key: "main",  label: t(lang, "language.main"),    langs: supportedLanguages.filter(l => "main" in l && l.main) },
  { key: "beta",  label: t(lang, "language.beta"),     langs: supportedLanguages.filter(l => "beta" in l && l.beta) },
  { key: "other", label: t(lang, "language.other"),    langs: supportedLanguages.filter(l => "other" in l && l.other) },
];
const itemCls = "lang-item relative flex items-center rounded-sm px-2 py-1.5 text-sm transition-colors hover:bg-accent hover:text-accent-foreground";
---

<details id="lang-toggle" class="group relative">
  <summary
    class="inline-flex items-center justify-center whitespace-nowrap rounded-md text-sm font-medium transition-colors focus-visible:outline-none focus-visible:ring-1 focus-visible:ring-ring border border-input bg-background shadow-sm hover:bg-accent hover:text-accent-foreground h-9 px-3 cursor-pointer list-none [&::-webkit-details-marker]:hidden"
    aria-label={`${currentInfo.name} - Select language`}
  >
    <span class="mr-2">{currentInfo.flag}</span>
    <span>{currentInfo.name}</span>
    <svg class="ml-2 h-4 w-4 transition-transform group-open:rotate-180" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor" aria-hidden="true">
      <path fill-rule="evenodd" d="M5.293 7.293a1 1 0 011.414 0L10 10.586l3.293-3.293a1 1 0 111.414 1.414l-4 4a1 1 0 01-1.414 0l-4-4a1 1 0 010-1.414z" clip-rule="evenodd" />
    </svg>
  </summary>

  <div class="absolute right-0 mt-2 w-80 rounded-md border bg-popover p-1 text-popover-foreground shadow-md z-50 max-h-96 overflow-y-auto">
    <div class="px-2 py-2">
      <input id="lang-search" type="text" placeholder={t(lang, "language.search")} aria-label={t(lang, "language.search")}
        class="w-full px-3 py-1.5 text-sm rounded-md border bg-background focus:outline-none focus:ring-1 focus:ring-ring" />
    </div>

    {sections.map(({ label, langs }, i) => (
      <div class="lang-section-group">
        {i > 0 && <div class="my-1 h-px bg-border" />}
        <div class="px-2 py-1.5 text-xs font-semibold text-muted-foreground">{label}</div>
        <div class="grid grid-cols-2 gap-1 lang-section">
          {langs.map(l => (
            <a
              href={localePath(l.code, basePath)}
              class:list={[itemCls, l.code === lang && "bg-accent"]}
              data-search={`${l.name} ${l.code} ${l.aliases?.join(" ") ?? ""}`}
              aria-label={l.name}
            >
              <span class="mr-2">{l.flag}</span>
              <span class="truncate">{l.name}</span>
              {l.code === lang && (
                <svg class="ml-auto h-4 w-4 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
                </svg>
              )}
            </a>
          ))}
        </div>
      </div>
    ))}
  </div>
</details>

<script is:inline>
  // Progressive enhancement: search filtering + click-outside-to-close.
  (function () {
    const details = document.getElementById("lang-toggle");
    const search = document.getElementById("lang-search");
    if (!details || !search) return;

    function filter(q) {
      q = q.toLowerCase();
      details.querySelectorAll(".lang-item").forEach(function (el) {
        el.classList.toggle("hidden", q !== "" && !(el.dataset.search || "").toLowerCase().includes(q));
      });
      details.querySelectorAll(".lang-section-group").forEach(function (g) {
        g.classList.toggle("hidden", !g.querySelector(".lang-item:not(.hidden)"));
      });
    }

    search.addEventListener("input", function () { filter(search.value); });

    // Close on outside click
    document.addEventListener("click", function (e) {
      if (details.open && !details.contains(e.target)) details.open = false;
    });

    // Reset search when closed
    details.addEventListener("toggle", function () {
      if (!details.open) { search.value = ""; filter(""); }
    });
  })();
</script>
