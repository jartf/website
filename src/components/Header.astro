---
// Static header

import { navItems, author } from "@/lib/constants";
import T from "@/components/T.astro";
import { LanguageToggle } from "@/components/LanguageToggle";
import { Image } from "astro:assets";

const isActivePath = (pathname: string, href: string) => {
  if (href === "/" && pathname !== "/") return false;
  return pathname === href || pathname.startsWith(href);
};

const pathname = Astro.url.pathname;
const navState = navItems.map((item) => ({ ...item, isActive: isActivePath(pathname, item.href) }));
const navBaseClasses = "text-sm transition-colors hover:text-primary whitespace-nowrap focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-ring focus-visible:ring-offset-2 focus-visible:ring-offset-background rounded-sm";
const navActiveClass = "text-foreground font-medium";
const navInactiveClass = "text-muted-foreground";

---

<header class="sticky top-0 z-50 w-full border-b bg-background/80 backdrop-blur-sm">
  <div class="container flex h-16 items-center justify-between px-4">
    <div class="flex items-center gap-2 min-w-0 flex-1">
      <!-- Logo -->
      <div class="flex-shrink-0">
        <a href="/" class="flex items-center gap-2 transition-opacity hover:opacity-80 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-ring focus-visible:ring-offset-2 focus-visible:ring-offset-background rounded-md" aria-label={`${author.name} - Homepage`}>
          <div class="relative size-8 overflow-hidden">
            <Image src="/favicon.png" alt={`${author.name}'s logo`} width={32} height={32} class="size-8" aria-hidden="true" loading="eager" fetchpriority="high" />
          </div>
          <span class="font-heading font-bold text-xl sm:inline-block">{author.displayName}</span>
        </a>
      </div>

      <!-- Desktop navigation -->
      <nav class="hidden lg:flex items-center ml-6 min-w-0" aria-label="Main navigation">
        <div class="flex items-center gap-4 lg:gap-6">
          {navState.map(({ href, key, isActive }) => (
            <a
              href={href}
              data-nav-key={key}
              data-nav-item="true"
              class:list={[navBaseClasses, isActive ? navActiveClass : navInactiveClass]}
              aria-current={isActive ? "page" : undefined}
            >
              <T key={`nav.${key}`} />
              {isActive && (
                <div class="h-0.5 bg-primary mt-0.5" aria-hidden="true" />
              )}
            </a>
          ))}
        </div>
      </nav>
    </div>

    <div class="flex items-center gap-1.5 md:gap-2 flex-shrink-0">
      <!-- Language toggle (React) -->
      <LanguageToggle client:only="react" transition:persist />

      <!-- Settings menu -->
      <details id="settings-menu" class="group relative">
        <summary class="p-2 rounded-md hover:bg-muted transition-colors cursor-pointer list-none [&::-webkit-details-marker]:hidden focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-ring focus-visible:ring-offset-2 focus-visible:ring-offset-background" aria-label="Settings">
          <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <path d="M12.22 2h-.44a2 2 0 0 0-2 2v.18a2 2 0 0 1-1 1.73l-.43.25a2 2 0 0 1-2 0l-.15-.08a2 2 0 0 0-2.73.73l-.22.38a2 2 0 0 0 .73 2.73l.15.1a2 2 0 0 1 1 1.72v.51a2 2 0 0 1-1 1.74l-.15.09a2 2 0 0 0-.73 2.73l.22.38a2 2 0 0 0 2.73.73l.15-.08a2 2 0 0 1 2 0l.43.25a2 2 0 0 1 1 1.73V20a2 2 0 0 0 2 2h.44a2 2 0 0 0 2-2v-.18a2 2 0 0 1 1-1.73l.43-.25a2 2 0 0 1 2 0l.15.08a2 2 0 0 0 2.73-.73l.22-.39a2 2 0 0 0-.73-2.73l-.15-.08a2 2 0 0 1-1-1.74v-.5a2 2 0 0 1 1-1.74l.15-.09a2 2 0 0 0 .73-2.73l-.22-.38a2 2 0 0 0-2.73-.73l-.15.08a2 2 0 0 1-2 0l-.43-.25a2 2 0 0 1-1-1.73V4a2 2 0 0 0-2-2z" />
            <circle cx="12" cy="12" r="3" />
          </svg>
        </summary>
        <div class="absolute right-0 top-full mt-2 w-72 rounded-md border bg-background/95 backdrop-blur-sm shadow-lg py-3 px-4 z-50 space-y-4" role="menu" aria-label="Settings">
          <!-- Theme -->
          <div class="flex items-center justify-between">
            <div class="flex items-center gap-2.5">
              <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-muted-foreground" aria-hidden="true">
                <path d="M12.22 2h-.44a2 2 0 0 0-2 2v.18a2 2 0 0 1-1 1.73l-.43.25a2 2 0 0 1-2 0l-.15-.08a2 2 0 0 0-2.73.73l-.22.38a2 2 0 0 0 .73 2.73l.15.1a2 2 0 0 1 1 1.72v.51a2 2 0 0 1-1 1.74l-.15.09a2 2 0 0 0-.73 2.73l.22.38a2 2 0 0 0 2.73.73l.15-.08a2 2 0 0 1 2 0l.43.25a2 2 0 0 1 1 1.73V20a2 2 0 0 0 2 2h.44a2 2 0 0 0 2-2v-.18a2 2 0 0 1 1-1.73l.43-.25a2 2 0 0 1 2 0l.15.08a2 2 0 0 0 2.73-.73l.22-.39a2 2 0 0 0-.73-2.73l-.15-.08a2 2 0 0 1-1-1.74v-.5a2 2 0 0 1 1-1.74l.15-.09a2 2 0 0 0 .73-2.73l-.22-.38a2 2 0 0 0-2.73-.73l-.15.08a2 2 0 0 1-2 0l-.43-.25a2 2 0 0 1-1-1.73V4a2 2 0 0 0-2-2z" />
                <circle cx="12" cy="12" r="3" />
              </svg>
              <span class="text-sm font-medium">Theme</span>
            </div>
            <div class="flex rounded-md border border-border overflow-hidden" role="radiogroup" aria-label="Theme selection">
              <button data-set-theme="system" class="settings-theme-btn px-2.5 py-1 text-xs font-medium transition-colors" role="radio" aria-checked="false" aria-label="Auto (system theme)">Auto</button>
              <button data-set-theme="light" class="settings-theme-btn px-2 py-1 transition-colors border-x border-border" role="radio" aria-checked="false" aria-label="Light theme">
                <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                  <circle cx="12" cy="12" r="4" />
                  <path d="M12 2v2" /><path d="M12 20v2" />
                  <path d="m4.93 4.93 1.41 1.41" /><path d="m17.66 17.66 1.41 1.41" />
                  <path d="M2 12h2" /><path d="M20 12h2" />
                  <path d="m6.34 17.66-1.41 1.41" /><path d="m19.07 4.93-1.41 1.41" />
                </svg>
              </button>
              <button data-set-theme="dark" class="settings-theme-btn px-2 py-1 transition-colors" role="radio" aria-checked="false" aria-label="Dark theme">
                <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                  <path d="M12 3a6 6 0 0 0 9 9 9 9 0 1 1-9-9Z" />
                </svg>
              </button>
            </div>
          </div>

          <!-- Music -->
          <div class="flex items-center justify-between">
            <div class="flex items-center gap-2.5">
              <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-muted-foreground" aria-hidden="true">
                <path d="M11 5 6 9H2v6h4l5 4V5Z" />
                <line x1="23" x2="17" y1="9" y2="15" />
                <line x1="17" x2="23" y1="9" y2="15" />
              </svg>
              <div>
                <span class="text-sm font-medium">Music</span>
                <p class="text-xs text-muted-foreground">Currently unavailable</p>
              </div>
            </div>
            <button
              type="button"
              disabled
              aria-pressed="false"
              aria-label="Music currently unavailable"
              class="relative inline-flex h-5 w-9 shrink-0 cursor-not-allowed items-center rounded-full border border-border bg-muted opacity-50 transition-colors"
            >
              <span class="pointer-events-none block size-4 rounded-full bg-muted-foreground shadow-sm translate-x-0.5 transition-transform" aria-hidden="true"></span>
            </button>
          </div>
        </div>
      </details>

      <!-- Mobile hamburger menu -->
      <details class="group lg:hidden relative">
        <summary class="p-2 rounded-md hover:bg-muted transition-colors cursor-pointer list-none [&::-webkit-details-marker]:hidden focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-ring" aria-label="Toggle navigation menu">
          <svg class="group-open:hidden" xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M4 6h16M4 12h16M4 18h16"/></svg>
          <svg class="hidden group-open:block" xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M18 6 6 18M6 6l12 12"/></svg>
        </summary>
        <nav
          class="absolute right-0 top-full mt-2 w-48 rounded-md border bg-background/95 backdrop-blur-sm shadow-lg py-2 z-50"
          aria-label="Mobile navigation"
        >
          {navState.map(({ href, key, isActive }) => (
            <a
              href={href}
              class:list={[
                "block px-4 py-2 text-sm transition-colors hover:bg-muted focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-ring focus-visible:ring-inset",
                isActive ? "text-foreground font-medium bg-muted/50" : "text-muted-foreground",
              ]}
              aria-current={isActive ? "page" : undefined}
            >
              <T key={`nav.${key}`} />
            </a>
          ))}
        </nav>
      </details>
    </div>
  </div>
</header>

<script>
  import { applyTheme } from '@/lib/theme-utils';

  function initSettingsMenu() {
    const themeBtns = document.querySelectorAll<HTMLButtonElement>('.settings-theme-btn');
    if (!themeBtns.length) return;

    const activeClasses = 'bg-primary text-primary-foreground';
    const inactiveClasses = 'text-muted-foreground hover:bg-muted';

    const updateThemeButtons = () => {
      const current = localStorage.getItem('theme') || 'system';
      themeBtns.forEach((btn) => {
        const isActive = btn.dataset.setTheme === current;
        btn.setAttribute('aria-checked', String(isActive));
        // Reset classes
        btn.classList.remove(...activeClasses.split(' '), ...inactiveClasses.split(' '));
        btn.classList.add(...(isActive ? activeClasses : inactiveClasses).split(' '));
      });
    };

    updateThemeButtons();

    themeBtns.forEach((btn) => {
      // Prevent duplicate listeners across View Transitions
      const clone = btn.cloneNode(true) as HTMLButtonElement;
      btn.replaceWith(clone);
      clone.addEventListener('click', () => {
        const theme = clone.dataset.setTheme;
        if (theme) {
          applyTheme(theme);
          // Re-query after clone replacements
          initSettingsMenu();
        }
      });
    });

    // Close settings menu when clicking outside
    const details = document.getElementById('settings-menu') as HTMLDetailsElement | null;
    if (details) {
      const closeOnOutsideClick = (e: MouseEvent) => {
        if (details.open && !details.contains(e.target as Node)) {
          details.open = false;
        }
      };
      document.removeEventListener('click', closeOnOutsideClick);
      document.addEventListener('click', closeOnOutsideClick);
    }
  }

  initSettingsMenu();
  document.addEventListener('astro:after-swap', initSettingsMenu);
</script>
