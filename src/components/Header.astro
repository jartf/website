---
// Static header

import { navItems, author } from "@/lib/constants";
import T from "@/components/T.astro";
import { LanguageToggle } from "@/components/LanguageToggle";
import { Image } from "astro:assets";

const isActivePath = (pathname: string, href: string) => {
  if (href === "/" && pathname !== "/") return false;
  return pathname === href || pathname.startsWith(href);
};

const pathname = Astro.url.pathname;
const navState = navItems.map((item) => ({ ...item, isActive: isActivePath(pathname, item.href) }));
const navBaseClasses = "text-sm transition-colors hover:text-primary whitespace-nowrap focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-ring focus-visible:ring-offset-2 focus-visible:ring-offset-background rounded-sm";
const navActiveClass = "text-foreground font-medium";
const navInactiveClass = "text-muted-foreground";

---

<header class="sticky top-0 z-50 w-full border-b bg-background/80 backdrop-blur-sm">
  <div class="container flex h-16 items-center justify-between px-4">
    <div class="flex items-center gap-2 min-w-0 flex-1">
      <!-- Logo -->
      <div class="flex-shrink-0">
        <a href="/" class="flex items-center gap-2 transition-opacity hover:opacity-80 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-ring focus-visible:ring-offset-2 focus-visible:ring-offset-background rounded-md" aria-label={`${author.name} - Homepage`}>
          <div class="relative size-8 overflow-hidden">
            <Image src="/favicon.png" alt={`${author.name}'s logo`} width={32} height={32} class="size-8" aria-hidden="true" loading="eager" fetchpriority="high" />
          </div>
          <span class="font-heading font-bold text-xl sm:inline-block">{author.displayName}</span>
        </a>
      </div>

      <!-- Desktop navigation -->
      <nav class="hidden lg:flex items-center ml-6 min-w-0" aria-label="Main navigation">
        <div class="flex items-center gap-4 lg:gap-6">
          {navState.map(({ href, key, isActive }) => (
            <a
              href={href}
              data-nav-key={key}
              data-nav-item="true"
              class:list={[navBaseClasses, isActive ? navActiveClass : navInactiveClass]}
              aria-current={isActive ? "page" : undefined}
            >
              <T key={`nav.${key}`} />
              {isActive && (
                <div class="h-0.5 bg-primary mt-0.5" aria-hidden="true" />
              )}
            </a>
          ))}
        </div>
      </nav>
    </div>

    <div class="flex items-center gap-1.5 md:gap-2 flex-shrink-0">
      <!-- Language toggle (React) -->
      <LanguageToggle client:only="react" transition:persist />

      <!-- Theme toggle -->
      <button
        id="theme-toggle"
        class="p-2 rounded-md hover:bg-muted transition-colors focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-ring focus-visible:ring-offset-2 focus-visible:ring-offset-background"
        aria-label="Toggle theme"
        title="Toggle theme"
      >
        <svg id="theme-toggle-dark-icon" class="hidden" xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <path d="M12 3a6 6 0 0 0 9 9 9 9 0 1 1-9-9Z" />
        </svg>
        <svg id="theme-toggle-light-icon" class="hidden" xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <circle cx="12" cy="12" r="4" />
          <path d="M12 2v2" />
          <path d="M12 20v2" />
          <path d="m4.93 4.93 1.41 1.41" />
          <path d="m17.66 17.66 1.41 1.41" />
          <path d="M2 12h2" />
          <path d="M20 12h2" />
          <path d="m6.34 17.66-1.41 1.41" />
          <path d="m19.07 4.93-1.41 1.41" />
        </svg>
      </button>

      <!-- Music toggle (disabled placeholder) -->
      <button
        type="button"
        disabled
        aria-pressed="false"
        aria-label="Music currently unavailable"
        aria-describedby="music-disabled-reason"
        title="Music currently unavailable"
        class="p-2 rounded-md hover:bg-muted transition-colors opacity-50 cursor-not-allowed"
      >
        <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <path d="M11 5 6 9H2v6h4l5 4V5Z" />
          <line x1="23" x2="17" y1="9" y2="15" />
          <line x1="17" x2="23" y1="9" y2="15" />
        </svg>
        <span id="music-disabled-reason" class="sr-only">Background music feature is currently disabled as no audio file is configured</span>
      </button>
    </div>
  </div>

  <!-- Mobile navigation bar -->
  <nav
    class="lg:hidden border-t bg-background/95 backdrop-blur-sm"
    aria-label="Mobile navigation"
  >
    <div class="container px-4 py-2">
      <div class="flex items-center justify-center gap-3 md:gap-5 gap-y-1 flex-wrap">
        {navState.map(({ href, key, isActive }) => (
          <a
            href={href}
            class:list={[`${navBaseClasses} py-1`, isActive ? navActiveClass : navInactiveClass]}
            aria-current={isActive ? "page" : undefined}
          >
            <T key={`nav.${key}`} />
            {isActive && (
              <div class="h-0.5 bg-primary mt-0.5" aria-hidden="true" />
            )}
          </a>
        ))}
      </div>
    </div>
  </nav>
</header>

<script>
  import { applyTheme } from '@/lib/theme-utils';

  function initThemeToggle() {
    const button = document.getElementById("theme-toggle");
    const darkIcon = document.getElementById("theme-toggle-dark-icon");
    const lightIcon = document.getElementById("theme-toggle-light-icon");
    if (!button || !darkIcon || !lightIcon) return;

    const updateIcons = (isDark: boolean) => {
      darkIcon.classList.toggle("hidden", !isDark);
      lightIcon.classList.toggle("hidden", isDark);
      const label = `Switch to ${isDark ? "light" : "dark"} mode`;
      button.setAttribute("aria-label", label);
      button.setAttribute("title", label);
    };

    updateIcons(document.documentElement.classList.contains("dark"));

    // Prevent duplicate listeners across View Transitions
    button.replaceWith(button.cloneNode(true));
    document.getElementById("theme-toggle")?.addEventListener("click", () => {
      const isDark = document.documentElement.classList.contains("dark");
      const next = isDark ? "light" : "dark";
      applyTheme(next);
      updateIcons(next === "dark");
    });
  }

  initThemeToggle();
  document.addEventListener("astro:after-swap", initThemeToggle);
</script>
