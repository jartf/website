---
import { navItems, author } from "@/lib/constants";
import T from "@/components/T.astro";
import LanguageToggle from "@/components/LanguageToggle.astro";
import { Image } from "astro:assets";
import { localePath, stripLocale } from "@/i18n/routing";

const lang = Astro.locals?.lang || "en";
const pathname = Astro.url.pathname;
const basePath = stripLocale(pathname);
const isActive = (href: string) => href === "/" ? basePath === "/" : basePath.startsWith(href);
const navState = navItems.map((item) => ({ ...item, href: localePath(lang, item.href), active: isActive(item.href) }));

const navBase = "text-sm transition-colors hover:text-primary whitespace-nowrap focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-ring focus-visible:ring-offset-2 focus-visible:ring-offset-background rounded-sm";

// Reused SVG path data
const gearPath = "M12.22 2h-.44a2 2 0 0 0-2 2v.18a2 2 0 0 1-1 1.73l-.43.25a2 2 0 0 1-2 0l-.15-.08a2 2 0 0 0-2.73.73l-.22.38a2 2 0 0 0 .73 2.73l.15.1a2 2 0 0 1 1 1.72v.51a2 2 0 0 1-1 1.74l-.15.09a2 2 0 0 0-.73 2.73l.22.38a2 2 0 0 0 2.73.73l.15-.08a2 2 0 0 1 2 0l.43.25a2 2 0 0 1 1 1.73V20a2 2 0 0 0 2 2h.44a2 2 0 0 0 2-2v-.18a2 2 0 0 1 1-1.73l.43-.25a2 2 0 0 1 2 0l.15.08a2 2 0 0 0 2.73-.73l.22-.39a2 2 0 0 0-.73-2.73l-.15-.08a2 2 0 0 1-1-1.74v-.5a2 2 0 0 1 1-1.74l.15-.09a2 2 0 0 0 .73-2.73l-.22-.38a2 2 0 0 0-2.73-.73l-.15.08a2 2 0 0 1-2 0l-.43-.25a2 2 0 0 1-1-1.73V4a2 2 0 0 0-2-2z";
const iconBase = { xmlns: "http://www.w3.org/2000/svg", fill: "none", stroke: "currentColor", "stroke-width": "2", "stroke-linecap": "round" as const, "stroke-linejoin": "round" as const, viewBox: "0 0 24 24" };

// Toggle switch class constants
const toggleOn = "settings-toggle relative inline-flex h-5 w-9 shrink-0 cursor-pointer items-center rounded-full border border-border transition-colors bg-primary";
const toggleOff = "settings-toggle relative inline-flex h-5 w-9 shrink-0 cursor-pointer items-center rounded-full border border-border transition-colors bg-muted";
const knobOn = "pointer-events-none block size-4 rounded-full bg-white shadow-sm translate-x-4 transition-transform";
const knobOff = "pointer-events-none block size-4 rounded-full bg-muted-foreground shadow-sm translate-x-0.5 transition-transform";

// Settings toggle definitions (id, i18n key, default on)
const toggles = [
  { id: "settings-stars-toggle",    i18n: "settings.stars",        defaultOn: true  },
  { id: "settings-motion-toggle",   i18n: "settings.reduceMotion", defaultOn: false },
  { id: "settings-contrast-toggle", i18n: "settings.highContrast", defaultOn: false },
  { id: "settings-dyslexia-toggle", i18n: "settings.dyslexiaFont", defaultOn: false },
] as const;

// SVG icon fragments per toggle (keyed by id)
const toggleIcons: Record<string, string> = {
  "settings-stars-toggle": `<polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2" />`,
  "settings-motion-toggle": `<circle cx="12" cy="12" r="10" stroke-dasharray="3 3" />`,
  "settings-contrast-toggle": `<circle cx="12" cy="12" r="10" /><path d="M12 2a10 10 0 0 1 0 20z" fill="currentColor" />`,
  "settings-dyslexia-toggle": `<path d="M13 18L8 6L3 18M11 14H5M21 18V15M21 15V12M21 15C21 16.6569 19.6569 18 18 18C16.3431 18 15 16.6569 15 15C15 13.3431 16.3431 12 18 12C19.6569 12 21 13.3431 21 15Z" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>`,
};
---

<header class="sticky top-0 z-50 w-full border-b bg-background/80 backdrop-blur-sm">
  <div class="container flex h-16 items-center justify-between px-4">
    <div class="flex items-center gap-2 min-w-0 flex-1">
      <!-- Logo -->
      <div class="flex-shrink-0">
        <a href={localePath(lang, "/")} class="flex items-center gap-2 transition-opacity hover:opacity-80 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-ring focus-visible:ring-offset-2 focus-visible:ring-offset-background rounded-md" aria-label={`${author.name} - Homepage`}>
          <div class="relative size-8 overflow-hidden">
            <Image src="/favicon.png" alt={`${author.name}'s logo`} width={32} height={32} class="size-8" aria-hidden="true" loading="eager" fetchpriority="high" />
          </div>
          <span class="font-heading font-bold text-xl sm:inline-block">{author.displayName}</span>
        </a>
      </div>

      <!-- Desktop navigation -->
      <nav class="hidden lg:flex items-center ml-6 min-w-0" aria-label="Main navigation">
        <div class="flex items-center gap-4 lg:gap-6">
          {navState.map(({ href, key, active }) => (
            <a
              href={href}
              class:list={[navBase, active ? "text-foreground font-medium" : "text-muted-foreground"]}
              aria-current={active ? "page" : undefined}
            >
              <T key={`nav.${key}`} />
              {active && <div class="h-0.5 bg-primary mt-0.5" aria-hidden="true" />}
            </a>
          ))}
        </div>
      </nav>
    </div>

    <div class="flex items-center gap-1.5 md:gap-2 flex-shrink-0">
      <!-- Language toggle (React) -->
      <LanguageToggle transition:persist />

      <!-- Settings menu -->
      <details id="settings-menu" class="group relative">
        <summary class="p-2 rounded-md hover:bg-muted transition-colors cursor-pointer list-none [&::-webkit-details-marker]:hidden focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-ring focus-visible:ring-offset-2 focus-visible:ring-offset-background" aria-label="Settings">
          <svg {...iconBase} width="20" height="20" aria-hidden="true">
            <path d={gearPath} /><circle cx="12" cy="12" r="3" />
          </svg>
        </summary>
        <div class="absolute right-0 top-full mt-2 w-72 rounded-md border bg-background/95 backdrop-blur-sm shadow-lg py-3 px-4 z-50 space-y-4" role="group" aria-label="Settings">
          <T key="settings.title" tag="h3" class="text-lg font-semibold text-foreground" />
          <hr class="border-border" />

          <!-- Theme -->
          <div class="flex items-center justify-between">
            <div class="flex items-center gap-2.5">
              <svg {...iconBase} width="18" height="18" class="text-muted-foreground" aria-hidden="true">
                <path d={gearPath} /><circle cx="12" cy="12" r="3" />
              </svg>
              <T key="settings.theme" class="text-sm font-medium" />
            </div>
            <div class="flex rounded-md border border-border overflow-hidden" role="radiogroup" aria-label="Theme selection">
              <button data-set-theme="system" class="settings-theme-btn px-2.5 py-1 text-xs font-medium transition-colors" role="radio" aria-checked="false" aria-label="Auto (system theme)"><T key="settings.themeAuto" /></button>
              <button data-set-theme="light" class="settings-theme-btn px-2 py-1 transition-colors border-x border-border" role="radio" aria-checked="false" aria-label="Light theme">
                <svg {...iconBase} width="14" height="14" aria-hidden="true">
                  <circle cx="12" cy="12" r="4" />
                  <path d="M12 2v2" /><path d="M12 20v2" />
                  <path d="m4.93 4.93 1.41 1.41" /><path d="m17.66 17.66 1.41 1.41" />
                  <path d="M2 12h2" /><path d="M20 12h2" />
                  <path d="m6.34 17.66-1.41 1.41" /><path d="m19.07 4.93-1.41 1.41" />
                </svg>
              </button>
              <button data-set-theme="dark" class="settings-theme-btn px-2 py-1 transition-colors" role="radio" aria-checked="false" aria-label="Dark theme">
                <svg {...iconBase} width="14" height="14" aria-hidden="true">
                  <path d="M12 3a6 6 0 0 0 9 9 9 9 0 1 1-9-9Z" />
                </svg>
              </button>
            </div>
          </div>

          <!-- Toggle switches -->
          {toggles.map(({ id, i18n, defaultOn }) => (
            <div class="flex items-center justify-between">
              <div class="flex items-center gap-2.5">
                <svg {...iconBase} width="18" height="18" class="text-muted-foreground" aria-hidden="true">
                  <Fragment set:html={toggleIcons[id]} />
                </svg>
                <T key={i18n} class="text-sm font-medium" id={`${id}-label`} />
              </div>
              <button id={id} type="button" role="switch" aria-checked={defaultOn ? "true" : "false"} aria-labelledby={`${id}-label`}
                class={defaultOn ? toggleOn : toggleOff}>
                <span class={defaultOn ? knobOn : knobOff} aria-hidden="true"></span>
              </button>
            </div>
          ))}

          <hr class="border-border" />

          <!-- Timezone anchor -->
          <div class="flex items-center justify-between">
            <div class="flex items-center gap-2.5">
              <svg {...iconBase} width="18" height="18" class="text-muted-foreground" aria-hidden="true">
                <circle cx="12" cy="12" r="10" />
                <polyline points="12 6 12 12 16 14" />
              </svg>
              <T key="settings.timezone" class="text-sm font-medium" />
            </div>
            <div class="flex rounded-md border border-border overflow-hidden" role="radiogroup" aria-label="Timezone selection">
              <button data-set-tz="local" class="settings-tz-btn px-2.5 py-1 text-xs font-medium transition-colors" role="radio" aria-checked="true"><T key="settings.tzYours" /></button>
              <button data-set-tz="author" class="settings-tz-btn px-2.5 py-1 text-xs font-medium transition-colors border-l border-border" role="radio" aria-checked="false"><T key="settings.tzAuthor" /></button>
            </div>
          </div>

          <!-- Music (disabled) -->
          <div class="flex items-center justify-between">
            <div class="flex items-center gap-2.5">
              <svg {...iconBase} width="18" height="18" class="text-muted-foreground" aria-hidden="true">
                <path d="M11 5 6 9H2v6h4l5 4V5Z" />
                <line x1="23" x2="17" y1="9" y2="15" /><line x1="17" x2="23" y1="9" y2="15" />
              </svg>
              <div>
                <T key="settings.music" class="text-sm font-medium" />
                <T key="settings.musicUnavailable" tag="p" class="text-xs text-muted-foreground" />
              </div>
            </div>
            <button type="button" disabled aria-pressed="false" aria-label="Music currently unavailable"
              class={`${toggleOff} cursor-not-allowed opacity-50`}>
              <span class={knobOff} aria-hidden="true"></span>
            </button>
          </div>
        </div>
      </details>

      <!-- Mobile hamburger menu -->
      <details class="group lg:hidden relative">
        <summary class="p-2 rounded-md hover:bg-muted transition-colors cursor-pointer list-none [&::-webkit-details-marker]:hidden focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-ring" aria-label="Toggle navigation menu">
          <svg class="group-open:hidden" {...iconBase} width="20" height="20" aria-hidden="true"><path d="M4 6h16M4 12h16M4 18h16"/></svg>
          <svg class="hidden group-open:block" {...iconBase} width="20" height="20" aria-hidden="true"><path d="M18 6 6 18M6 6l12 12"/></svg>
        </summary>
        <nav class="absolute right-0 top-full mt-2 w-48 rounded-md border bg-background/95 backdrop-blur-sm shadow-lg py-2 z-50" aria-label="Mobile navigation">
          {navState.map(({ href, key, active }) => (
            <a
              href={href}
              class:list={[
                "block px-4 py-2 text-sm transition-colors hover:bg-muted focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-ring focus-visible:ring-inset",
                active ? "text-foreground font-medium bg-muted/50" : "text-muted-foreground",
              ]}
              aria-current={active ? "page" : undefined}
            >
              <T key={`nav.${key}`} />
            </a>
          ))}
        </nav>
      </details>
    </div>
  </div>
</header>

<script>
  import { applyTheme } from '@/lib/theme-utils';

  const ACTIVE = ['bg-primary', 'text-primary-foreground'];
  const INACTIVE = ['text-muted-foreground', 'hover:bg-muted'];

  function setToggle(btn: HTMLButtonElement, on: boolean) {
    btn.setAttribute('aria-checked', String(on));
    const knob = btn.querySelector('span');
    btn.classList.toggle('bg-primary', on);
    btn.classList.toggle('bg-muted', !on);
    knob?.classList.toggle('translate-x-4', on);
    knob?.classList.toggle('translate-x-0.5', !on);
    knob?.classList.toggle('bg-white', on);
    knob?.classList.toggle('bg-muted-foreground', !on);
  }

  function bindToggle(id: string, key: string, onUpdate: (on: boolean) => void) {
    const btn = document.getElementById(id) as HTMLButtonElement | null;
    if (!btn) return;
    const on = (localStorage.getItem(key) ?? (btn.getAttribute('aria-checked') === 'true' ? 'true' : 'false')) === 'true';
    setToggle(btn, on);
    onUpdate(on);
    btn.onclick = () => {
      const next = btn.getAttribute('aria-checked') !== 'true';
      localStorage.setItem(key, String(next));
      setToggle(btn, next);
      onUpdate(next);
    };
  }

  function updateRadioGroup(selector: string, storageKey: string, fallback: string) {
    const current = localStorage.getItem(storageKey) || fallback;
    document.querySelectorAll<HTMLButtonElement>(selector).forEach((btn) => {
      const active = Object.values(btn.dataset)[0] === current;
      btn.setAttribute('aria-checked', String(active));
      ACTIVE.forEach(c => btn.classList.toggle(c, active));
      INACTIVE.forEach(c => btn.classList.toggle(c, !active));
    });
  }

  let ac: AbortController;

  function init() {
    ac?.abort();
    ac = new AbortController();
    const { signal } = ac;

    updateRadioGroup('.settings-theme-btn', 'theme', 'system');
    updateRadioGroup('.settings-tz-btn', 'timezone-anchor', 'local');

    document.querySelectorAll<HTMLButtonElement>('.settings-theme-btn').forEach((btn) => {
      btn.addEventListener('click', () => {
        if (btn.dataset.setTheme) {
          applyTheme(btn.dataset.setTheme);
          updateRadioGroup('.settings-theme-btn', 'theme', 'system');
        }
      }, { signal });
    });

    document.querySelectorAll<HTMLButtonElement>('.settings-tz-btn').forEach((btn) => {
      btn.addEventListener('click', () => {
        if (btn.dataset.setTz) {
          localStorage.setItem('timezone-anchor', btn.dataset.setTz);
          updateRadioGroup('.settings-tz-btn', 'timezone-anchor', 'local');
          document.dispatchEvent(new CustomEvent('timezone-change'));
        }
      }, { signal });
    });

    bindToggle('settings-stars-toggle', 'stars-enabled', (on) =>
      document.documentElement.toggleAttribute('data-no-stars', !on));

    bindToggle('settings-contrast-toggle', 'high-contrast', (on) =>
      document.documentElement.classList.toggle('high-contrast', on));

    bindToggle('settings-dyslexia-toggle', 'dyslexia-font', (on) =>
      document.documentElement.classList.toggle('dyslexia-font', on));

    bindToggle('settings-motion-toggle', 'reduce-motion', (on) => {
      document.documentElement.classList.toggle('reduce-motion', on);
      const starsBtn = document.getElementById('settings-stars-toggle') as HTMLButtonElement | null;
      if (!starsBtn) return;
      if (on) {
        // Force stars off and disable the toggle
        setToggle(starsBtn, false);
        document.documentElement.toggleAttribute('data-no-stars', true);
        starsBtn.disabled = true;
        starsBtn.classList.add('opacity-50', 'cursor-not-allowed');
        starsBtn.classList.remove('cursor-pointer');
      } else {
        // Re-enable and restore saved preference
        starsBtn.disabled = false;
        starsBtn.classList.remove('opacity-50', 'cursor-not-allowed');
        starsBtn.classList.add('cursor-pointer');
        const saved = (localStorage.getItem('stars-enabled') ?? 'true') === 'true';
        setToggle(starsBtn, saved);
        document.documentElement.toggleAttribute('data-no-stars', !saved);
      }
    });

    const menu = document.getElementById('settings-menu') as HTMLDetailsElement | null;
    if (menu) {
      document.addEventListener('click', (e) => {
        if (menu.open && !menu.contains(e.target as Node)) menu.open = false;
      }, { signal });
    }

  }

  init();
  document.addEventListener('astro:after-swap', init);
</script>
