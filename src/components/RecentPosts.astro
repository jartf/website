---
// Recent Posts component with i18n
import { getCollection, type CollectionEntry } from "astro:content";
import T from "@/components/T.astro";

type RecentPost = {
  slug: string;
  title: string;
  excerpt: string;
  dateISO: string;
  dateMs: number;
  readingTime: number;
  dateTextEn: string;
};

const dateFormatOptions: Intl.DateTimeFormatOptions = { year: "numeric", month: "short", day: "numeric" };
const dateFormatter = new Intl.DateTimeFormat("en", dateFormatOptions);

const posts: RecentPost[] = (await getCollection("blog", ({ data }: CollectionEntry<"blog">) => !data.draft))
  .sort((a: CollectionEntry<"blog">, b: CollectionEntry<"blog">) => b.data.date.getTime() - a.data.date.getTime())
  .slice(0, 3)
  .map((post: CollectionEntry<"blog">) => {
    const dateISO = post.data.date.toISOString();
    return {
      slug: post.slug,
      title: post.data.title,
      excerpt: post.data.excerpt ?? "No excerpt available",
      dateISO,
      dateMs: post.data.date.getTime(),
      readingTime: post.data.readingTime ?? 5,
      dateTextEn: dateFormatter.format(post.data.date),
    };
  });
---

<section aria-labelledby="recent-posts-heading">
  <h2 id="recent-posts-heading" class="text-2xl font-bold mb-4 text-center">
    <a href="/blog/" tabindex="-1" class="no-underline hover:underline focus:underline" style="color:inherit">
      <T key="home.recentPosts" />
    </a>
  </h2>
  <div class="space-y-4">
    {posts.map((post, index) => (
      <article class="border rounded-lg p-4 bg-card card-hover-effect group">
        <a href={`/blog/${post.slug}/`} class="block">
          <div class="flex items-start justify-between gap-4">
            <div class="flex-1 min-w-0">
              <h3 class="font-semibold text-lg group-hover:text-primary transition-colors line-clamp-1">
                {post.title}
              </h3>
              <p class="text-sm text-muted-foreground mt-1 line-clamp-2">
                {post.excerpt}
              </p>
              <div class="flex items-center gap-3 mt-2 text-xs text-muted-foreground">
                <time datetime={post.dateISO} data-date-ms={post.dateMs}>
                  {post.dateTextEn}
                </time>
                <span>•</span>
                <span class="reading-time"><span data-reading-time>{post.readingTime}</span> <T key="blog.minRead" /></span>
              </div>
            </div>
            <div class="flex-shrink-0 text-2xl text-muted-foreground dark:text-muted-foreground/60 font-bold">
              {String(index + 1).padStart(2, '0')}
            </div>
          </div>
        </a>
      </article>
    ))}
  </div>
  <div class="text-center mt-4">
    <a href="/blog/" class="inline-flex items-center gap-2 px-4 py-2 text-sm font-medium border rounded-lg hover:bg-accent transition-colors">
      <T key="nav.blog" />
      <span>→</span>
    </a>
  </div>
</section>

<script>
  import { languageStore, initLanguage } from '@/i18n';

  const dateFormatOptions: Intl.DateTimeFormatOptions = { year: 'numeric', month: 'short', day: 'numeric' };
  const rootSelector = 'section[aria-labelledby="recent-posts-heading"]';

  function updateDates(lang?: string) {
    const locale = typeof lang === 'string' && lang ? lang : languageStore.get();
    const formatter = new Intl.DateTimeFormat(locale, dateFormatOptions);
    document.querySelectorAll(`${rootSelector} [data-date-ms]`).forEach((el) => {
      const dateMs = el.getAttribute('data-date-ms');
      if (!dateMs) return;
      el.textContent = formatter.format(new Date(Number(dateMs)));
    });
  }

  const initialLang = (window as any).__INITIAL_LANG__;
  if (initialLang && initialLang !== 'en') {
    languageStore.set(initialLang);
  } else {
    initLanguage();
  }

  updateDates();
  window.addEventListener('languageChange', (e) => updateDates((e as CustomEvent<string>)?.detail));
</script>
