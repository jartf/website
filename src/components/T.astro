---
// Translation component for Astro

import { translations, supportedLanguages, type SupportedLanguage, getNestedValue, translateWithParams } from "@/i18n";

interface Props {
  key: string;
  params?: Record<string, string | number>;
  tag?: string;
  class?: string;
  [key: string]: any;
}

const { key, params, tag = "span", class: className, ...rest } = Astro.props;

// Pre-render translations for all languages for this key.
const translatedTexts: Record<string, string> = {};
supportedLanguages.forEach((lang) => {
  const langCode = lang.code as SupportedLanguage;
  const trans = translations[langCode] || translations.en;
  let value = getNestedValue(trans, key);

  // Fallback to English
  if (!value && langCode !== "en") {
    value = getNestedValue(translations.en, key);
  }

  if (value) {
    translatedTexts[langCode] = translateWithParams(value, params);
  }
});

const Tag = tag as any;
---

<Tag class={className} data-t-key={key} {...rest}>
  {translatedTexts["en"] || key}
</Tag>

<script is:inline define:vars={{ translatedTexts, tKey: key }}>
  function getInitialLang() {
    try {
      return window.__INITIAL_LANG__ || localStorage.getItem("i18nextLng") || "en";
    } catch (_) {
      return "en";
    }
  }

  function updateTranslation() {
    const currentLang = getInitialLang();
    const text = translatedTexts[currentLang] || translatedTexts["en"] || tKey;

    document.querySelectorAll(`[data-t-key="${tKey}"]`).forEach((element) => {
      if (element.textContent !== text) element.textContent = text;
    });
  }

  updateTranslation();
  window.addEventListener("languageChange", updateTranslation);
  document.addEventListener("astro:after-swap", updateTranslation);
</script>
