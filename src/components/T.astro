---
// Server-side translation component
import { t } from "@/i18n";

interface Props {
  key: string;
  params?: Record<string, string | number>;
  tag?: string;
  class?: string;
  [key: string]: any;
}

const { key, params, tag = "span", class: className, ...rest } = Astro.props;
const lang = Astro.locals?.lang || "en";
const Tag = tag as any;
---

<Tag class={className} {...rest}>{t(lang, key, params)}</Tag>
