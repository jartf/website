---
// Recent posts component
import { getCollection, type CollectionEntry } from "astro:content";
import T from "@/components/T.astro";
import { routes } from "@/lib/constants";
import { localePath } from "@/i18n/routing";

const lang = Astro.locals?.lang || "en";

type RecentPost = {
  slug: string;
  title: string;
  excerpt: string;
  dateISO: string;
  readingTime: number;
  dateTextEn: string;
};

const posts: RecentPost[] = (await getCollection("blog", ({ data }: CollectionEntry<"blog">) => !data.draft))
  .sort((a: CollectionEntry<"blog">, b: CollectionEntry<"blog">) => b.data.date.getTime() - a.data.date.getTime())
  .slice(0, 3)
  .map((post: CollectionEntry<"blog">) => ({
    slug: post.id,
    title: post.data.title,
    excerpt: post.data.excerpt ?? "No excerpt available",
    dateISO: post.data.date.toISOString(),
    readingTime: post.data.readingTime ?? 5,
    dateTextEn: post.data.date.toLocaleDateString(lang, { year: "numeric", month: "long", day: "numeric" }),
  }));
---

<section aria-labelledby="recent-posts-heading">
  <h2 id="recent-posts-heading" class="text-2xl font-bold mb-4 text-center">
    <a href={localePath(lang, routes.blog)} tabindex="-1" class="no-underline hover:underline focus:underline text-inherit">
      <T key="home.recentPosts" />
    </a>
  </h2>
  <div class="space-y-4">
    {posts.map((post, index) => (
      <article class="border rounded-lg p-4 bg-card card-hover-effect hover:scale-[1.02] group">
        <a href={localePath(lang, `/blog/${post.slug}/`)} class="block">
          <div class="flex items-start justify-between gap-4">
            <div class="flex-1 min-w-0">
              <h3 class="font-semibold text-lg group-hover:text-primary transition-colors line-clamp-1">
                {post.title}
              </h3>
              <p class="text-sm text-muted-foreground mt-1 line-clamp-2">
                {post.excerpt}
              </p>
              <div class="flex items-center gap-3 mt-2 text-xs text-muted-foreground">
                <time datetime={post.dateISO} data-date={post.dateISO}>
                  {post.dateTextEn}
                </time>
                <span>•</span>
                <span class="reading-time"><span data-reading-time>{post.readingTime}</span> <T key="blog.minRead" /></span>
              </div>
            </div>
            <div class="flex-shrink-0 text-2xl text-muted-foreground font-bold">
              {String(index + 1).padStart(2, '0')}
            </div>
          </div>
        </a>
      </article>
    ))}
  </div>
  <div class="text-center mt-4">
    <a href={localePath(lang, routes.blog)} class="inline-flex items-center gap-2 px-4 py-2 text-sm font-medium border rounded-lg hover:bg-accent transition-colors">
      <T key="nav.blog" />
      <span>→</span>
    </a>
  </div>
</section>

<script>
  import { updateDateElements } from '@/lib/utils/timezone-utils';

  function updateDates() {
    const locale = document.documentElement.dataset.locale || 'en';
    const root = document.querySelector('section[aria-labelledby="recent-posts-heading"]');
    if (root) updateDateElements(root, locale);
  }

  updateDates();
  document.addEventListener('timezone-change', updateDates);
</script>
